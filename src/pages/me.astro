---
import Layout from "../layouts/Layout.astro";

const scienceCards = [
  ["Matter", "Atoms gather like quiet alphabets, composing stone, ocean, skin, and star."],
  ["Life", "Chemistry learns rhythm; cells become memory, hunger, repair, and wonder."],
  ["Time", "Every civilization is a brief candle held against an ancient dark."],
  ["Cosmos", "The sky is not above us only; it is the archive from which we came."],
  ["Intelligence", "Mind turns experience into maps, tools, ethics, machines, and questions."],
];

const civilizationCards = [
  ["Astronomy", "Temples aligned with seasons, teaching people to read the heavens as calendars."],
  ["Writing", "Marks in clay made memory portable, fragile lives joining a longer human voice."],
  ["Architecture", "Stone became order: a geometry of shelter, ceremony, power, and prayer."],
];
---

<Layout
  title="The Memory of Earth | Ugurcan Yagiz"
  description="A surreal 3D digital experience exploring science, civilization, time, and the future."
>
  <section class="me-page" aria-label="The Memory of Earth interactive digital exhibition">
    <div class="cosmos-canvas" aria-hidden="true">
      <canvas id="memory-earth-scene"></canvas>
    </div>

    <section class="me-section hero" data-stage="0">
      <div class="hero-copy reveal">
        <p class="eyebrow">Interactive digital manifesto</p>
        <h1>The Memory of Earth</h1>
        <p class="hero-subtitle">A surreal journey through science, civilization, time, and the future.</p>
      </div>
      <div class="scroll-cue" aria-hidden="true">Scroll through time</div>
    </section>

    <section class="me-section origin" data-stage="1">
      <div class="section-copy narrow reveal">
        <p class="eyebrow">Origin</p>
        <h2>From Stardust to Consciousness</h2>
        <p>
          Before names, borders, and monuments, matter practiced patience. Dust became mineral,
          mineral became ocean, and life slowly discovered the courage to remember itself.
        </p>
        <p>
          Human awareness began as a spark inside nature: a fragile instrument capable of measuring
          the stars while still belonging to the soil.
        </p>
      </div>
    </section>

    <section class="me-section civilization" data-stage="2">
      <div class="section-copy reveal">
        <p class="eyebrow">Civilization</p>
        <h2>Civilization as a Dream of Order</h2>
        <p>
          We raised walls, observatories, libraries, and myths to make the invisible visible. Every
          ancient city was a negotiation between fear and imagination.
        </p>
      </div>
      <div class="artifact-grid">
        {civilizationCards.map(([title, text]) => (
          <article class="artifact-card reveal-card">
            <span class="artifact-glyph" aria-hidden="true">✦</span>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="me-section science" data-stage="3">
      <div class="section-copy reveal">
        <p class="eyebrow">Science</p>
        <h2>Science: The Language Beneath Reality</h2>
        <p>
          Science is not the opposite of poetry. It is a disciplined form of awe: a way of listening
          carefully enough that reality begins to answer.
        </p>
      </div>
      <div class="science-grid">
        {scienceCards.map(([title, text]) => (
          <article class="science-card reveal-card">
            <div class="card-orbit" aria-hidden="true"></div>
            <h3>{title}</h3>
            <p>{text}</p>
          </article>
        ))}
      </div>
    </section>

    <section class="me-section future" data-stage="4">
      <div class="section-copy narrow reveal">
        <p class="eyebrow">Future</p>
        <h2>The Future Is Not Built Yet</h2>
        <p>
          Artificial minds, distant worlds, repaired bodies, and new civilizations wait as unfinished
          sketches. The future asks for imagination, but also humility.
        </p>
        <p>
          What we build next should not merely be faster or brighter. It should be more conscious of
          the memory it inherits.
        </p>
      </div>
      <div class="horizon" aria-hidden="true"></div>
    </section>

    <section class="me-section closing" data-stage="5">
      <div class="closing-panel reveal">
        <p class="closing-line">Past is memory. Future is imagination. Humanity lives between them.</p>
        <p class="signature">Created by Ugurcan Yagiz</p>
        <a class="home-button" href="/">Back to Home</a>
      </div>
    </section>
  </section>
</Layout>

<script>
  import * as THREE from "https://esm.sh/three@0.181.2";
  import gsap from "https://esm.sh/gsap@3.13.0";
  import { ScrollTrigger } from "https://esm.sh/gsap@3.13.0/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const canvas = document.querySelector("#memory-earth-scene");
  const scene = new THREE.Scene();
  const renderer = new THREE.WebGLRenderer({ canvas, alpha: true, antialias: window.innerWidth > 760 });
  const camera = new THREE.PerspectiveCamera(42, window.innerWidth / window.innerHeight, 0.1, 100);
  const clock = new THREE.Clock();
  const pointer = new THREE.Vector2();
  const isMobile = window.matchMedia("(max-width: 700px)").matches;

  camera.position.set(0, 0.35, isMobile ? 8 : 6.4);
  renderer.setPixelRatio(Math.min(window.devicePixelRatio, isMobile ? 1.35 : 1.8));
  renderer.setSize(window.innerWidth, window.innerHeight);

  scene.add(new THREE.AmbientLight(0x6f7cff, 0.7));
  const keyLight = new THREE.PointLight(0x9ee7ff, 18, 20);
  keyLight.position.set(3, 4, 5);
  scene.add(keyLight);
  const emberLight = new THREE.PointLight(0xff9d6c, 9, 16);
  emberLight.position.set(-4, -2, 3);
  scene.add(emberLight);

  const world = new THREE.Group();
  scene.add(world);

  const planetMaterial = new THREE.MeshStandardMaterial({
    color: 0x172037,
    roughness: 0.48,
    metalness: 0.18,
    emissive: 0x101a36,
    emissiveIntensity: 0.72,
  });
  const planet = new THREE.Mesh(new THREE.IcosahedronGeometry(isMobile ? 1.45 : 1.85, 7), planetMaterial);
  world.add(planet);

  const wire = new THREE.Mesh(
    new THREE.IcosahedronGeometry(isMobile ? 1.49 : 1.9, 3),
    new THREE.MeshBasicMaterial({ color: 0x8ddfff, wireframe: true, transparent: true, opacity: 0.16 })
  );
  world.add(wire);

  const ringMaterial = new THREE.MeshBasicMaterial({ color: 0xd8b06a, transparent: true, opacity: 0.5, side: THREE.DoubleSide });
  for (let i = 0; i < 3; i++) {
    const ring = new THREE.Mesh(new THREE.TorusGeometry(isMobile ? 2.05 : 2.55, 0.006, 8, 180), ringMaterial.clone());
    ring.rotation.set(Math.PI / (2.8 + i), i * 0.72, i * 0.5);
    world.add(ring);
  }

  const particleCount = isMobile ? 380 : 900;
  const positions = new Float32Array(particleCount * 3);
  for (let i = 0; i < particleCount; i++) {
    const radius = 4 + Math.random() * (isMobile ? 5 : 8);
    const theta = Math.random() * Math.PI * 2;
    const phi = Math.acos(2 * Math.random() - 1);
    positions[i * 3] = radius * Math.sin(phi) * Math.cos(theta);
    positions[i * 3 + 1] = radius * Math.sin(phi) * Math.sin(theta) * 0.72;
    positions[i * 3 + 2] = radius * Math.cos(phi);
  }
  const particlesGeometry = new THREE.BufferGeometry();
  particlesGeometry.setAttribute("position", new THREE.BufferAttribute(positions, 3));
  const particles = new THREE.Points(
    particlesGeometry,
    new THREE.PointsMaterial({ color: 0xbddcff, size: isMobile ? 0.018 : 0.024, transparent: true, opacity: 0.62 })
  );
  scene.add(particles);

  document.addEventListener("pointermove", (event) => {
    pointer.x = (event.clientX / window.innerWidth - 0.5) * 2;
    pointer.y = (event.clientY / window.innerHeight - 0.5) * 2;
  }, { passive: true });

  gsap.utils.toArray(".reveal").forEach((element) => {
    gsap.fromTo(element, { autoAlpha: 0, y: 36, scale: 0.98 }, {
      autoAlpha: 1,
      y: 0,
      scale: 1,
      duration: 1.15,
      ease: "power3.out",
      scrollTrigger: { trigger: element, start: "top 82%" },
    });
  });

  gsap.utils.toArray(".reveal-card").forEach((element, index) => {
    gsap.fromTo(element, { autoAlpha: 0, y: 46, rotateX: 8 }, {
      autoAlpha: 1,
      y: 0,
      rotateX: 0,
      duration: 0.9,
      delay: (index % 5) * 0.06,
      ease: "power3.out",
      scrollTrigger: { trigger: element, start: "top 88%" },
    });
  });

  gsap.timeline({
    scrollTrigger: { trigger: ".me-page", start: "top top", end: "bottom bottom", scrub: 1.1 },
  })
    .to(world.rotation, { y: Math.PI * 1.7, x: 0.45, z: -0.2 }, 0)
    .to(world.position, { x: isMobile ? 0 : 1.2, y: -0.2, z: -0.8 }, 0)
    .to(camera.position, { x: isMobile ? 0 : -0.55, y: 0.8, z: isMobile ? 7.2 : 5.3 }, 0)
    .to(planetMaterial, { emissiveIntensity: 1.8, metalness: 0.45 }, 0.45)
    .to(particles.material, { opacity: 0.95, size: isMobile ? 0.024 : 0.034 }, 0.55);

  function animate() {
    const elapsed = clock.getElapsedTime();
    world.rotation.y += 0.0017;
    planet.rotation.x = elapsed * 0.035;
    wire.rotation.y = -elapsed * 0.055;
    particles.rotation.y = elapsed * 0.015;
    camera.position.x += (pointer.x * (isMobile ? 0.08 : 0.2) - camera.position.x) * 0.025;
    camera.position.y += (-pointer.y * (isMobile ? 0.05 : 0.12) + 0.35 - camera.position.y) * 0.018;
    camera.lookAt(0, 0, 0);
    renderer.render(scene, camera);
    requestAnimationFrame(animate);
  }
  animate();

  window.addEventListener("resize", () => {
    camera.aspect = window.innerWidth / window.innerHeight;
    camera.updateProjectionMatrix();
    renderer.setSize(window.innerWidth, window.innerHeight);
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, window.innerWidth < 700 ? 1.35 : 1.8));
  });
</script>

<style>
  :global(body:has(.me-page)) {
    background: #050710;
  }

  :global(body:has(.me-page) .topbar),
  :global(body:has(.me-page) .site-footer) {
    background: rgba(5, 7, 16, 0.72);
    border-color: rgba(255, 255, 255, 0.08);
  }

  :global(body:has(.me-page) .subnav) {
    display: none;
  }

  :global(body:has(.me-page) .brand),
  :global(body:has(.me-page) .footer-left),
  :global(body:has(.me-page) .icon-btn) {
    color: rgba(244, 238, 226, 0.82);
  }

  .me-page {
    position: relative;
    min-height: 100vh;
    overflow: clip;
    color: #f6efe4;
    background:
      radial-gradient(circle at 18% 12%, rgba(91, 124, 255, 0.25), transparent 34rem),
      radial-gradient(circle at 82% 48%, rgba(255, 159, 98, 0.18), transparent 30rem),
      linear-gradient(180deg, #050710 0%, #090b18 42%, #110d16 72%, #050710 100%);
  }

  .cosmos-canvas {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
  }

  #memory-earth-scene {
    width: 100%;
    height: 100%;
    display: block;
  }

  .me-section {
    position: relative;
    z-index: 1;
    min-height: 100vh;
    display: grid;
    align-content: center;
    gap: 2rem;
    padding: clamp(6rem, 11vw, 9rem) clamp(1.1rem, 5vw, 5rem);
  }

  .hero {
    place-items: center;
    text-align: center;
  }

  .hero-copy,
  .section-copy,
  .closing-panel {
    max-width: 820px;
    border: 1px solid rgba(255, 255, 255, 0.1);
    background: linear-gradient(135deg, rgba(255,255,255,0.11), rgba(255,255,255,0.035));
    box-shadow: 0 30px 120px rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(18px);
    border-radius: 32px;
    padding: clamp(1.4rem, 4vw, 3.4rem);
  }

  .hero-copy {
    max-width: 980px;
    background: linear-gradient(135deg, rgba(8, 11, 25, 0.28), rgba(255, 255, 255, 0.03));
    border-color: rgba(216, 176, 106, 0.18);
  }

  .narrow { max-width: 720px; }
  .origin .section-copy, .future .section-copy { margin-left: auto; }

  .eyebrow {
    margin: 0 0 1rem;
    color: #d8b06a;
    font-size: 0.78rem;
    letter-spacing: 0.24em;
    text-transform: uppercase;
  }

  h1, h2, h3, p { margin-top: 0; }
  h1 {
    margin-bottom: 1rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(3.6rem, 10vw, 9.5rem);
    line-height: 0.9;
    letter-spacing: -0.08em;
    text-wrap: balance;
  }

  h2 {
    margin-bottom: 1rem;
    font-family: Georgia, "Times New Roman", serif;
    font-size: clamp(2.35rem, 6vw, 5.6rem);
    line-height: 0.95;
    letter-spacing: -0.055em;
    text-wrap: balance;
  }

  h3 { margin-bottom: 0.65rem; font-size: 1.1rem; }
  p { color: rgba(246, 239, 228, 0.76); font-size: clamp(1rem, 1.6vw, 1.18rem); line-height: 1.75; }
  .hero-subtitle { max-width: 650px; margin: 0 auto; font-size: clamp(1.1rem, 2.4vw, 1.55rem); }

  .scroll-cue {
    position: absolute;
    bottom: 2rem;
    color: rgba(246, 239, 228, 0.55);
    font-size: 0.75rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
  }

  .artifact-grid, .science-grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: clamp(1rem, 2vw, 1.4rem);
    max-width: 1120px;
  }

  .science-grid { grid-template-columns: repeat(5, minmax(0, 1fr)); }

  .artifact-card, .science-card {
    min-height: 220px;
    border: 1px solid rgba(255,255,255,0.12);
    border-radius: 26px;
    padding: 1.35rem;
    background: linear-gradient(150deg, rgba(255,255,255,0.12), rgba(255,255,255,0.035));
    backdrop-filter: blur(16px);
    transform-style: preserve-3d;
    transition: transform 220ms ease, border-color 220ms ease, background 220ms ease;
  }

  .artifact-card:hover, .science-card:hover {
    transform: translateY(-8px) scale(1.015);
    border-color: rgba(216, 176, 106, 0.42);
    background: linear-gradient(150deg, rgba(216,176,106,0.16), rgba(141,223,255,0.07));
  }

  .artifact-glyph {
    display: inline-grid;
    place-items: center;
    width: 42px;
    height: 42px;
    margin-bottom: 2.8rem;
    border-radius: 50%;
    color: #d8b06a;
    background: rgba(216,176,106,0.1);
  }

  .card-orbit {
    width: 54px;
    height: 54px;
    margin-bottom: 2rem;
    border: 1px solid rgba(141,223,255,0.58);
    border-radius: 50%;
    box-shadow: inset 0 0 18px rgba(141,223,255,0.18), 0 0 28px rgba(141,223,255,0.1);
  }

  .horizon {
    width: min(760px, 82vw);
    height: 2px;
    margin: 2rem auto 0;
    background: linear-gradient(90deg, transparent, #8ddfff, #d8b06a, transparent);
    box-shadow: 0 0 44px #8ddfff;
  }

  .closing { min-height: 78vh; place-items: center; text-align: center; }
  .closing-line { font-family: Georgia, "Times New Roman", serif; font-size: clamp(1.7rem, 4vw, 3.6rem); line-height: 1.15; color: #f6efe4; }
  .signature { color: #d8b06a; font-size: 0.95rem; letter-spacing: 0.12em; text-transform: uppercase; }
  .home-button {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 48px;
    margin-top: 1rem;
    padding: 0 1.3rem;
    border: 1px solid rgba(216,176,106,0.45);
    border-radius: 999px;
    color: #070914;
    background: #f6efe4;
    font-weight: 700;
    transition: transform 180ms ease, box-shadow 180ms ease;
  }
  .home-button:hover { transform: translateY(-2px); box-shadow: 0 16px 38px rgba(216,176,106,0.18); }

  @media (max-width: 980px) {
    .artifact-grid, .science-grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .science-grid .science-card:last-child { grid-column: 1 / -1; }
  }

  @media (max-width: 640px) {
    .me-section { min-height: auto; padding-block: 6rem; }
    .hero { min-height: calc(100vh - 64px); }
    .artifact-grid, .science-grid { grid-template-columns: 1fr; }
    .artifact-card, .science-card { min-height: 190px; }
    .hero-copy, .section-copy, .closing-panel { border-radius: 24px; }
    .origin .section-copy, .future .section-copy { margin-left: 0; }
  }

  @media (prefers-reduced-motion: reduce) {
    .artifact-card, .science-card, .home-button { transition: none; }
  }
</style>
