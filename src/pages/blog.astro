---
import SiteLayout from "../components/SiteLayout.astro";
import TopicIndexTemplate from "../components/TopicIndexTemplate.astro";

const cards = [
  {
    href: "/blog/story-of-my-life",
    category: "LIFE",
    title: "the story of my life",
  },
  {
    href: "/blog/what-is-real",
    category: "LIFE",
    title: "do we really know what is real?",
  },
  {
    href: "/blog/idiots-of-tomorrow",
    category: "THOUGHT",
    title: "we are the idiots of tomorrow.",
  },
  {
    href: "/blog/we-must-believe",
    category: "BELIEF",
    title: "we must believe (?)",
  },
];
---

<SiteLayout title="JLOG! — Ugurcan" description="A clean, modern, light-color topic index for personal JLOG writing in the archive." fullBleed showBackground={false}>
  <TopicIndexTemplate cards={cards} sectionLabel="Blog" />
</SiteLayout>
