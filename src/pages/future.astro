---
import Layout from "../layouts/Layout.astro";
import FilterBar from "../components/FilterBar.astro";

/**
 * Future categories (filters)
 * Keep the strings consistent in:
 * - filters array
 * - card.category
 * - badge--CATEGORY class names
 */
const filters = ["ALL", "AI", "BIOTECH", "SPACE", "ENERGY", "COMPUTING", "SOCIETY", "ROBOTICS"];

const cards = [
  {
    href: "/future/ai-agents",
    category: "AI",
    subtitle: "Workflows • Autonomy",
    title: "AI Agents: From Tools to Teammates",
    excerpt:
      "The next wave isn’t just chat — it’s agents that plan, call tools, verify, and hand you finished work (with receipts).",
    img: "https://images.unsplash.com/photo-1526378722484-bd91ca387e72?w=200&q=80",
  },
  {
    href: "/future/longevity-biotech",
    category: "BIOTECH",
    subtitle: "Aging • Prevention",
    title: "Longevity: Treating Aging Like an Engineering Problem",
    excerpt:
      "Instead of waiting for disease, biotech is moving toward monitoring and repairing the body early — like maintenance for biology.",
    img: "https://images.unsplash.com/photo-1581594549595-35f6edc7b762?q=80",
  },
  {
    href: "/future/space-economy",
    category: "SPACE",
    subtitle: "Launch costs • Industry",
    title: "The Space Economy: When Orbit Becomes a Workplace",
    excerpt:
      "Cheaper launch and better robotics could turn orbit into a factory floor — communications, materials, energy, and research.",
    img: "https://images.unsplash.com/photo-1446776811953-b23d57bd21aa?w=200&q=80",
  },
  {
    href: "/future/fusion-and-grid",
    category: "ENERGY",
    subtitle: "Fusion • Storage",
    title: "Energy: Fusion, Storage, and the Smarter Grid",
    excerpt:
      "Even before fusion arrives, batteries + software can reshape the grid — balancing supply and demand in real time.",
    img: "https://images.unsplash.com/photo-1509395176047-4a66953fd231?w=200&q=80",
  },
  {
    href: "/future/quantum-post-crypto",
    category: "COMPUTING",
    subtitle: "Quantum • Security",
    title: "Quantum Computing: Powerful, But Not Magic",
    excerpt:
      "Quantum won’t replace normal computers. It will crush specific problems — and force the world to upgrade encryption.",
    img: "https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=200&q=80",
  },
  {
    href: "/future/robots-at-home",
    category: "ROBOTICS",
    subtitle: "Dexterity • Cost curves",
    title: "Robots at Home: The Hardest Product Challenge",
    excerpt:
      "Home robots need safe strength, good hands, and common sense — the last 10% is the toughest, but progress is real.",
    img: "https://images.unsplash.com/photo-1485827404703-89b55fcc595e?w=200&q=80",
  },
  {
    href: "/future/society-trust",
    category: "SOCIETY",
    subtitle: "Identity • Truth",
    title: "Trust in the AI Era: Proving What’s Real",
    excerpt:
      "As synthetic media grows, society will rely more on verification: provenance, signatures, and transparent evidence trails.",
    img: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=200&q=80",
  },
];

import AtlasBackground from "../components/AtlasBackground.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---
<Layout title="Future — Ugurcan" description="Signals dashboard for AI, biotech, space, energy, computing, society, and robotics — thoughtful, not hype-driven.">
  <FilterBar slot="subnav" filters={filters} cardSelector=".future-card" queryKey="topic" defaultFilter="ALL" />
  <main class="atlas-page future-atlas">
    <AtlasBackground variant="future" id="future-scene" />
    <div class="atlas-content">
      <section class="atlas-hero">
        <div class="atlas-hero__panel" data-reveal>
          <p class="atlas-eyebrow">Personal atlas / Future</p>
          <h1>Future</h1>
          <p class="atlas-hero__subtitle">Signals dashboard for AI, biotech, space, energy, computing, society, and robotics — thoughtful, not hype-driven.</p>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Scroll system" title="AI → Biotech → Space → Energy → Computing → Society → Robotics" text="Move through this room like an exhibition: each card is a fragment, a question, and a doorway into a longer note." />
        <div class="atlas-grid atlas-grid--four">
          <article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>AI</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Biotech</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Space</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Energy</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Computing</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Society</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Robotics</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Archive" title="Existing notes, redesigned as exhibition cards" text="All routes and articles are preserved; the visual system now matches the surreal premium direction of /me." />
        <div class="atlas-grid">
          {cards.map((c) => (
            <a class="atlas-card future-card" href={c.href} data-category={c.category} data-reveal>
              <span class="atlas-glyph" aria-hidden="true">⬡</span>
              <p class="atlas-eyebrow">{c.category} · {c.subtitle}</p>
              <h3>{c.title}</h3>
              <p>{c.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
    <ScrollReveal />
  </main>
</Layout>
