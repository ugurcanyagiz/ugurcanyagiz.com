<style>
  .resume {
    max-width: 900px;
    margin: 0 auto;
    padding: 30px 18px;
    display: grid;
    gap: 16px;
  }

  .card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 20px;
  }

  .hero {
    text-align: center;
    background: linear-gradient(180deg, #fdfdff 0%, #f6f8ff 100%);
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 4.8vw, 44px);
    letter-spacing: -0.02em;
  }

  .role {
    margin: 8px 0;
    font-size: 18px;
    font-weight: 700;
  }

  .contact {
    margin: 0;
    color: rgba(11, 11, 15, 0.75);
  }

  h2 {
    margin: 0 0 10px;
  }

  h3,
  h4 {
    margin: 14px 0 6px;
  }

  .date {
    margin: 0;
    color: rgba(11, 11, 15, 0.65);
  }

  ul {
    margin: 0;
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }

  .excel-showcase p {
    margin: 0 0 14px;
    color: rgba(11, 11, 15, 0.78);
  }

  .excel-grid {
    display: grid;
    gap: 10px;
  }

  .excel-skill {
    background: linear-gradient(180deg, #f9fbff, #f4f7ff);
    border: 1px solid rgba(67, 108, 255, 0.12);
    padding: 10px 12px;
    border-radius: 12px;
  }

  .excel-skill__head {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    font-size: 14px;
    margin-bottom: 8px;
  }

  .excel-skill__head strong {
    color: #2f46e5;
  }

  .excel-skill__bar {
    height: 8px;
    border-radius: 999px;
    background: rgba(64, 102, 255, 0.14);
    overflow: hidden;
  }

  .excel-skill__bar span {
    display: block;
    height: 100%;
    width: 0;
    background: linear-gradient(90deg, #3656ff, #54d3ff);
    border-radius: inherit;
    animation: excelGrow 1.25s ease forwards;
    animation-delay: var(--delay);
  }

  .excel-cards {
    margin-top: 14px;
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 10px;
  }

  .excel-card {
    border-radius: 12px;
    padding: 12px;
    border: 1px solid rgba(0, 0, 0, 0.07);
    background: #fff;
    animation: floatCard 3.2s ease-in-out infinite;
  }

  .excel-card:nth-child(2) {
    animation-delay: .5s;
  }

  .excel-card:nth-child(3) {
    animation-delay: 1s;
  }

  .excel-card h3 {
    margin: 0 0 6px;
    font-size: 16px;
  }

  .excel-card p {
    margin: 0;
    font-size: 14px;
  }

  @keyframes excelGrow {
    from { width: 0; }
    to { width: var(--pct); }
  }

  @keyframes floatCard {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-4px); }
  }

  @media (max-width: 860px) {
    .excel-cards {
      grid-template-columns: 1fr;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .excel-skill__bar span,
    .excel-card {
      animation: none;
      width: var(--pct);
    }
  }

</style>
