  </div>

  <dialog class="faq-dialog" id="faqDialog">
    <form method="dialog" class="faq-dialog-close-wrap">
      <button class="faq-dialog-close" aria-label="Close popup">✕</button>
    </form>
    <h3 id="faqDialogQuestion"></h3>
    <p id="faqDialogAnswer"></p>
  </dialog>
</Layout>

<style>
  .resume {
    max-width: 900px;
    margin: 0 auto;
    padding: 30px 18px;
    display: grid;
    gap: 16px;
  }

  .card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 20px;
  }

  .hero {
    text-align: center;
    background: linear-gradient(180deg, #fdfdff 0%, #f6f8ff 100%);
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 4.8vw, 44px);
    letter-spacing: -0.02em;
  }

  .role {
    margin: 8px 0;
    font-size: 18px;
    font-weight: 700;
  }

  .contact {
    margin: 0;
    color: rgba(11, 11, 15, 0.75);
  }

  h2 {
    margin: 0 0 10px;
  }

  h3,
  h4 {
    margin: 14px 0 6px;
  }

  .date {
    margin: 0;
    color: rgba(11, 11, 15, 0.65);
  }

  ul {
    margin: 0;
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }

  .excel-showcase p {
    margin: 0 0 14px;
    color: rgba(11, 11, 15, 0.78);
  }

  .excel-gif-frame {
    --slide-duration: 7s;
    --slide-count: 5;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(67, 108, 255, 0.2);
    min-height: 340px;
    background: #f6f8ff;
  }

  .excel-gif-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.03);
    filter: blur(1px);
    animation: gifCarousel calc(var(--slide-duration) * var(--slide-count)) cubic-bezier(0.25, 0.1, 0.25, 1) infinite;
    animation-delay: calc(var(--index) * var(--slide-duration));
  }

  .excel-gif-frame img:first-child {
    opacity: 1;
  }

  @keyframes gifCarousel {
    0%,
    2% {
      opacity: 0;
      transform: scale(1.03);
      filter: blur(2px);
    }
    6%,
    16% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
    20%,
    100% {
      opacity: 0;
      transform: scale(0.99);
      filter: blur(1px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .excel-gif-frame img {
      animation: gifCarouselReduced calc(var(--slide-duration) * var(--slide-count)) ease-in-out infinite;
      animation-delay: calc(var(--index) * var(--slide-duration));
      transform: none;
      filter: none;
    }
  }

  @keyframes gifCarouselReduced {
    0%,
    4% {
      opacity: 0;
    }
    8%,
    18% {
      opacity: 1;
    }
    20%,
    100% {
      opacity: 0;
    }
  }

  .floating-faq-shell {
    position: fixed;
    right: 20px;
    bottom: 20px;
    z-index: 45;
    width: min(360px, calc(100vw - 24px));
  }

  .resume-faq {
    position: relative;
    background: rgba(13, 17, 38, 0.92);
    color: #fff;
    border: 1px solid rgba(255, 255, 255, 0.2);
    backdrop-filter: blur(10px);
    border-radius: 18px;
    box-shadow: 0 18px 40px rgba(11, 11, 15, 0.28);
    padding: 14px;
  }

  .floating-contact-links {
    display: flex;
    justify-content: flex-end;
    gap: 10px;
    margin: 0 6px 10px 0;
  }

  .quick-link-bubble {
    width: 42px;
    height: 42px;
    border-radius: 999px;
    display: grid;
    place-items: center;
    color: #fff;
    background: #2563eb;
    border: 1px solid rgba(255, 255, 255, 0.46);
    box-shadow: 0 6px 14px rgba(17, 24, 72, 0.4);
    transition: transform 160ms ease, filter 160ms ease, box-shadow 160ms ease;
  }

  .quick-link-bubble svg {
    width: 21px;
    height: 21px;
    fill: currentColor;
  }

  .quick-link-bubble.linkedin {
    background: #0a66c2;
  }

  .quick-link-bubble.phone {
    background: #16a34a;
  }

  .quick-link-bubble:hover {
    transform: translateY(-2px) scale(1.04);
    filter: brightness(1.06);
    box-shadow: 0 10px 18px rgba(17, 24, 72, 0.5);
  }

  .quick-link-bubble:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .faq-bubbles {
    display: grid;
    gap: 8px;
  }

  .faq-bubble {
    width: 100%;
    border: 1px solid rgba(158, 180, 255, 0.55);
    background: linear-gradient(135deg, #304ac6 0%, #5a78ff 100%);
    color: #fff;
    border-radius: 999px;
    padding: 10px 14px;
    text-align: left;
    font-weight: 600;
    font-size: 14px;
    line-height: 1.35;
    cursor: pointer;
    transition: transform 180ms ease, box-shadow 180ms ease, filter 180ms ease;
  }

  .faq-bubble:hover {
    transform: translateY(-2px) scale(1.01);
    box-shadow: 0 8px 18px rgba(35, 54, 150, 0.45);
    filter: brightness(1.05);
  }

  .faq-bubble:focus-visible {
    outline: 2px solid #fff;
    outline-offset: 2px;
  }

  .faq-dialog {
    border: 0;
    border-radius: 18px;
    width: min(640px, calc(100vw - 20px));
    padding: 24px;
    background: #ffffff;
    color: #0b0b0f;
    box-shadow: 0 20px 45px rgba(0, 0, 0, 0.28);
  }

  .faq-dialog::backdrop {
    background: rgba(6, 9, 24, 0.6);
    backdrop-filter: blur(2px);
  }

  .faq-dialog h3 {
    margin: 0 0 10px;
    font-size: 26px;
  }

  .faq-dialog p {
    margin: 0;
    line-height: 1.65;
    color: rgba(11, 11, 15, 0.86);
  }

  .faq-dialog-close-wrap {
    margin: 0;
    text-align: right;
  }

  .faq-dialog-close {
    border: 0;
    background: rgba(11, 11, 15, 0.08);
    width: 34px;
    height: 34px;
    border-radius: 999px;
    cursor: pointer;
    font-size: 16px;
    transition: background 160ms ease;
  }

  .faq-dialog-close:hover {
    background: rgba(11, 11, 15, 0.16);
  }

  @media (max-width: 760px) {
    .floating-faq-shell {
      right: 12px;
      bottom: 12px;
      width: calc(100vw - 24px);
    }

    .faq-bubble {
      font-size: 13px;
    }
  }
</style>

<script>
  const dialog = document.getElementById("faqDialog");
  const questionNode = document.getElementById("faqDialogQuestion");
  const answerNode = document.getElementById("faqDialogAnswer");
  const bubbles = document.querySelectorAll(".faq-bubble");

  bubbles.forEach((bubble) => {
    bubble.addEventListener("click", () => {
      if (!dialog || !questionNode || !answerNode) return;
      questionNode.textContent = bubble.getAttribute("data-faq-question") ?? "";
      answerNode.textContent = bubble.getAttribute("data-faq-answer") ?? "";
      if (typeof dialog.showModal === "function") {
        dialog.showModal();
      }
    });
  });
</script>
