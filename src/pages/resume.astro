<style>
  .resume {
    max-width: 900px;
    margin: 0 auto;
    padding: 30px 18px;
    display: grid;
    gap: 16px;
  }

  .card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 20px;
  }

  .hero {
    text-align: center;
    background: linear-gradient(180deg, #fdfdff 0%, #f6f8ff 100%);
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 4.8vw, 44px);
    letter-spacing: -0.02em;
  }

  .role {
    margin: 8px 0;
    font-size: 18px;
    font-weight: 700;
  }

  .contact {
    margin: 0;
    color: rgba(11, 11, 15, 0.75);
  }

  h2 {
    margin: 0 0 10px;
  }

  h3,
  h4 {
    margin: 14px 0 6px;
  }

  .date {
    margin: 0;
    color: rgba(11, 11, 15, 0.65);
  }

  ul {
    margin: 0;
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }
</style>
