<style>
  .resume {
    max-width: 900px;
    margin: 0 auto;
    padding: 30px 18px;
    display: grid;
    gap: 16px;
  }

  .card {
    background: #fff;
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 16px;
    padding: 20px;
  }

  .hero {
    text-align: center;
    background: linear-gradient(180deg, #fdfdff 0%, #f6f8ff 100%);
  }

  h1 {
    margin: 0;
    font-size: clamp(32px, 4.8vw, 44px);
    letter-spacing: -0.02em;
  }

  .role {
    margin: 8px 0;
    font-size: 18px;
    font-weight: 700;
  }

  .contact {
    margin: 0;
    color: rgba(11, 11, 15, 0.75);
  }

  h2 {
    margin: 0 0 10px;
  }

  h3,
  h4 {
    margin: 14px 0 6px;
  }

  .date {
    margin: 0;
    color: rgba(11, 11, 15, 0.65);
  }

  ul {
    margin: 0;
    padding-left: 22px;
  }

  li {
    margin-bottom: 8px;
  }

  .excel-showcase p {
    margin: 0 0 14px;
    color: rgba(11, 11, 15, 0.78);
  }

  .excel-gif-frame {
    --slide-duration: 7s;
    --slide-count: 5;
    position: relative;
    overflow: hidden;
    border-radius: 12px;
    border: 1px solid rgba(67, 108, 255, 0.2);
    min-height: 340px;
    background: #f6f8ff;
  }

  .excel-gif-frame img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transform: scale(1.03);
    filter: blur(1px);
    animation: gifCarousel calc(var(--slide-duration) * var(--slide-count)) cubic-bezier(0.25, 0.1, 0.25, 1) infinite;
    animation-delay: calc(var(--index) * var(--slide-duration));
  }

  .excel-gif-frame img:first-child {
    opacity: 1;
  }

  @keyframes gifCarousel {
    0%,
    2% {
      opacity: 0;
      transform: scale(1.03);
      filter: blur(2px);
    }
    6%,
    16% {
      opacity: 1;
      transform: scale(1);
      filter: blur(0);
    }
    20%,
    100% {
      opacity: 0;
      transform: scale(0.99);
      filter: blur(1px);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .excel-gif-frame img {
      animation: gifCarouselReduced calc(var(--slide-duration) * var(--slide-count)) ease-in-out infinite;
      animation-delay: calc(var(--index) * var(--slide-duration));
      transform: none;
      filter: none;
    }
  }

  @keyframes gifCarouselReduced {
    0%,
    4% {
      opacity: 0;
    }
    8%,
    18% {
      opacity: 1;
    }
    20%,
    100% {
      opacity: 0;
    }
  }

</style>
