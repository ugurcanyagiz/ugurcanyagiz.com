const slug = Astro.params.slug ?? "";
const segments = slug.split("/").filter(Boolean);
const titleCase = (value: string) => value.replace(/[-_]+/g, " ").replace(/\b\w/g, (char) => char.toUpperCase());
const section = segments[0] || "atlas";
const parentTitle = titleCase(segments.at(-2) || section);
const topicTitle = titleCase(segments.at(-1) || "Topic");
const title = segments.map(titleCase).join(" / ") || "Topic";
const parentHref = `/${segments.slice(0, -1).join("/")}`;
const sectionHref = `/${section}`;
const trail = segments.map((part, index) => ({
  label: titleCase(part),
  href: `/${segments.slice(0, index + 1).join("/")}`,
}));

type SectionContent = {
  lens: string;
  context: string;
  ideas: string[];
  readingPath: string[];
  questions: string[];
};

const SECTION_CONTENT: Record<string, SectionContent> = {
  science: {
    lens: "Science burada ezberlenecek cevaplar değil; gözlem, model, test ve düzeltme döngüsü olarak ele alınır.",
    context: "Bu alt konu, evrenin nasıl çalıştığını anlamak için ölçekleri birbirine bağlar: ölçümden teoriye, teoriden gündelik sezgiye.",
    ideas: ["Önce gözlenebilir olguyu ayır: ne gerçekten ölçülüyor, ne yorumlanıyor?", "Modelin gücünü ve sınırını birlikte oku; iyi bilim hem açıklama hem de hata payı verir.", "Küçük mekanizmaların büyük sonuçlara nasıl dönüştüğünü izle."],
    readingPath: ["Temel kavramları kur", "Mekanizmayı örneklerle sadeleştir", "Açık kalan soruları ve yanlış anlaşılmaları not et"],
    questions: ["Hangi veri bu fikri destekler?", "Model hangi ölçekte bozulur?", "Bu konu başka hangi bilim alanına bağlanır?"],
  },
  history: {
    lens: "History sayfaları olay listesinden çok neden-sonuç, kurumlar, teşvikler ve kırılgan sistemler üzerine kurulur.",
    context: "Bu alt konu, geçmişteki bir örüntünün bugüne nasıl miras kaldığını; coğrafya, ekonomi, fikirler ve güç dengeleri üzerinden açıklar.",
    ideas: ["Tek neden arama; tarih genellikle birden fazla baskının aynı anda birikmesiyle değişir.", "Kurumların ve teknolojilerin insanların seçeneklerini nasıl daraltıp genişlettiğini izle.", "Kazananların anlatısı ile sahadaki gündelik gerçeklik arasındaki farkı ayır."],
    readingPath: ["Zaman ve mekân bağlamını kur", "Aktörlerin teşviklerini çıkar", "Uzun vadeli sonuçları bugünün sistemleriyle karşılaştır"],
    questions: ["Kim ne kazanıyordu, kim ne kaybediyordu?", "Kırılma noktası olay mıydı, yoksa birikmiş baskı mı?", "Bu örüntü bugün nerede tekrar ediyor?"],
  },
  art: {
    lens: "Art bölümü sanatı yalnızca beğeni değil; dikkat, ritim, malzeme, kompozisyon ve kültürel hafıza sistemi olarak okur.",
    context: "Bu alt konu, bir eserin ya da pratiğin nasıl anlam ürettiğini; görsel kararlar, teknik sınırlamalar ve izleyici algısı üzerinden inceler.",
    ideas: ["Biçim mesaj taşır: ölçek, boşluk, renk ve tekrar izleyicinin bedenini yönlendirir.", "Teknik seçimler estetik kadar pratiktir; araç, zaman ve malzeme sonucu belirler.", "Anlam çoğu zaman kontrasttan doğar: sessizlik/ses, boşluk/doluluk, düzen/bozulma."],
    readingPath: ["İlk izlenimi tarif et", "Kompozisyon ve tekniği parçalarına ayır", "Kültürel bağlam ve kişisel deneyimle yeniden oku"],
    questions: ["Göz ilk nereye gidiyor ve neden?", "Hangi teknik karar duyguyu değiştiriyor?", "Eser kendi döneminin hangi sorusuna cevap veriyor?"],
  },
  future: {
    lens: "Future sayfaları tahminden çok sinyal okuma pratiğidir: maliyet eğrileri, kurumlar, güvenlik ve insan davranışı birlikte düşünülür.",
    context: "Bu alt konu, yaklaşan teknolojik veya toplumsal değişimi abartıya kaçmadan; fırsatlar, riskler ve gerekli altyapı açısından haritalar.",
    ideas: ["Bir teknolojinin geleceğini yalnızca prototip değil; maliyet, güven, dağıtım ve bakım belirler.", "Yeni sistemler eski kurumlarla çarpışır; hukuk, eğitim ve kültür adaptasyon hızını şekillendirir.", "En iyi gelecek okuması hem iyimser hem temkinlidir: kapasiteyi ve yan etkiyi birlikte görür."],
    readingPath: ["Bugünkü sinyalleri ayır", "Ölçeklenme engellerini yaz", "İnsanlar ve kurumlar için sonuçları düşün"],
    questions: ["Bu değişimi hangi maliyet eğrisi hızlandırır?", "Güvenlik ve güven problemi nerede ortaya çıkar?", "Kazanan sadece teknoloji mi, yoksa onu kullanan sistem mi?"],
  },
  blog: {
    lens: "JLOG alt sayfaları kişisel notları, okuma izlerini ve araştırma sorularını kısa ama düzenli düşünce dosyalarına dönüştürür.",
    context: "Bu alt konu, bir fikri bitmiş cevap gibi değil; gözlem, alıntı, soru ve tekrar düşünme alanı olarak konumlandırır.",
    ideas: ["Kişisel gözlem ile genel iddiayı birbirinden ayır.", "Okunan metnin sende bıraktığı soruyu kaybetme.", "Kısa notlar zamanla daha büyük araştırma rotalarına dönüşebilir."],
    readingPath: ["Notun çıkış noktasını belirle", "Bağlantılı fikirleri sırala", "Açık kalan soruyu kaydet"],
    questions: ["Bu not hangi meraktan doğdu?", "Hangi kaynak veya deneyim fikri değiştirdi?", "Bunu sonra nasıl test ederim?"],
  },
};

const content = SECTION_CONTENT[section] || SECTION_CONTENT.science;
const topicHuman = topicTitle.toLowerCase();
const parentHuman = parentTitle.toLowerCase();
---

<SiteLayout
  title={`${title} | UGURCAN YAGIZ`}
  description={`${topicTitle} için hafif renkli, scroll tabanlı atlas alt konu şablonu.`}
  activeSection={section}
  showBackground={false}
  fullBleed
>
  <article class="topic-placeholder topic-deep-page">
    <nav class="topic-deep-page__crumbs" aria-label="Breadcrumb">
      <a href={sectionHref}>{titleCase(section)}</a>
      {trail.slice(1).map((item, index) => (
        <>
          <span aria-hidden="true">/</span>
          {index === trail.length - 2 ? <span>{item.label}</span> : <a href={item.href}>{item.label}</a>}
        </>
      ))}
    </nav>

    <header class="topic-deep-page__hero">
      <p class="topic-placeholder__eyebrow">{titleCase(section)} atlas / {parentTitle}</p>
      <h1>{topicTitle}</h1>
      <p>
        {content.context} Bu sayfa özellikle <b>{topicHuman}</b> başlığını <b>{parentHuman}</b> rotası içinde konumlandırır
        ve ziyaretçiye hızlı okunur, dolu bir başlangıç haritası sunar.
      </p>
      <div class="topic-deep-page__actions">
        <a href={parentHref}>← Parent topic</a>
        <a href={sectionHref}>Section index</a>
      </div>
    </header>

    <section class="topic-deep-page__section" aria-label="Topic structure">
      <div class="topic-deep-page__card">
        <span>01</span>
        <h2>Lens</h2>
        <p>{content.lens}</p>
      </div>
      <div class="topic-deep-page__card">
        <span>02</span>
        <h2>Core ideas</h2>
        <ul>
          {content.ideas.map((idea) => <li>{idea}</li>)}
        </ul>
      </div>
      <div class="topic-deep-page__card">
        <span>03</span>
        <h2>Reading path</h2>
        <ol>
          {content.readingPath.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    </section>

    <section class="topic-deep-page__detail" aria-label="Topic notes">
      <div>
        <p class="topic-deep-page__kicker">Why it matters</p>
        <h2>{topicTitle} nasıl okunmalı?</h2>
        <p>
          {topicTitle}, tek başına duran bir başlık gibi görünse de atlasın içinde daha büyük bir ağın parçasıdır.
          Bu yüzden sayfa; tanım, mekanizma, örnek ve sonuç sırasını izleyerek hızlı bir zihinsel model kurar.
        </p>
      </div>
      <div class="topic-deep-page__questions">
        <p class="topic-deep-page__kicker">Guiding questions</p>
        <ul>
          {content.questions.map((question) => <li>{question}</li>)}
        </ul>
      </div>
    </section>
  </article>
</SiteLayout>

<style>
  :global(body:has(.topic-deep-page)){
    background:#f7f3ea;
    color:#181511;
  }

  :global(body:has(.topic-deep-page) .site-page){
    color:#181511;
    background:
      radial-gradient(circle at 14% 10%, color-mix(in srgb,var(--section-accent) 20%, transparent), transparent 30rem),
      radial-gradient(circle at 82% 8%, rgba(255,255,255,.94), transparent 24rem),
      linear-gradient(180deg,#fbfaf6 0%,#f4eee3 52%,#fffdf8 100%);
  }

  :global(body:has(.topic-deep-page) .site-page__cosmos){
    background:
      radial-gradient(circle at 12% 14%, color-mix(in srgb,var(--section-accent) 16%, transparent), transparent 28rem),
      linear-gradient(180deg,rgba(255,255,255,.72),rgba(245,239,227,.86));
    opacity:1;
  }

  :global(body:has(.topic-deep-page) .site-page__cosmos:after){
    background:linear-gradient(180deg,rgba(255,255,255,.08),rgba(255,253,248,.92));
  }

  :global(body:has(.topic-deep-page) .site-page__landscape),
  :global(body:has(.topic-deep-page) .site-page__sun),
  :global(body:has(.topic-deep-page) .site-page__cloud),
  :global(body:has(.topic-deep-page) .site-page__orbit){
    opacity:.1;
  }

  :global(body:has(.topic-deep-page) .site-page__section-mark){
    color:rgba(24,21,17,.42);
    text-shadow:none;
  }

  :global(body:has(.topic-deep-page) .site-page__home-link){
    color:#181511;
    background:rgba(255,255,255,.76);
    border-color:rgba(24,21,17,.12);
  }

  :global(body:has(.topic-deep-page) .site-page__scroll-progress){
    background:linear-gradient(90deg, transparent, var(--section-accent), #181511);
    box-shadow:0 0 18px color-mix(in srgb,var(--section-accent) 38%, transparent);
  }

  .topic-deep-page{
    width:min(1180px, calc(100% - 40px));
    margin:0 auto;
    padding:clamp(7rem,12vw,11rem) 0 clamp(5rem,10vw,9rem);
    color:#181511;
  }

  .topic-deep-page__crumbs{
    display:flex;
    flex-wrap:wrap;
    gap:.55rem;
    align-items:center;
    margin-bottom:clamp(1rem,2vw,1.6rem);
    color:rgba(24,21,17,.52);
    font-size:.72rem;
    font-weight:900;
    letter-spacing:.14em;
    text-transform:uppercase;
  }

  .topic-deep-page__crumbs a{
    color:rgba(24,21,17,.62);
  }

  .topic-deep-page__hero,
  .topic-deep-page__card{
    border:1px solid rgba(24,21,17,.10);
    background:rgba(255,255,255,.68);
    box-shadow:0 28px 90px rgba(55,42,18,.10);
    backdrop-filter:blur(20px) saturate(1.05);
  }

  .topic-deep-page__hero{
    position:relative;
    overflow:hidden;
    border-radius:clamp(28px,4vw,48px);
    padding:clamp(1.5rem,4vw,4rem);
  }

  .topic-deep-page__hero:after{
    content:"";
    position:absolute;
    inset:auto -12% -48% -12%;
    height:68%;
    background:radial-gradient(ellipse at center,color-mix(in srgb,var(--section-accent) 18%, transparent),transparent 68%);
    pointer-events:none;
  }

  .topic-placeholder__eyebrow{
    margin:0 0 1rem;
    color:color-mix(in srgb,var(--section-accent) 72%, #181511);
    font-size:.74rem;
    font-weight:950;
    letter-spacing:.22em;
    text-transform:uppercase;
  }

  .topic-deep-page h1{
    max-width:11ch;
    margin:0 0 1rem;
    color:#181511;
    font-family:Georgia,"Times New Roman",serif;
    font-size:clamp(3.5rem,10vw,9rem);
    font-weight:500;
    line-height:.86;
    letter-spacing:-.08em;
    text-transform:capitalize;
    text-wrap:balance;
  }

  .topic-deep-page p{
    max-width:760px;
    margin:0;
    color:rgba(24,21,17,.68);
    font-size:clamp(1rem,2vw,1.28rem);
    line-height:1.75;
  }

  .topic-deep-page__actions{
    position:relative;
    z-index:1;
    display:flex;
    flex-wrap:wrap;
    gap:.75rem;
    margin-top:1.5rem;
  }

  .topic-deep-page__actions a{
    display:inline-flex;
    align-items:center;
    min-height:44px;
    padding:0 1rem;
    border:1px solid rgba(24,21,17,.12);
    border-radius:999px;
    color:#181511;
    background:rgba(255,255,255,.72);
    font-size:.76rem;
    font-weight:900;
    letter-spacing:.1em;
    text-transform:uppercase;
  }

  .topic-deep-page__section{
    display:grid;
    grid-template-columns:repeat(3,minmax(0,1fr));
    gap:clamp(1rem,2vw,1.35rem);
    margin-top:clamp(1rem,3vw,2rem);
  }

  .topic-deep-page__card{
    min-height:240px;
    border-radius:clamp(22px,3vw,34px);
    padding:clamp(1.1rem,2.5vw,1.7rem);
    transition:transform .25s ease,border-color .25s ease,box-shadow .25s ease,background .25s ease;
  }

  .topic-deep-page__card span{
    display:inline-grid;
    place-items:center;
    width:42px;
    height:42px;
    margin-bottom:clamp(2rem,5vw,4rem);
    border:1px solid color-mix(in srgb,var(--section-accent) 38%, rgba(24,21,17,.12));
    border-radius:50%;
    color:color-mix(in srgb,var(--section-accent) 72%, #181511);
    background:color-mix(in srgb,var(--section-accent) 10%, white);
    font-weight:950;
  }

  .topic-deep-page__card h2{
    margin:0 0 .55rem;
    color:#181511;
    font-family:Georgia,"Times New Roman",serif;
    font-size:clamp(1.45rem,2.4vw,2.15rem);
    font-weight:500;
    letter-spacing:-.045em;
  }

  .topic-deep-page__card p,
  .topic-deep-page__card li{
    color:rgba(24,21,17,.66);
    font-size:1rem;
    line-height:1.8;
  }

  .topic-deep-page__card ul,
  .topic-deep-page__card ol{
    display:grid;
    gap:.65rem;
    margin:0;
    padding-left:1.15rem;
  }

  .topic-deep-page__detail{
    display:grid;
    grid-template-columns:minmax(0,1.25fr) minmax(280px,.75fr);
    gap:clamp(1rem,2vw,1.4rem);
    margin-top:clamp(1rem,2vw,1.4rem);
    padding:clamp(1.3rem,3vw,2.2rem);
    border:1px solid rgba(24,21,17,.1);
    border-radius:28px;
    background:rgba(255,255,255,.66);
    box-shadow:0 22px 70px rgba(60,43,20,.08);
  }

  .topic-deep-page__detail h2{
    margin:.25rem 0 .7rem;
    color:#181511;
    font-family:Georgia,"Times New Roman",serif;
    font-size:clamp(1.7rem,3vw,3rem);
    font-weight:500;
    letter-spacing:-.05em;
  }

  .topic-deep-page__detail p,
  .topic-deep-page__detail li{
    color:rgba(24,21,17,.68);
    line-height:1.85;
  }

  .topic-deep-page__kicker{
    margin:0;
    color:var(--section-accent);
    font-size:.72rem;
    font-weight:950;
    letter-spacing:.16em;
    text-transform:uppercase;
  }

  .topic-deep-page__questions ul{
    display:grid;
    gap:.8rem;
    margin:.8rem 0 0;
    padding-left:1.15rem;
  }

  @media (hover:hover){
    .topic-deep-page__card:hover,
    .topic-deep-page__actions a:hover{
      transform:translateY(-7px);
      border-color:color-mix(in srgb,var(--section-accent) 40%, rgba(24,21,17,.12));
      background:#fff;
      box-shadow:0 38px 120px rgba(55,42,18,.14);
    }
  }

  @supports (animation-timeline: view()){
    .topic-deep-page__hero,
    .topic-deep-page__crumbs,
    .topic-deep-page__card{
      animation:topic-deep-reveal both ease-out;
      animation-timeline:view();
      animation-range:entry 0% cover 30%;
    }

    @keyframes topic-deep-reveal{
      from{opacity:.2;transform:translateY(44px) scale(.985);filter:blur(8px)}
      to{opacity:1;transform:translateY(0) scale(1);filter:blur(0)}
    }
  }

  @media (max-width:860px){
    .topic-deep-page__section,
    .topic-deep-page__detail{grid-template-columns:1fr}
