const slug = Astro.params.slug ?? "";
const title = slug
  .split("/")
  .filter(Boolean)
  .map((part) => part.replace(/-/g, " "))
  .join(" / ") || "Topic";
---

<SiteLayout
  title={`${title} | UGURCAN YAGIZ`}
  description={`Placeholder page for ${title}.`}
  theme="dark"
>
  <article class="topic-placeholder">
    <p class="topic-placeholder__eyebrow">Knowledge atlas topic</p>
    <h1>{title}</h1>
    <p>
      This is a placeholder page for <code>/{slug}</code>. A full topic page can be added here later.
    </p>
    <a href="/">← Back to Atlas</a>
  </article>
</SiteLayout>

<style>
  .topic-placeholder {
    max-width: 760px;
    margin: 0 auto;
    padding: clamp(72px, 12vw, 140px) 24px;
    color: #fff7df;
  }

  .topic-placeholder__eyebrow {
    margin: 0 0 12px;
    color: rgba(121, 215, 255, .78);
    font-size: 12px;
    font-weight: 760;
    letter-spacing: .18em;
    text-transform: uppercase;
  }

  .topic-placeholder h1 {
    margin: 0 0 18px;
    font-size: clamp(42px, 8vw, 88px);
    line-height: .95;
    text-transform: capitalize;
  }

  .topic-placeholder p {
    color: rgba(255, 247, 223, .72);
    font-size: 18px;
    line-height: 1.7;
  }

  .topic-placeholder a {
    color: #efca80;
    font-weight: 800;
  }
</style>
