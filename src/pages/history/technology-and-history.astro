---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "Technology Changes the Winners — History";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <!-- HERO -->
    <header class="hero">
      <div class="hero-grid">
        <section class="card card--hero">
          <div class="hero-top">
            <a class="back" href="/">← Back to Atlas</a>
            <span class="chip chip--history">TECH</span>
          </div>

          <h1>Technology Changes the Winners</h1>
          <p class="subtitle">From ships to algorithms, technology changes who can coordinate, produce, and influence at scale.</p>

          <div class="hero-actions">
            <a class="btn" href="#tldr">Start reading</a>
            <a class="btn btn--ghost" href="#faq">Jump to FAQ</a>
          </div>
        </section>

        <section class="card card--ink">
          <p class="quote">
            “Tools don’t just change what we do—they change who can do it.”
          </p>
          <p class="meta">{updated}</p>
        </section>
      </div>
    </header>

    <!-- TL;DR -->
    <section class="section" id="tldr">
      <h2>TL;DR</h2>
      <div class="tldr">
        <div class="tldr-item">
          <div class="dot dot--a" aria-hidden="true"></div>
          <div>
            <h3>Tech shifts power</h3>
            <p>New tools lower costs of coordination, production, and violence—changing winners and losers.</p>
          </div>
        </div>
        <div class="tldr-item">
          <div class="dot dot--b" aria-hidden="true"></div>
          <div>
            <h3>Second-order effects dominate</h3>
            <p>Big impacts come from institutions and norms adapting to the tool.</p>
          </div>
        </div>
        <div class="tldr-item">
          <div class="dot dot--c" aria-hidden="true"></div>
          <div>
            <h3>Adoption beats invention</h3>
            <p>A technology matters when it becomes infrastructure, not when it first appears.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- SIMPLE MODEL -->
    <section class="section">
      <h2>A simple model</h2>
      <div class="grid-2">
        <div class="card card--soft">
          <h3>The lens</h3>
          <p>Technology alters constraints. History then rearranges itself around the new constraint landscape.</p>
        </div>
        <div class="card card--soft">
          <h3>Mechanisms</h3>
          <ul>
            <li>Communication tech → faster coordination (for states and crowds).</li>
            <li>Energy tech → higher productivity and military capacity.</li>
            <li>Measurement and computation → better planning and control.</li>
            <li>Platforms → new gatekeepers and dependency chains.</li>
          </ul>
        </div>
      </div>
    </section>

    <!-- QUICK EXAMPLES -->
    <section class="section">
      <h2>Quick examples</h2>
      <div class="card card--soft">
        <ul class="bullets">
          <li>Steam power enabling industrial scale and global trade.</li>
          <li>Telegraph shrinking decision time and expanding markets.</li>
          <li>Computing and networks creating information economies.</li>
        </ul>
      </div>
    </section>

    <!-- NAV -->
    <nav class="navrow" aria-label="Page navigation">
      <a class="navcard" href="/history">
        <span class="navlabel">Back</span>
        <span class="navtitle">History index</span>
      </a>
      <a class="navcard navcard--next" href="/future">
        <span class="navlabel">Next category</span>
        <span class="navtitle">Future</span>
      </a>
    </nav>

    <!-- FAQ -->
    <section class="section" id="faq">
      <h2>FAQ</h2>
      <div class="faq">
        <details class="faq-item">
          <summary>Does tech cause history?</summary>
          <div class="faq-body">
            <p>It shapes possibilities, but politics and culture determine how possibilities are used.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>Why do some societies adopt faster?</summary>
          <div class="faq-body">
            <p>Institutions, capital, education, and incentives for experimentation.</p>
          </div>
        </details>
        <details class="faq-item">
          <summary>What’s the modern parallel?</summary>
          <div class="faq-body">
            <p>AI and biotech: general-purpose tools that reprice labor, risk, and governance.</p>
          </div>
        </details>
      </div>
    </section>

    <footer class="endcap">
      <a class="back" href="/">← Back to Atlas</a>
    </footer>
  </article>

</ArticleLayout>
