---
import SiteLayout from "../components/SiteLayout.astro";
import FilterBar from "../components/FilterBar.astro";

const cards = [
  {
    href: "/science/relativity",
    category: "PHYSICS",
    subtitle: "Space-time • Gravity",
    title: "Einstein & Relativity",
    excerpt:
      "Time and space aren’t rigid. They stretch, shrink, and bend — and that bending is what we call gravity.",
    img: "https://images.unsplash.com/photo-1520607162513-77705c0f0d4a?w=200&q=80",
  },
  {
    href: "/science/big-bang",
    category: "SPACE",
    subtitle: "Origins • Expansion",
    title: "The Big Bang (In Simple Words)",
    excerpt:
      "The universe didn’t explode into space — space itself expanded. And it’s still expanding today.",
    img: "https://images.unsplash.com/photo-1444703686981-a3abbc4d4fe3?w=200&q=80",
  },
  {
    href: "/science/black-holes",
    category: "SPACE",
    subtitle: "Extreme gravity • Event horizon",
    title: "Black Holes",
    excerpt:
      "A place where gravity becomes so strong that even light can’t escape — like nature’s ultimate trapdoor.",
    img: "https://images.unsplash.com/photo-1454789548928-9efd52dc4031?w=200&q=80",
  },
  {
    href: "/science/time",
    category: "PHYSICS",
    subtitle: "Clocks • Dimensions",
    title: "What Is Time, Really?",
    excerpt:
      "Time feels like a river, but physics treats it like a dimension — and it doesn’t flow the same for everyone.",
    img: "https://images.unsplash.com/photo-1496307042754-b4aa456c4a2d?w=200&q=80",
  },
  {
    href: "/science/quantum-basics",
    category: "PHYSICS",
    subtitle: "Small-scale rules • Measurement",
    title: "Quantum Physics: The Weird Rules",
    excerpt:
      "In the tiny world, things can be in more than one state — until we measure them.",
    img: "https://images.unsplash.com/photo-1531297484001-80022131f5a1?w=200&q=80",
  },
  {
    href: "/science/superposition",
    category: "PHYSICS",
    subtitle: "Possibilities • Observation",
    title: "Superposition (Like a Coin Mid-Flip)",
    excerpt:
      "A quantum object can be ‘both’ possibilities at once — like a coin that is heads and tails until you look.",
    img: "https://images.unsplash.com/photo-1526374965328-7f61d4dc18c5?w=200&q=80",
  },
  {
    href: "/science/entanglement",
    category: "PHYSICS",
    subtitle: "Correlations • Distance",
    title: "Entanglement: The Cosmic Link",
    excerpt:
      "Two particles can share one state, even far apart — change one, and the other responds instantly.",
    img: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=200&q=80",
  },
  {
    href: "/science/waves-particles",
    category: "PHYSICS",
    subtitle: "Light • Matter",
    title: "Wave–Particle Duality",
    excerpt:
      "Light and matter can behave like waves and particles — the behavior depends on how we observe them.",
    img: "https://images.unsplash.com/photo-1456428199391-a3b1cb5e93ab?w=200&q=80",
  },
  {
    href: "/science/uncertainty",
    category: "PHYSICS",
    subtitle: "Limits • Precision",
    title: "Uncertainty Principle",
    excerpt:
      "You can’t know a particle’s exact position and exact speed at the same time — it’s a built-in limit of reality.",
    img: "https://images.unsplash.com/photo-1504384308090-c894fdcc538d?w=200&q=80",
  },
  {
    href: "/science/atoms",
    category: "CHEMISTRY",
    subtitle: "Structure • Bonds",
    title: "Atoms: The LEGO of Nature",
    excerpt:
      "Everything you touch is built from atoms — tiny structures with patterns that decide what materials become.",
    img: "https://images.unsplash.com/photo-1554475901-4538ddfbccc2?w=200&q=80",
  },
  {
    href: "/science/chemistry-life",
    category: "CHEMISTRY",
    subtitle: "Reactions • Energy",
    title: "Chemistry That Powers Life",
    excerpt:
      "Cells run on chemical reactions — little controlled fires, batteries, and molecular machines working together.",
    img: "https://images.unsplash.com/photo-1581092334651-ddf26d9a09d1?w=200&q=80",
  },
  {
    href: "/science/evolution",
    category: "BIOLOGY",
    subtitle: "Selection • Time",
    title: "Evolution (Without the Drama)",
    excerpt:
      "Small changes, over long time, guided by survival and reproduction — nature’s slow, powerful editing process.",
    img: "https://images.unsplash.com/photo-1500534314209-a25ddb2bd429?w=200&q=80",
  },
  {
    href: "/science/dna",
    category: "BIOLOGY",
    subtitle: "Genes • Information",
    title: "DNA: Life’s Instruction Manual",
    excerpt:
      "A long molecule that stores recipes for building living things — copied, repaired, and sometimes changed.",
    img: "https://images.unsplash.com/photo-1581092918056-0c4c3acd3789?w=200&q=80",
  },
  {
    href: "/science/cells",
    category: "BIOLOGY",
    subtitle: "Membranes • Factories",
    title: "Cells: Tiny Cities",
    excerpt:
      "A cell is like a city: walls, power plants, factories, delivery routes — all coordinated by chemistry.",
    img: "https://images.unsplash.com/photo-1559757175-5700dde675bc?w=200&q=80",
  },
  {
    href: "/science/consciousness",
    category: "MIND",
    subtitle: "Experience • Awareness",
    title: "Consciousness: The Hard Question",
    excerpt:
      "How does a brain create experience? We can map signals — but turning signals into ‘feeling’ is still mysterious.",
    img: "https://images.unsplash.com/photo-1526379095098-d400fd0bf935?w=200&q=80",
  },
  {
    href: "/science/memory",
    category: "MIND",
    subtitle: "Networks • Recall",
    title: "Memory: How the Brain Stores You",
    excerpt:
      "Memories aren’t single files. They’re patterns across networks — re-written a little each time you recall them.",
    img: "https://images.unsplash.com/photo-1520694478160-2402b5536d0c?w=200&q=80",
  },
  {
    href: "/science/dreams",
    category: "MIND",
    subtitle: "Emotion • Simulation",
    title: "Dreams: Why We See Stories at Night",
    excerpt:
      "Dreams may help the brain simulate, process emotion, and stitch meaning from fragments of memory.",
    img: "https://images.unsplash.com/photo-1496307653780-42ee777d4833?w=200&q=80",
  },
  {
    href: "/science/language",
    category: "MIND",
    subtitle: "Symbols • Culture",
    title: "Language: The Human Superpower",
    excerpt:
      "Language compresses thought, transfers knowledge, and lets minds coordinate — like a shared operating system.",
    img: "https://images.unsplash.com/photo-1521737604893-d14cc237f11d?w=200&q=80",
  },
  {
    href: "/science/future-of-ai",
    category: "TECHNOLOGY",
    subtitle: "Tools • Verification",
    title: "AI & the Future of Science",
    excerpt:
      "AI can speed up discovery, but it can also mislead. The key is verification, transparency, and careful experiments.",
    img: "https://images.unsplash.com/photo-1526378722484-bd91ca387e72?w=200&q=80",
  },
  {
    href: "/science/life-beyond-earth",
    category: "SPACE",
    subtitle: "Astrobiology • Signals",
    title: "Life Beyond Earth (Careful Optimism)",
    excerpt:
      "We don’t know yet. But chemistry is universal — and the universe is huge. How common is life?",
    img: "https://images.unsplash.com/photo-1447433819943-74a20887a81e?w=200&q=80",
  },
];

const filters = ["ALL", "SPACE", "PHYSICS", "BIOLOGY", "CHEMISTRY", "TECHNOLOGY", "MIND"];

import AtlasBackground from "../components/AtlasBackground.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---
<SiteLayout title="Science — Ugurcan" description="Cosmos → Matter → Life → Mind → Technology. A layered exploration of reality, curiosity, and careful awe." fullBleed showBackground={false}>
  <FilterBar slot="subnav" filters={filters} cardSelector=".science-card" queryKey="topic" defaultFilter="ALL" />
  <main class="atlas-page science-atlas">
    <AtlasBackground variant="science" id="science-scene" />
    <div class="atlas-content">
      <section class="atlas-hero">
        <div class="atlas-hero__panel" data-reveal>
          <p class="atlas-eyebrow">Personal atlas / Science</p>
          <h1>Science</h1>
          <p class="atlas-hero__subtitle">Cosmos → Matter → Life → Mind → Technology. A layered exploration of reality, curiosity, and careful awe.</p>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Scroll system" title="Cosmos → Matter → Life → Mind → Technology" text="Move through this room like an exhibition: each card is a fragment, a question, and a doorway into a longer note." />
        <div class="atlas-grid atlas-grid--four">
          <article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Cosmos</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Matter</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Life</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Mind</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Technology</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Archive" title="Existing notes, redesigned as exhibition cards" text="All routes and articles are preserved; the visual system now matches the surreal premium direction of /me." />
        <div class="atlas-grid">
          {cards.map((c) => (
            <a class="atlas-card science-card" href={c.href} data-category={c.category} data-reveal>
              <span class="atlas-glyph" aria-hidden="true">✺</span>
              <p class="atlas-eyebrow">{c.category} · {c.subtitle}</p>
              <h3>{c.title}</h3>
              <p>{c.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
    <ScrollReveal />
  </main>
</SiteLayout>
