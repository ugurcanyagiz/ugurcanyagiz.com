---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "DNA: Life’s Instruction Manual — Science";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/">← Back to Atlas</a>
        <span class="chip">BIOLOGY</span>
      </div>
      <h1>DNA: Life’s Instruction Manual</h1>
      <p class="subtitle">DNA stores hereditary information in a chemical code that cells read, copy, and edit.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Code to function</h3><p>Genes are templates for RNAs and proteins that build and regulate cells.</p></div>
        <div class="card"><h3>Replication with proofreading</h3><p>Cells copy DNA with high fidelity and repair many errors.</p></div>
        <div class="card"><h3>Variation enables adaptation</h3><p>Mutations, recombination, and regulation differences drive diversity.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>DNA is transcribed into RNA.</li>
        <li>RNA is translated into proteins (or acts directly).</li>
        <li>Proteins and regulatory RNAs shape cellular behavior.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Is one gene equal to one trait?</summary><p>Rarely. Most traits involve many genes plus environment.</p></details>
        <details><summary>Why do identical twins differ over time?</summary><p>Epigenetics and life experience change gene expression.</p></details>
        <details><summary>What changed recently?</summary><p>Sequencing became cheap, enabling precision medicine and ancestry analysis.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>

</ArticleLayout>
