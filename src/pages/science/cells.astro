---
import Layout from "../../layouts/Layout.astro";

const title = "Cells: Tiny Cities — Science";
const updated = "Updated: 2026";
---

<Layout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/science">← Back to Science</a>
        <span class="chip">BIOLOGY</span>
      </div>
      <h1>Cells: Tiny Cities</h1>
      <p class="subtitle">Cells are organized systems with boundaries, power generation, logistics, and waste management.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Compartmentalization creates efficiency</h3><p>Organelles separate tasks so incompatible reactions can run safely.</p></div>
        <div class="card"><h3>Membranes are intelligent gates</h3><p>They regulate traffic, signaling, and gradients crucial for life.</p></div>
        <div class="card"><h3>Networks, not parts</h3><p>Cell behavior emerges from coordinated pathways, not single molecules.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>Membrane defines inside vs outside.</li>
        <li>Mitochondria/chloroplasts manage energy conversion.</li>
        <li>Nucleus and cytoskeleton coordinate information and structure.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Are all cells the same?</summary><p>No. Specialization creates neurons, muscle, immune cells, and more.</p></details>
        <details><summary>Can cells decide?</summary><p>They execute biochemical decision rules via signaling networks.</p></details>
        <details><summary>Why is cell biology practical?</summary><p>Cancer, aging, immunity, and drug design are cell-level problems.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>


<style>
  .page{ max-width: 920px; margin: 0 auto; padding: 28px 18px 88px; }
  .hero-top{ display:flex; align-items:center; justify-content: space-between; gap: 12px; margin-bottom: 14px; }
  .back{ color: rgba(11,11,15,0.60); font-size: 13px; font-weight: 650; text-decoration: none; }
  .back:hover{ color: rgba(11,11,15,0.92); }
  h1{ margin: 0 0 10px; font-size: 40px; font-weight: 850; letter-spacing: -0.03em; line-height: 1.08; }
  .subtitle{ margin: 0; font-size: 14px; line-height: 1.6; color: rgba(11,11,15,0.62); max-width: 78ch; }
  .chip{ font-size: 11px; font-weight: 900; letter-spacing: .14em; text-transform: uppercase; padding: 7px 10px; border-radius: 999px; border: 1px solid rgba(0,122,255,.2); background: rgba(0,122,255,.12); color: rgba(0,122,255,.9); }
  .section{ margin-top: 24px; }
  .section h2{ margin:0 0 12px; font-size: 20px; font-weight: 840; letter-spacing: -0.02em; }
  .grid{ display:grid; gap: 10px; }
  .card{ background: rgba(255,255,255,.9); border: 1px solid rgba(0,0,0,.06); border-radius: 16px; padding: 14px 16px; box-shadow: 0 8px 24px rgba(0,0,0,.05); }
  .card h3{ margin:0 0 6px; font-size: 15px; }
  .card p{ margin:0; font-size: 14px; line-height: 1.6; color: rgba(11,11,15,.66); }
  ul{ margin:0; padding-left: 18px; color: rgba(11,11,15,.7); font-size: 14px; line-height: 1.7; }
  .faq{ display:grid; gap: 10px; }
  details{ background: rgba(255,255,255,.9); border: 1px solid rgba(0,0,0,.06); border-radius: 14px; padding: 12px 14px; }
  summary{ cursor:pointer; font-weight: 800; }
  details p{ margin: 8px 0 0; font-size: 14px; line-height: 1.6; color: rgba(11,11,15,.65); }
  .footnav{ margin-top: 26px; display:flex; justify-content: space-between; gap: 12px; }
  .btn{ display:inline-flex; align-items:center; justify-content:center; padding:10px 12px; border-radius: 999px; border:1px solid rgba(0,0,0,.1); background: rgba(255,255,255,.92); font-size:13px; font-weight:800; text-decoration:none; color: rgba(11,11,15,.85); }
  @media (max-width: 640px){ h1{ font-size: 34px; } .footnav{ flex-direction: column; } }
</style>

</Layout>
