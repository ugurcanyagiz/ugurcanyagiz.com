---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "Chemistry That Powers Life — Science";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/">← Back to Atlas</a>
        <span class="chip">BIOLOGY</span>
      </div>
      <h1>Chemistry That Powers Life</h1>
      <p class="subtitle">Living systems are controlled chemical networks that process energy, matter, and information.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Metabolism is organized chemistry</h3><p>Cells run linked pathways that convert nutrients into usable energy and building blocks.</p></div>
        <div class="card"><h3>Enzymes are molecular catalysts</h3><p>They speed specific reactions while reducing unwanted side effects.</p></div>
        <div class="card"><h3>Homeostasis is dynamic control</h3><p>Feedback loops keep pH, temperature, and signaling in viable ranges.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>Capture energy from food or light.</li>
        <li>Convert it into ATP and reducing power.</li>
        <li>Use controlled reactions for growth, repair, and signaling.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Is biology separate from chemistry?</summary><p>No, biology is chemistry under evolutionary constraints.</p></details>
        <details><summary>Why is water central?</summary><p>Its polarity and heat capacity make it an ideal reaction medium.</p></details>
        <details><summary>What is the key takeaway?</summary><p>Life works because reactions are compartmentalized, catalyzed, and regulated.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>

</ArticleLayout>
