---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "Evolution (Without the Drama) — Science";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/">← Back to Atlas</a>
        <span class="chip">BIOLOGY</span>
      </div>
      <h1>Evolution (Without the Drama)</h1>
      <p class="subtitle">Evolution is cumulative change in populations driven by variation, selection, drift, and time.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Selection is context-dependent</h3><p>Traits are favored when they improve reproduction in a given environment.</p></div>
        <div class="card"><h3>Random mutation, non-random filtering</h3><p>Mutations appear without direction; selection filters outcomes.</p></div>
        <div class="card"><h3>Small steps create big shifts</h3><p>Complex adaptations emerge over many generations.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>Variation arises through mutation and recombination.</li>
        <li>Environmental pressures alter survival and reproductive success.</li>
        <li>Gene frequencies shift across generations.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Does evolution have a final goal?</summary><p>No. It responds to current constraints, not a preset destination.</p></details>
        <details><summary>Can evolution happen quickly?</summary><p>Yes, especially in microbes and under strong selective pressure.</p></details>
        <details><summary>How strong is the evidence?</summary><p>Genetics, fossils, and observed adaptation all converge.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>

</ArticleLayout>
