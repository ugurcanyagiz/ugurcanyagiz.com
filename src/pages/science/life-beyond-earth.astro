---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "Life Beyond Earth (Careful Optimism) — Science";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/">← Back to Atlas</a>
        <span class="chip">SPACE</span>
      </div>
      <h1>Life Beyond Earth (Careful Optimism)</h1>
      <p class="subtitle">Astrobiology asks how common life is by combining chemistry, planetary science, and signal detection.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Chemistry is universal</h3><p>The same physical laws and elements exist across the cosmos.</p></div>
        <div class="card"><h3>Habitable does not mean inhabited</h3><p>Water and energy sources are necessary but not sufficient.</p></div>
        <div class="card"><h3>Evidence hierarchy matters</h3><p>Biosignatures require cross-checks to avoid false positives.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>Identify potentially habitable environments.</li>
        <li>Search for atmospheric or geochemical biosignatures.</li>
        <li>Validate with independent instruments and models.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Have we found alien life?</summary><p>No confirmed discovery as of 2026.</p></details>
        <details><summary>Best places to search nearby?</summary><p>Mars, Europa, Enceladus, and exoplanets with promising atmospheres.</p></details>
        <details><summary>Why “careful optimism”?</summary><p>Because priors are uncertain, but the search space is enormous and improving.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>

</ArticleLayout>
