---
import ArticleLayout from "../../components/ArticleLayout.astro";

const title = "Language: The Human Superpower — Science";
const updated = "Updated: 2026";
---

<ArticleLayout title={title}>
  <article class="page">
    <header>
      <div class="hero-top">
        <a class="back" href="/">← Back to Atlas</a>
        <span class="chip">MIND</span>
      </div>
      <h1>Language: The Human Superpower</h1>
      <p class="subtitle">Language compresses complex thought into shareable symbols, enabling collective intelligence.</p>
      <p class="subtitle">{updated}</p>
    </header>

    <section class="section">
      <h2>Key ideas</h2>
      <div class="grid">
        <div class="card"><h3>Compression and abstraction</h3><p>Words package high-dimensional experience into reusable concepts.</p></div>
        <div class="card"><h3>Coordination technology</h3><p>Shared language allows planning, law, science, and institutions at scale.</p></div>
        <div class="card"><h3>Learning loops</h3><p>Culture accumulates because knowledge survives individual lifetimes.</p></div>
      </div>
    </section>

    <section class="section">
      <h2>Mental model</h2>
      <div class="card">
        <ul>
        <li>Perception maps to concepts.</li>
        <li>Grammar structures relations across concepts.</li>
        <li>Communication aligns mental models between people.</li>
        </ul>
      </div>
    </section>

    <section class="section">
      <h2>FAQ</h2>
      <div class="faq">
        <details><summary>Is language only speech?</summary><p>No. Sign languages and writing are equally rich systems.</p></details>
        <details><summary>Do languages shape thought?</summary><p>They influence attention and framing, though humans can think beyond one language.</p></details>
        <details><summary>Why is this a superpower?</summary><p>It turns individual cognition into networked civilization.</p></details>
      </div>
    </section>

    <nav class="footnav">
      <a class="btn" href="/science">← Science index</a>
      <a class="btn" href="/future">Explore Future →</a>
    </nav>
  </article>

</ArticleLayout>
