---
import Layout from "../layouts/Layout.astro";
import AtlasBackground from "../components/AtlasBackground.astro";
import SolarSystemHub from "../components/SolarSystemHub.astro";
---

<Layout title="UGURCAN" description="A minimal orbit navigation for Ugurcan Yagiz.">
  <main class="atlas-page home-atlas thought-home" aria-label="Orbit navigation homepage">
    <AtlasBackground variant="atlas" id="home-atlas-scene" />
    <div class="atlas-content atlas-content--wide">
      <SolarSystemHub />
    </div>
  </main>
</Layout>
