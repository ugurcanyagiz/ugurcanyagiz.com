---
import SiteLayout from "../components/SiteLayout.astro";
import FilterBar from "../components/FilterBar.astro";

/**
 * Categories (filters) for ART
 * Keep these exact strings in:
 * - filters array
 * - card.category
 * - badge--CATEGORY class names
 */
const filters = ["ALL", "PAINTING", "MUSIC", "ARCHITECTURE", "FILM", "DESIGN", "PHOTOGRAPHY"];

const cards = [
  {
    href: "/art/why-we-like-melodies",
    category: "MUSIC",
    subtitle: "Harmony • Emotion",
    title: "Why Melodies Feel Like Memories",
    excerpt:
      "A simple melody can trigger emotion faster than words. Here’s why your brain treats music like a shortcut to feeling.",
    img: "https://images.unsplash.com/photo-1511379938547-c1f69419868d?w=200&q=80",
  },
  {
    href: "/art/composition-in-painting",
    category: "PAINTING",
    subtitle: "Balance • Attention",
    title: "Composition: How Paintings Control Your Eyes",
    excerpt:
      "Great paintings ‘direct’ your attention using contrast, lines, and spacing—like invisible choreography.",
    img: "https://images.unsplash.com/photo-1541961017774-22349e4a1262?w=200&q=80",
  },
  {
    href: "/art/architecture-as-a-language",
    category: "ARCHITECTURE",
    subtitle: "Space • Human behavior",
    title: "Architecture Is a Language (Without Words)",
    excerpt:
      "Buildings silently tell you where to walk, where to rest, and how to feel—open, safe, or overwhelmed.",
    img: "https://images.unsplash.com/photo-1529421308418-eab98863cee1?w=200&q=80",
  },
  {
    href: "/art/film-editing-invisible-art",
    category: "FILM",
    subtitle: "Cuts • Rhythm",
    title: "Editing: The Invisible Art That Creates Meaning",
    excerpt:
      "A cut is not just a cut. It decides what you know, what you miss, and what you feel—second by second.",
    img: "https://images.unsplash.com/photo-1524985069026-dd778a71c7b4?w=200&q=80",
  },
  {
    href: "/art/minimalism-why-it-works",
    category: "DESIGN",
    subtitle: "Clarity • Reduction",
    title: "Minimalism: Why Less Often Feels Better",
    excerpt:
      "Minimal design removes negotiation. When choices shrink, attention sharpens—and the message lands cleaner.",
    img: "https://images.unsplash.com/photo-1526481280695-3c687fd643ed?w=200&q=80",
  },
  {
    href: "/art/photography-light",
    category: "PHOTOGRAPHY",
    subtitle: "Light • Depth",
    title: "Light: The One Thing Every Great Photo Shares",
    excerpt:
      "You can fix many things—but not bad light. Here’s how light creates shape, mood, and realism.",
    img: "https://images.unsplash.com/photo-1500530855697-b586d89ba3ee?w=200&q=80",
  },
  {
    href: "/art/color-theory-simple",
    category: "DESIGN",
    subtitle: "Color • Perception",
    title: "Color Theory (Made Simple)",
    excerpt:
      "Colors don’t just decorate. They signal distance, importance, temperature, and emotion—instantly.",
    img: "https://images.unsplash.com/photo-1513364776144-60967b0f800f?w=200&q=80",
  },
  {
    href: "/art/film-sound-design",
    category: "FILM",
    subtitle: "Silence • Tension",
    title: "Sound Design: The Secret Weapon of Cinema",
    excerpt:
      "The scariest moment in a movie is often made by sound—tiny details your brain reads as ‘real.’",
    img: "https://images.unsplash.com/photo-1485846234645-a62644f84728?w=200&q=80",
  },
  {
    href: "/art/painting-brushwork",
    category: "PAINTING",
    subtitle: "Texture • Time",
    title: "Brushwork: You Can See the Artist’s Decisions",
    excerpt:
      "Brushwork is visible thinking. It shows speed, confidence, doubt—and sometimes the artist’s mood.",
    img: "https://images.unsplash.com/photo-1517694712202-14dd9538aa97?w=200&q=80",
  },
  {
    href: "/art/music-tension-release",
    category: "MUSIC",
    subtitle: "Tension • Release",
    title: "Why Music Feels Like a Story",
    excerpt:
      "Music creates expectation, then resolves it. That tension-and-release loop is why songs feel like journeys.",
    img: "https://images.unsplash.com/photo-1470225620780-dba8ba36b745?w=200&q=80",
  },
];

import AtlasBackground from "../components/AtlasBackground.astro";
import SectionHeader from "../components/SectionHeader.astro";
import ScrollReveal from "../components/ScrollReveal.astro";
---
<SiteLayout title="Art — Ugurcan" description="A digital gallery about perception and craft — music, painting, architecture, film, design, and photography.">
  <FilterBar slot="subnav" filters={filters} cardSelector=".art-card" queryKey="topic" defaultFilter="ALL" />
  <main class="atlas-page art-atlas">
    <AtlasBackground variant="art" id="art-scene" />
    <div class="atlas-content">
      <section class="atlas-hero">
        <div class="atlas-hero__panel" data-reveal>
          <p class="atlas-eyebrow">Personal atlas / Art</p>
          <h1>Art</h1>
          <p class="atlas-hero__subtitle">A digital gallery about perception and craft — music, painting, architecture, film, design, and photography.</p>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Scroll system" title="Music → Painting → Architecture → Film → Design → Photography" text="Move through this room like an exhibition: each card is a fragment, a question, and a doorway into a longer note." />
        <div class="atlas-grid atlas-grid--four">
          <article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Music</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Painting</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Architecture</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Film</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Design</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article><article class="atlas-card" data-reveal style="--accent: rgba(141,223,255,.18)"><span class="atlas-glyph">✦</span><h3>Photography</h3><p>A layer in the map: patterns, examples, and quiet connections.</p></article>
        </div>
      </section>

      <section class="atlas-section">
        <SectionHeader eyebrow="Archive" title="Existing notes, redesigned as exhibition cards" text="All routes and articles are preserved; the visual system now matches the surreal premium direction of /me." />
        <div class="atlas-grid">
          {cards.map((c) => (
            <a class="atlas-card art-card" href={c.href} data-category={c.category} data-reveal>
              <span class="atlas-glyph" aria-hidden="true">✧</span>
              <p class="atlas-eyebrow">{c.category} · {c.subtitle}</p>
              <h3>{c.title}</h3>
              <p>{c.excerpt}</p>
            </a>
          ))}
        </div>
      </section>
    </div>
    <ScrollReveal />
  </main>
</SiteLayout>
