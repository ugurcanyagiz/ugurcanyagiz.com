---
const categories = [
  { key: 'jlog', title: 'JLOG', href: '/blog' },
  { key: 'science', title: 'Science', href: '/science' },
  { key: 'history', title: 'History', href: '/history' },
  { key: 'art', title: 'Art', href: '/art' },
  { key: 'future', title: 'Future', href: '/future' },
];
---

<section class="circle-hub" data-circle-hub aria-label="Primary orbit navigation">
  <div class="circle-hub__atmosphere" aria-hidden="true"></div>
  <div class="circle-hub__scene" data-orbit-scene>
    <div class="circle-hub__orbit" data-orbit>
      <div class="circle-hub__guide circle-hub__guide--outer" aria-hidden="true"></div>
      {categories.map((category, index) => (
        <a
          class="orbit-item orbit-item--main"
          href={category.href}
          data-category={category.key}
          data-index={index}
          style={`--i:${index};--count:${categories.length};`}
          aria-label={`Open ${category.title}`}
        >
          <span class="orbit-item__label">{category.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const hub = document.querySelector('[data-circle-hub]');

  if (hub) {
    const orbit = hub.querySelector('[data-orbit]');
    const scene = hub.querySelector('[data-orbit-scene]');
    const items = Array.from(hub.querySelectorAll('[data-category]'));
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mobileQuery = window.matchMedia('(max-width: 640px)');
    let targetRotation = 0;
    let currentRotation = 0;
    let velocity = 0;
    let mouseX = 0;
    let mouseY = 0;
    let targetMouseX = 0;
    let targetMouseY = 0;
    let touchY = null;

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));

    const getRadii = () => {
      const width = window.innerWidth;
      const height = window.innerHeight;
      const isMobile = mobileQuery.matches;
      return {
        x: Math.min(width * (isMobile ? 0.32 : 0.34), isMobile ? 168 : 455),
        y: Math.min(height * (isMobile ? 0.24 : 0.245), isMobile ? 142 : 228),
        centerY: isMobile ? 0.54 : 0.515,
      };
    };

    const rotateByDelta = (deltaY) => {
      if (reduce) return;
      const normalized = clamp(deltaY, -120, 120);
      targetRotation += normalized * (mobileQuery.matches ? 0.0048 : 0.0042);
      velocity += normalized * (mobileQuery.matches ? 0.0009 : 0.00075);
    };

    const onWheel = (event) => {
      event.preventDefault();
      rotateByDelta(event.deltaY);
    };

    window.addEventListener('wheel', onWheel, { passive: false });

    window.addEventListener('touchstart', (event) => {
      touchY = event.touches[0]?.clientY ?? null;
    }, { passive: true });

    window.addEventListener('touchmove', (event) => {
      if (touchY === null) return;
      event.preventDefault();
      const nextY = event.touches[0]?.clientY ?? touchY;
      rotateByDelta((touchY - nextY) * 1.65);
      touchY = nextY;
    }, { passive: false });

    window.addEventListener('touchend', () => {
      touchY = null;
    }, { passive: true });

    hub.addEventListener('pointermove', (event) => {
      if (reduce) return;
      const rect = hub.getBoundingClientRect();
      targetMouseX = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      targetMouseY = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
    }, { passive: true });

    hub.addEventListener('pointerleave', () => {
      targetMouseX = 0;
      targetMouseY = 0;
    });

    items.forEach((link) => {
      link.addEventListener('click', () => {
        link.classList.add('is-departing');
      });
    });

    const positionItems = () => {
      const { x: radiusX, y: radiusY, centerY } = getRadii();
      const centerX = window.innerWidth / 2;
      const center = window.innerHeight * centerY;
      const count = items.length;

      items.forEach((item, index) => {
        const baseAngle = (Math.PI * 2 * index) / count - Math.PI / 2;
        const angle = baseAngle + currentRotation;
        const x = Math.cos(angle) * radiusX;
        const y = Math.sin(angle) * radiusY;
        const depth = (Math.sin(angle) + 1) / 2;
        const front = 1 - depth;
        const scale = 0.82 + front * 0.28;
        const opacity = 0.46 + front * 0.48;
        const blur = depth * 1.15;
        const brightness = 0.74 + front * 0.42;

        item.style.setProperty('--orbit-x', `${centerX + x}px`);
        item.style.setProperty('--orbit-y', `${center + y}px`);
        item.style.setProperty('--orbit-scale', `${scale}`);
        item.style.setProperty('--orbit-opacity', `${opacity}`);
        item.style.setProperty('--orbit-blur', `${blur}px`);
        item.style.setProperty('--orbit-brightness', `${brightness}`);
        item.style.setProperty('--orbit-z', `${Math.round(20 + front * 80)}`);
      });
    };

    const tick = () => {
      if (!reduce) {
        targetRotation += velocity;
        velocity *= 0.935;
        currentRotation += (targetRotation - currentRotation) * 0.075;
        mouseX += (targetMouseX - mouseX) * 0.065;
        mouseY += (targetMouseY - mouseY) * 0.065;

        orbit.style.setProperty('--tilt-x', `${mouseY * -2.4}deg`);
        orbit.style.setProperty('--tilt-y', `${mouseX * 3.2}deg`);
        orbit.style.setProperty('--mouse-x', `${mouseX * (mobileQuery.matches ? 4 : 12)}px`);
        orbit.style.setProperty('--mouse-y', `${mouseY * (mobileQuery.matches ? 3 : 8)}px`);
        scene?.style.setProperty('--scene-parallax-x', `${mouseX * (mobileQuery.matches ? -5 : -14)}px`);
        scene?.style.setProperty('--scene-parallax-y', `${mouseY * (mobileQuery.matches ? -4 : -10)}px`);
        positionItems();
      }
      requestAnimationFrame(tick);
    };

    positionItems();
    window.addEventListener('resize', positionItems, { passive: true });
    requestAnimationFrame(tick);
  }
</script>
