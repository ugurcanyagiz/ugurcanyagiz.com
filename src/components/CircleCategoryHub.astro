---
const categories = [
  {
    key:'jlog',
    title:'JLOG',
    href:'/blog',
    description:'Personal notes, reflections, memory, belief, and becoming.',
    subtopics:['Life','Thought','Memory','Belief'],
  },
  {
    key:'science',
    title:'Science',
    href:'/science',
    description:'Cosmos, matter, life, mind, and the search for what is real.',
    subtopics:['Cosmos','Matter','Life','Mind'],
  },
  {
    key:'history',
    title:'History',
    href:'/history',
    description:'Civilizations, power, patterns, and the long memory of humanity.',
    subtopics:['Civilizations','Power','Patterns','Memory'],
  },
  {
    key:'art',
    title:'Art',
    href:'/art',
    description:'Music, images, architecture, film, and the shape of perception.',
    subtopics:['Music','Image','Architecture','Film'],
  },
  {
    key:'future',
    title:'Future',
    href:'/future',
    description:'AI, space, society, transformation, and what may come next.',
    subtopics:['AI','Space','Society','Transformation'],
  },
];

const fragments = categories.flatMap((category, categoryIndex) => (
  category.subtopics.map((topic, topicIndex) => ({
    topic,
    parent:category.title,
    categoryIndex,
    topicIndex,
  }))
));
---

<section class="circle-hub" data-circle-hub aria-label="Interactive personal knowledge atlas">
  <div class="circle-hub__atmosphere" aria-hidden="true"></div>
  <div class="circle-hub__scene">
    <div class="circle-hub__center" data-hub-center>
      <p class="atlas-eyebrow">Personal knowledge atlas</p>
      <h1>Ugurcan Yagiz</h1>
      <p>A personal space for notes on science, history, art, future thinking, and life.</p>
    </div>

    <div class="circle-hub__orbit" data-orbit>
      <div class="circle-hub__guide circle-hub__guide--outer" aria-hidden="true"></div>
      <div class="circle-hub__guide circle-hub__guide--inner" aria-hidden="true"></div>
      {categories.map((category, index) => (
        <button
          class="orbit-item orbit-item--main"
          type="button"
          data-category={category.key}
          data-title={category.title}
          data-description={category.description}
          data-subtopics={category.subtopics.join(', ')}
          data-href={category.href}
          style={`--i:${index};--count:${categories.length};`}
          aria-label={`Preview ${category.title}`}
        >
          <span class="orbit-item__label">{category.title}</span>
          <span class="orbit-item__action">Explore</span>
        </button>
      ))}
      {fragments.map((fragment, index) => (
        <span
          class="orbit-item orbit-item--fragment"
          data-fragment-parent={fragment.parent}
          style={`--i:${index};--count:${fragments.length};--ring:${fragment.topicIndex};`}
        >
          {fragment.topic}
        </span>
      ))}
    </div>

    <aside class="category-preview" data-preview aria-live="polite">
      <p class="atlas-eyebrow" data-preview-kicker>Hover or select a room</p>
      <h2 data-preview-title>JLOG</h2>
      <p data-preview-description>Personal notes, reflections, memory, belief, and becoming.</p>
      <div class="category-preview__topics" data-preview-topics>
        <span>Life</span><span>Thought</span><span>Memory</span><span>Belief</span>
      </div>
      <a class="atlas-button atlas-button--primary" href="/blog" data-preview-link>Open JLOG</a>
      <button class="category-preview__close" type="button" data-preview-close aria-label="Close category preview">×</button>
    </aside>
  </div>
</section>

<script>
  const hub = document.querySelector('[data-circle-hub]');
  if (hub) {
    const orbit = hub.querySelector('[data-orbit]');
    const preview = hub.querySelector('[data-preview]');
    const center = hub.querySelector('[data-hub-center]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    let targetRot = 0, currentRot = 0, mx = 0, my = 0, tx = 0, ty = 0, selected = false;
    const setPreview = (button, mode = 'hover') => {
      preview.querySelector('[data-preview-kicker]').textContent = mode === 'selected' ? 'Selected room' : 'Currently focused';
      preview.querySelector('[data-preview-title]').textContent = button.dataset.title;
      preview.querySelector('[data-preview-description]').textContent = button.dataset.description;
      preview.querySelector('[data-preview-link]').href = button.dataset.href;
      preview.querySelector('[data-preview-link]').textContent = `Open ${button.dataset.title}`;
      preview.querySelector('[data-preview-topics]').innerHTML = button.dataset.subtopics.split(', ').map(t => `<span>${t}</span>`).join('');
      hub.dataset.active = button.dataset.title;
      hub.querySelectorAll('[data-fragment-parent]').forEach((fragment) => fragment.classList.toggle('is-related', fragment.dataset.fragmentParent === button.dataset.title));
    };
    hub.querySelectorAll('[data-category]').forEach((button) => {
      button.addEventListener('pointerenter', () => !selected && setPreview(button));
      button.addEventListener('focus', () => !selected && setPreview(button));
      button.addEventListener('click', () => {
        selected = true;
        setPreview(button, 'selected');
        hub.classList.add('is-selected');
        button.classList.add('is-selected');
        center.classList.add('is-dimmed');
        preview.classList.add('is-open');
      });
    });

    hub.querySelector('[data-preview-close]').addEventListener('click', () => {
      selected = false;
      hub.classList.remove('is-selected');
      center.classList.remove('is-dimmed');
      preview.classList.remove('is-open');
      hub.querySelectorAll('.is-selected').forEach((el) => el.classList.remove('is-selected'));
    });

    if (!reduce) {
      const updateScroll = () => {
        const rect = hub.getBoundingClientRect();
        const progress = Math.min(1, Math.max(0, (window.innerHeight - rect.top) / (window.innerHeight + rect.height)));
        targetRot = progress * 145;
      };

      window.addEventListener('scroll', updateScroll, { passive: true });
      updateScroll();

      hub.addEventListener('pointermove', (event) => {
        const rect = hub.getBoundingClientRect();
        tx = ((event.clientX - rect.left) / rect.width - .5) * 2;
        ty = ((event.clientY - rect.top) / rect.height - .5) * 2;
      });

      const tick = () => {
        currentRot += (targetRot - currentRot) * .075;
        mx += (tx - mx) * .08;
        my += (ty - my) * .08;
        orbit.style.setProperty('--scroll-rotation', `${currentRot}deg`);
        orbit.style.setProperty('--tilt-x', `${my * -3.5}deg`);
        orbit.style.setProperty('--tilt-y', `${mx * 4.5}deg`);
        orbit.style.setProperty('--mouse-x', `${mx * 8}px`);
        orbit.style.setProperty('--mouse-y', `${my * 6}px`);
        requestAnimationFrame(tick);
      };

      requestAnimationFrame(tick);
    }
  }
</script>
