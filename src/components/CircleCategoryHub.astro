---
const categories = [
  { key: 'jlog', title: 'JLOG', href: '/blog' },
  { key: 'science', title: 'Science', href: '/science' },
  { key: 'history', title: 'History', href: '/history' },
  { key: 'art', title: 'Art', href: '/art' },
  { key: 'future', title: 'Future', href: '/future' },
];
---

<section class="circle-hub" data-circle-hub aria-label="Primary orbit navigation">
  <div class="circle-hub__atmosphere" aria-hidden="true"></div>
  <div class="circle-hub__scene">
    <div class="circle-hub__orbit" data-orbit>
      <div class="circle-hub__guide circle-hub__guide--outer" aria-hidden="true"></div>
      {categories.map((category, index) => (
        <a
          class="orbit-item orbit-item--main"
          href={category.href}
          data-category={category.key}
          style={`--i:${index};--count:${categories.length};`}
          aria-label={`Open ${category.title}`}
        >
          <span class="orbit-item__label">{category.title}</span>
        </a>
      ))}
    </div>
  </div>
</section>

<script>
  const hub = document.querySelector('[data-circle-hub]');

  if (hub) {
    const orbit = hub.querySelector('[data-orbit]');
    const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const mobile = window.matchMedia('(max-width: 640px)').matches;
    let targetRot = 0;
    let currentRot = 0;
    let velocity = 0;
    let mx = 0;
    let my = 0;
    let tx = 0;
    let ty = 0;

    const applyWheelRotation = (event) => {
      if (reduce) return;
      event.preventDefault();
      const delta = Math.max(-80, Math.min(80, event.deltaY));
      velocity += delta * (mobile ? 0.055 : 0.07);
    };

    window.addEventListener('wheel', applyWheelRotation, { passive: false });

    let touchY = null;
    window.addEventListener('touchstart', (event) => {
      touchY = event.touches[0]?.clientY ?? null;
    }, { passive: true });

    window.addEventListener('touchmove', (event) => {
      if (reduce || touchY === null) return;
      event.preventDefault();
      const nextY = event.touches[0]?.clientY ?? touchY;
      velocity += (touchY - nextY) * (mobile ? 0.05 : 0.06);
      touchY = nextY;
    }, { passive: false });

    hub.addEventListener('pointermove', (event) => {
      if (reduce) return;
      const rect = hub.getBoundingClientRect();
      tx = ((event.clientX - rect.left) / rect.width - 0.5) * 2;
      ty = ((event.clientY - rect.top) / rect.height - 0.5) * 2;
    }, { passive: true });

    hub.addEventListener('pointerleave', () => {
      tx = 0;
      ty = 0;
    });

    hub.querySelectorAll('[data-category]').forEach((link) => {
      link.addEventListener('click', () => {
        link.classList.add('is-departing');
      });
    });

    const tick = () => {
      if (!reduce) {
        targetRot += velocity;
        velocity *= 0.91;
        currentRot += (targetRot - currentRot) * 0.085;
        mx += (tx - mx) * 0.07;
        my += (ty - my) * 0.07;
        orbit.style.setProperty('--scroll-rotation', `${currentRot}deg`);
        orbit.style.setProperty('--tilt-x', `${my * -3}deg`);
        orbit.style.setProperty('--tilt-y', `${mx * 4}deg`);
        orbit.style.setProperty('--mouse-x', `${mx * (mobile ? 3 : 8)}px`);
        orbit.style.setProperty('--mouse-y', `${my * (mobile ? 2 : 6)}px`);
      }
      requestAnimationFrame(tick);
    };

    requestAnimationFrame(tick);
  }
</script>
