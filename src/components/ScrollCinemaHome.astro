---
const nodes = [
  { title: "Science", href: "/science", index: "01", kicker: "Matter & mind", className: "science" },
  { title: "History", href: "/history", index: "02", kicker: "Time & empire", className: "history" },
  { title: "Art", href: "/art", index: "03", kicker: "Form & feeling", className: "art" },
  { title: "Future", href: "/future", index: "04", kicker: "Signals ahead", className: "future" },
  { title: "JLOG", href: "/blog", index: "05", kicker: "Field notes", className: "jlog" },
];
---

<section class="atlas" data-knowledge-atlas aria-label="UGURCAN interactive knowledge atlas homepage">
  <div class="atlas__sticky">
    <canvas class="atlas__canvas" data-atlas-canvas aria-hidden="true"></canvas>
    <svg class="atlas__sigils" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="atlasGold" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0" stop-color="#fff4c7" stop-opacity=".7" />
          <stop offset=".55" stop-color="#d7a84f" stop-opacity=".3" />
          <stop offset="1" stop-color="#79d7ff" stop-opacity=".16" />
        </linearGradient>
      </defs>
      <path class="atlas__curve atlas__curve--science" d="M173 424 C 304 244, 489 239, 594 392 S 866 570, 1038 355" />
      <path class="atlas__curve atlas__curve--history" d="M128 519 C 316 571, 419 324, 608 397 S 858 502, 1068 279" />
      <path class="atlas__curve atlas__curve--art" d="M195 294 C 347 196, 432 566, 595 402 S 842 202, 1032 491" />
      <path class="atlas__curve atlas__curve--future" d="M108 402 C 332 361, 427 430, 600 400 S 881 342, 1104 403" />
    </svg>

    <div class="atlas__shade" aria-hidden="true"></div>
    <div class="atlas__grain" aria-hidden="true"></div>

    <a class="atlas__brand" href="/" aria-label="UGURCAN home">
      <span>UGURCAN</span>
      <small>Knowledge Atlas</small>
    </a>

    <nav class="atlas__nav" aria-label="Primary sections" data-atlas-nav>
      {nodes.map((node) => (
        <a class:list={["atlas__node", `atlas__node--${node.className}`]} href={node.href} aria-label={`Open ${node.title}`} data-atlas-node>
          <span class="atlas__node-index">{node.index}</span>
          <span class="atlas__node-mark" aria-hidden="true"></span>
          <span class="atlas__node-text">
            <span class="atlas__node-title">{node.title}</span>
            <span class="atlas__node-kicker">{node.kicker}</span>
          </span>
        </a>
      ))}
    </nav>

    <p class="atlas__phase" data-atlas-phase aria-live="polite">Quiet cosmic core</p>
    <div class="atlas__meter" aria-hidden="true"><span></span></div>
  </div>
</section>

<script>
  const atlases = document.querySelectorAll('[data-knowledge-atlas]');

  atlases.forEach((atlas) => {
    const canvas = atlas.querySelector('[data-atlas-canvas]');
    const ctx = canvas.getContext('2d', { alpha: true, desynchronized: true });
    const nodes = Array.from(atlas.querySelectorAll('[data-atlas-node]'));
    const phaseLabel = atlas.querySelector('[data-atlas-phase]');
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointerQuery = window.matchMedia('(pointer: fine) and (min-width: 900px)');
    const phases = ['Quiet cosmic core', 'Science: particle field', 'History: orbital time', 'Art: organic harmonics', 'Future: unified atlas'];

    let width = 1;
    let height = 1;
    let dpr = 1;
    let target = 0;
    let progress = 0;
    let raf = 0;
    let time = 0;
    let pointerX = 0;
    let pointerY = 0;
    let reduce = reduceQuery.matches;
    let particles = [];

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const lerp = (a, b, t) => a + (b - a) * t;
    const smooth = (edge0, edge1, x) => {
      const t = clamp((x - edge0) / (edge1 - edge0), 0, 1);
      return t * t * (3 - 2 * t);
    };

    function seedParticles() {
      const count = window.innerWidth < 700 ? 86 : window.innerWidth < 1100 ? 130 : 180;
      particles = Array.from({ length: count }, (_, i) => ({
        angle: (i * 2.399963 + (i % 7) * .17) % (Math.PI * 2),
        radius: .12 + ((i * 37) % 100) / 100 * .78,
        size: .45 + ((i * 19) % 100) / 100 * 1.75,
        speed: .12 + ((i * 13) % 100) / 100 * .42,
        tone: i % 5,
      }));
    }

    function sizeCanvas() {
      dpr = Math.min(window.devicePixelRatio || 1, window.innerWidth < 700 ? 1.45 : 2);
      const rect = canvas.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width * dpr));
      height = Math.max(1, Math.floor(rect.height * dpr));
      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }
    }

    function updateProgress() {
      const rect = atlas.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      target = reduce ? 0 : clamp(-rect.top / scrollable, 0, 1);
      atlas.style.setProperty('--progress', target.toFixed(4));
      if (!raf) raf = requestAnimationFrame(draw);
    }

    function drawOrbitalRing(cx, cy, rx, ry, rotation, alpha, color) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.scale(1, ry / rx);
      ctx.beginPath();
      ctx.arc(0, 0, rx, 0, Math.PI * 2);
      ctx.strokeStyle = color;
      ctx.globalAlpha = alpha;
      ctx.lineWidth = Math.max(1, dpr);
      ctx.stroke();
      ctx.restore();
    }

    function draw() {
      raf = 0;
      const easing = reduce ? 1 : window.innerWidth < 700 ? .18 : .095;
      progress = lerp(progress, target, easing);
      time += reduce ? 0 : .012;
      atlas.style.setProperty('--draw-progress', progress.toFixed(4));
      atlas.style.setProperty('--mx', pointerX.toFixed(3));
      atlas.style.setProperty('--my', pointerY.toFixed(3));

      const cx = width * (.5 + pointerX * .018);
      const cy = height * (.5 + pointerY * .014);
      const min = Math.min(width, height);
      const science = smooth(.16, .38, progress);
      const history = smooth(.36, .58, progress);
      const art = smooth(.56, .78, progress);
      const future = smooth(.76, 1, progress);

      ctx.clearRect(0, 0, width, height);
      const bg = ctx.createRadialGradient(cx, cy, min * .04, cx, cy, min * .86);
      bg.addColorStop(0, `rgba(35, 29, 18, ${.78 + future * .1})`);
      bg.addColorStop(.28, '#07111f');
      bg.addColorStop(.68, '#030711');
      bg.addColorStop(1, '#01030a');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      ctx.save();
      ctx.globalAlpha = .08 + future * .08;
      ctx.strokeStyle = '#a9c8dd';
      ctx.lineWidth = 1 * dpr;
      const grid = 72 * dpr;
      for (let x = (cx % grid); x < width; x += grid) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(lerp(x, cx, .08), height); ctx.stroke(); }
      for (let y = (cy % grid); y < height; y += grid) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(width, lerp(y, cy, .08)); ctx.stroke(); }
      ctx.restore();

      particles.forEach((p) => {
        const layerPull = lerp(.72, 1.08, progress);
        const a = p.angle + time * p.speed + progress * (p.tone % 2 ? 1.7 : -1.25);
        const orbit = p.radius * min * .58 * layerPull;
        const x = cx + Math.cos(a) * orbit * (1 + history * .18);
        const y = cy + Math.sin(a) * orbit * (.48 + art * .12);
        const alpha = .14 + science * .36 + future * .18;
        ctx.beginPath();
        ctx.fillStyle = p.tone === 0 ? `rgba(235, 187, 91, ${alpha})` : `rgba(213, 231, 244, ${alpha * .72})`;
        ctx.arc(x, y, p.size * dpr * (1 + future * .45), 0, Math.PI * 2);
        ctx.fill();
      });

      for (let i = 0; i < 6; i += 1) {
        drawOrbitalRing(cx, cy, min * (.19 + i * .082 + future * .018), min * (.055 + i * .024 + history * .02), time * (.18 + i * .03) + progress * i, .11 + i * .018 + history * .05, i % 2 ? 'rgba(240,198,111,.88)' : 'rgba(166,213,238,.62)');
      }

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(time * .24 + progress * 2.2);
      for (let i = 0; i < 18; i += 1) {
        const a = i / 18 * Math.PI * 2;
        const r = min * (.15 + Math.sin(i * 1.7 + time) * .012 + art * .045);
        ctx.beginPath();
        ctx.moveTo(Math.cos(a) * r * .42, Math.sin(a) * r * .42);
        ctx.quadraticCurveTo(Math.cos(a + .55) * r, Math.sin(a + .55) * r, Math.cos(a + 1.15) * r * .72, Math.sin(a + 1.15) * r * .72);
        ctx.strokeStyle = `rgba(237, 202, 128, ${art * .18 + future * .08})`;
        ctx.lineWidth = (1.2 + art * 1.2) * dpr;
        ctx.stroke();
      }
      ctx.restore();

      const core = ctx.createRadialGradient(cx - min * .035, cy - min * .045, 0, cx, cy, min * (.145 + future * .018));
      core.addColorStop(0, 'rgba(255,247,213,.95)');
      core.addColorStop(.18, 'rgba(234,186,83,.8)');
      core.addColorStop(.48, 'rgba(71,105,130,.34)');
      core.addColorStop(1, 'rgba(2,6,14,0)');
      ctx.fillStyle = core;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.15 + future * .02), 0, Math.PI * 2);
      ctx.fill();

      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      ctx.strokeStyle = `rgba(255, 224, 146, ${.28 + future * .34})`;
      ctx.lineWidth = (1.4 + future * 1.6) * dpr;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.05 + future * .08), time, time + Math.PI * (1.15 + future));
      ctx.stroke();
      ctx.restore();

      updateNodes(progress);
      const phaseIndex = Math.min(4, Math.floor(progress * 5));
      if (phaseLabel && phaseLabel.textContent !== phases[phaseIndex]) phaseLabel.textContent = phases[phaseIndex];
      if (Math.abs(progress - target) > .001 || !reduce) raf = requestAnimationFrame(draw);
    }

    function updateNodes(p) {
      const radiusX = Math.min(window.innerWidth * (window.innerWidth < 700 ? .36 : .34), 520);
      const radiusY = Math.min(window.innerHeight * (window.innerWidth < 700 ? .33 : .28), 265);
      nodes.forEach((node, index) => {
        const angle = index / nodes.length * Math.PI * 2 - Math.PI / 2 + p * Math.PI * 1.45;
        const depth = (Math.sin(angle) + 1) / 2;
        node.style.setProperty('--x', `${Math.cos(angle) * radiusX}px`);
        node.style.setProperty('--y', `${Math.sin(angle) * radiusY}px`);
        node.style.setProperty('--s', lerp(.78, 1.12, depth).toFixed(3));
        node.style.setProperty('--o', lerp(.56, 1, depth).toFixed(3));
        node.style.setProperty('--z', String(Math.round(10 + depth * 90)));
      });
    }

    function onPointerMove(event) {
      if (!finePointerQuery.matches || reduce) return;
      pointerX = (event.clientX / window.innerWidth - .5) * 2;
      pointerY = (event.clientY / window.innerHeight - .5) * 2;
    }

    sizeCanvas();
    seedParticles();
    updateNodes(0);
    updateProgress();
    window.addEventListener('scroll', updateProgress, { passive: true });
    window.addEventListener('resize', () => { sizeCanvas(); seedParticles(); updateProgress(); }, { passive: true });
    window.addEventListener('pointermove', onPointerMove, { passive: true });
    reduceQuery.addEventListener?.('change', (event) => { reduce = event.matches; updateProgress(); });
  });
</script>

<style>
  .atlas {
    --progress: 0;
    --draw-progress: 0;
    --mx: 0;
    --my: 0;
    min-height: 340vh;
    background: #01030a;
    color: #fff7df;
  }

  .atlas__sticky {
    position: sticky;
    top: 0;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    place-items: center;
    background: #01030a;
  }

  .atlas__canvas,
  .atlas__sigils,
  .atlas__shade,
  .atlas__grain {
    position: absolute;
    inset: 0;
  }

  .atlas__canvas {
    z-index: -4;
    width: 100%;
    height: 100%;
  }

  .atlas__sigils {
    z-index: -3;
    opacity: .82;
    transform: translate3d(calc(var(--mx) * -10px), calc(var(--my) * -8px), 0) scale(1.02);
  }

  .atlas__curve {
    fill: none;
    stroke: url(#atlasGold);
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 9 18;
    opacity: 0;
  }

  .atlas__curve--science { opacity: calc(max(0, min(1, (var(--draw-progress) - .18) * 6)) * .36); }
  .atlas__curve--history { opacity: calc(max(0, min(1, (var(--draw-progress) - .38) * 6)) * .34); }
  .atlas__curve--art { opacity: calc(max(0, min(1, (var(--draw-progress) - .58) * 6)) * .48); stroke-dasharray: 2 13; }
  .atlas__curve--future { opacity: calc(max(0, min(1, (var(--draw-progress) - .78) * 7)) * .58); stroke-dasharray: 1 10; }

  .atlas__shade {
    z-index: 5;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 50%, transparent 0 34%, rgba(1,3,10,.34) 64%, rgba(1,3,10,.92) 100%),
      linear-gradient(180deg, rgba(1,3,10,.64), transparent 24%, transparent 70%, rgba(1,3,10,.72));
  }

  .atlas__grain {
    z-index: 6;
    pointer-events: none;
    opacity: .12;
    mix-blend-mode: overlay;
    background-image: repeating-radial-gradient(circle at 30% 20%, rgba(255,255,255,.22) 0 1px, transparent 1px 4px);
  }

  .atlas__brand {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 18;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: #fff7df;
    text-decoration: none;
    transform: translate3d(calc(-50% + var(--mx) * -6px), calc(-50% + var(--my) * -5px), 0);
  }

  .atlas__brand span {
    font-size: clamp(18px, 2.2vw, 31px);
    font-weight: 850;
    letter-spacing: .48em;
    text-indent: .48em;
    text-shadow: 0 0 36px rgba(234, 187, 91, .52), 0 22px 80px rgba(0,0,0,.86);
  }

  .atlas__brand small {
    color: rgba(255,247,223,.56);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: .34em;
    text-transform: uppercase;
  }

  .atlas__brand::before,
  .atlas__brand::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(236, 196, 114, .22);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%) rotateX(68deg) rotateZ(calc(var(--draw-progress) * 38deg));
  }

  .atlas__brand::before { width: clamp(170px, 25vw, 330px); aspect-ratio: 1; }
  .atlas__brand::after { width: clamp(250px, 38vw, 520px); aspect-ratio: 1; opacity: .5; }

  .atlas__nav {
    position: absolute;
    inset: 0;
    z-index: 30;
    pointer-events: none;
    perspective: 1200px;
  }

  .atlas__node {
    --x: 0px;
    --y: 0px;
    --s: 1;
    --o: 1;
    --z: 20;
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: var(--z);
    display: inline-grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 10px;
    min-width: clamp(138px, 15vw, 186px);
    min-height: 58px;
    padding: 11px 14px;
    color: #fff7df;
    text-decoration: none;
    border: 1px solid rgba(255, 247, 223, .15);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255,255,255,.13), rgba(255,255,255,.045));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 24px 70px rgba(0,0,0,.32);
    opacity: var(--o);
    backdrop-filter: blur(24px) saturate(140%);
    pointer-events: auto;
    transform: translate(-50%, -50%) translate3d(var(--x), var(--y), 0) scale(var(--s));
    transition: border-color .22s ease, background .22s ease, box-shadow .22s ease, opacity .22s ease;
    will-change: transform, opacity;
  }

  .atlas__node:hover,
  .atlas__node:focus-visible {
    border-color: rgba(239, 202, 128, .62);
    background: linear-gradient(135deg, rgba(255,255,255,.22), rgba(255,255,255,.075));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.25), 0 28px 90px rgba(222, 174, 82, .22);
    outline: none;
  }

  .atlas__node-index {
    color: rgba(237, 202, 128, .76);
    font-size: 10px;
    font-weight: 850;
    letter-spacing: .18em;
  }

  .atlas__node-mark {
    width: 9px;
    aspect-ratio: 1;
    border-radius: 999px;
    background: #eac06c;
    box-shadow: 0 0 20px rgba(234, 192, 108, .7);
  }

  .atlas__node-text { display: flex; min-width: 0; flex-direction: column; gap: 3px; }
  .atlas__node-title { font-size: 15px; font-weight: 780; letter-spacing: -.01em; }
  .atlas__node-kicker { color: rgba(255,247,223,.55); font-size: 11px; white-space: nowrap; }

  .atlas__phase {
    position: absolute;
    left: clamp(18px, 4vw, 56px);
    bottom: clamp(18px, 4vw, 44px);
    z-index: 28;
    margin: 0;
    color: rgba(255,247,223,.66);
    font-size: 11px;
    font-weight: 750;
    letter-spacing: .24em;
    text-transform: uppercase;
  }

  .atlas__meter {
    position: absolute;
    right: clamp(18px, 3vw, 34px);
    top: 50%;
    z-index: 28;
    width: 2px;
    height: 130px;
    overflow: hidden;
    border-radius: 999px;
    background: rgba(255,255,255,.13);
    transform: translateY(-50%);
  }

  .atlas__meter span {
    display: block;
    width: 100%;
    height: calc(var(--progress) * 100%);
    background: linear-gradient(#fff7df, #d9a64e);
  }

  @media (max-width: 900px) {
    .atlas { min-height: 300vh; }
    .atlas__brand span { font-size: 15px; letter-spacing: .36em; text-indent: .36em; }
    .atlas__brand small { display: none; }
    .atlas__node { min-width: 118px; min-height: 48px; padding: 10px 12px; gap: 8px; border-radius: 18px; }
    .atlas__node-kicker { display: none; }
    .atlas__node-title { font-size: 13px; }
    .atlas__node-index { font-size: 9px; }
    .atlas__phase { max-width: 220px; font-size: 10px; letter-spacing: .16em; }
    .atlas__meter { display: none; }
  }

  @media (max-width: 520px) {
    .atlas__node { min-width: 104px; grid-template-columns: auto 1fr; }
    .atlas__node-mark { display: none; }
  }

  @media (prefers-reduced-motion: reduce) {
    .atlas { min-height: 100svh; }
    .atlas__sigils,
    .atlas__brand { transform: none; }
    .atlas__node { transition: none; }
  }
</style>
