---
const nodes = [
  { title: "Science", href: "/science", index: "01", kicker: "Matter & mind", className: "science" },
  { title: "History", href: "/history", index: "02", kicker: "Time & empire", className: "history" },
  { title: "Art", href: "/art", index: "03", kicker: "Form & feeling", className: "art" },
  { title: "Future", href: "/future", index: "04", kicker: "Signals ahead", className: "future" },
  { title: "JLOG", href: "/blog", index: "05", kicker: "Field notes", className: "jlog" },
];
---

<section class="scroll-cinema" data-scroll-cinema aria-label="UGURCAN cinematic knowledge atlas homepage">
  <div class="scroll-cinema__sticky">
    <canvas class="scroll-cinema__canvas" data-cinema-canvas aria-hidden="true"></canvas>
    <picture class="scroll-cinema__fallback" data-cinema-fallback aria-hidden="true">
      <source srcset="/images/orbit-bg-mobile.webp" media="(orientation: portrait), (max-width: 640px)" />
      <source srcset="/images/orbit-bg-tablet.webp" media="(max-width: 1180px)" />
      <img src="/images/orbit-bg-desktop.webp" alt="" loading="eager" decoding="async" fetchpriority="high" draggable="false" />
    </picture>

    <div class="scroll-cinema__stars" aria-hidden="true"></div>
    <div class="scroll-cinema__field" aria-hidden="true"></div>
    <div class="scroll-cinema__orbit scroll-cinema__orbit--wide" aria-hidden="true"></div>
    <div class="scroll-cinema__orbit scroll-cinema__orbit--tight" aria-hidden="true"></div>
    <div class="scroll-cinema__gold" aria-hidden="true"></div>
    <div class="scroll-cinema__depth" aria-hidden="true"></div>
    <div class="scroll-cinema__vignette" aria-hidden="true"></div>
    <div class="scroll-cinema__grain" aria-hidden="true"></div>

    <a class="scroll-cinema__brand" href="/" aria-label="UGURCAN home">UGURCAN</a>

    <nav class="scroll-cinema__nodes" aria-label="Primary sections" data-orbit-nav>
      {nodes.map((node) => (
        <a class:list={["scroll-cinema__node", `scroll-cinema__node--${node.className}`]} href={node.href} aria-label={`Open ${node.title}`} data-orbit-node>
          <span class="scroll-cinema__node-index">{node.index}</span>
          <span class="scroll-cinema__node-text">
            <span class="scroll-cinema__node-title">{node.title}</span>
            <span class="scroll-cinema__node-kicker">{node.kicker}</span>
          </span>
          <span class="scroll-cinema__node-arrow" aria-hidden="true">↗</span>
        </a>
      ))}
    </nav>

    <div class="scroll-cinema__meter" aria-hidden="true">
      <span></span>
    </div>
  </div>
</section>

<script>
  const scenes = document.querySelectorAll('[data-scroll-cinema]');

  scenes.forEach((scene) => {
    const canvas = scene.querySelector('[data-cinema-canvas]');
    const fallback = scene.querySelector('[data-cinema-fallback]');
    const ctx = canvas.getContext('2d', { alpha: true, desynchronized: true });
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const finePointerQuery = window.matchMedia('(pointer: fine) and (min-width: 900px)');
    const orbitNodes = Array.from(scene.querySelectorAll('[data-orbit-node]'));
    const frameSets = {
      desktop: { dir: '/frames/desktop', count: 160, warm: 10 },
      tablet: { dir: '/frames/tablet', count: 110, warm: 7 },
      mobile: { dir: '/frames/mobile', count: 72, warm: 4 },
    };
    const fallbackImages = {
      desktop: '/images/orbit-bg-desktop.webp',
      tablet: '/images/orbit-bg-tablet.webp',
      mobile: '/images/orbit-bg-mobile.webp',
    };

    let mode = 'desktop';
    let reduce = reduceQuery.matches;
    let hasFrames = false;
    let frameCount = 1;
    let target = 0;
    let current = 0;
    let raf = 0;
    let lastFrame = -1;
    let images = [];
    let fallbackImage = null;
    let mouseX = 0;
    let mouseY = 0;

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const lerp = (start, end, amount) => start + (end - start) * amount;
    const frameUrl = (set, index) => `${set.dir}/frame-${String(index).padStart(4, '0')}.webp`;

    function getMode() {
      if (window.matchMedia('(orientation: portrait), (max-width: 640px)').matches) return 'mobile';
      if (window.matchMedia('(max-width: 1180px)').matches) return 'tablet';
      return 'desktop';
    }

    function loadImage(src) {
      return new Promise((resolve, reject) => {
        const image = new Image();
        image.decoding = 'async';
        image.onload = () => resolve(image);
        image.onerror = reject;
        image.src = src;
      });
    }

    function sizeCanvas() {
      const dpr = Math.min(window.devicePixelRatio || 1, mode === 'mobile' ? 1.5 : 2);
      const width = Math.max(1, Math.floor(canvas.clientWidth * dpr));
      const height = Math.max(1, Math.floor(canvas.clientHeight * dpr));
      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }
    }

    function drawCover(image) {
      if (!image) return;
      sizeCanvas();
      const scale = Math.max(canvas.width / image.naturalWidth, canvas.height / image.naturalHeight);
      const width = image.naturalWidth * scale;
      const height = image.naturalHeight * scale;
      const progressZoom = reduce ? 1.03 : lerp(1.03, 1.16, current);
      const parallaxX = finePointerQuery.matches && !reduce ? mouseX * 16 * (window.devicePixelRatio || 1) : 0;
      const parallaxY = finePointerQuery.matches && !reduce ? mouseY * 12 * (window.devicePixelRatio || 1) : 0;
      ctx.clearRect(0, 0, canvas.width, canvas.height);
      ctx.save();
      ctx.translate(canvas.width / 2 + parallaxX, canvas.height / 2 + parallaxY);
      ctx.scale(progressZoom, progressZoom);
      ctx.drawImage(image, -width / 2, -height / 2, width, height);
      ctx.restore();
    }

    function nearestLoadedFrame(index) {
      if (images[index]) return { image: images[index], index };
      for (let offset = 1; offset < frameCount; offset += 1) {
        const before = index - offset;
        const after = index + offset;
        if (before >= 0 && images[before]) return { image: images[before], index: before };
        if (after < frameCount && images[after]) return { image: images[after], index: after };
      }
      return { image: fallbackImage, index: -1 };
    }

    function paint() {
      const requestedIndex = hasFrames ? Math.min(frameCount - 1, Math.round(current * (frameCount - 1))) : 0;
      const { image, index } = hasFrames ? nearestLoadedFrame(requestedIndex) : { image: fallbackImage, index: 0 };
      if (image && (index !== lastFrame || !hasFrames)) {
        drawCover(image);
        lastFrame = index;
      }
    }

    function setSceneVars(progress) {
      scene.style.setProperty('--progress', progress.toFixed(4));
      scene.style.setProperty('--scene-scale', lerp(1, 1.08, progress).toFixed(4));
      scene.style.setProperty('--scene-tilt', `${lerp(-.4, .7, progress).toFixed(3)}deg`);
      scene.style.setProperty('--gold-opacity', lerp(.42, .76, progress).toFixed(4));
      scene.style.setProperty('--depth-opacity', lerp(.25, .56, progress).toFixed(4));
      scene.style.setProperty('--mx', mouseX.toFixed(4));
      scene.style.setProperty('--my', mouseY.toFixed(4));
    }

    function updateOrbitNodes(progress) {
      const nodeCount = orbitNodes.length;
      if (!nodeCount) return;

      const viewportWidth = window.innerWidth;
      const viewportHeight = window.innerHeight;
      const radiusX = Math.min(viewportWidth * (mode === 'mobile' ? .38 : .34), 520);
      const radiusY = Math.min(viewportHeight * (mode === 'mobile' ? .28 : .31), 290);
      const rotation = progress * Math.PI * 2;

      orbitNodes.forEach((node, index) => {
        const baseAngle = (index / nodeCount) * Math.PI * 2;
        const angle = baseAngle + rotation;
        const x = Math.cos(angle) * radiusX;
        const y = Math.sin(angle) * radiusY;
        const depth = (Math.sin(angle) + 1) / 2;

        node.style.setProperty('--orbit-x', `${x.toFixed(2)}px`);
        node.style.setProperty('--orbit-y', `${y.toFixed(2)}px`);
        node.style.setProperty('--orbit-scale', lerp(.72, 1.18, depth).toFixed(4));
        node.style.setProperty('--orbit-opacity', lerp(.44, 1, depth).toFixed(4));
        node.style.setProperty('--orbit-blur', `${lerp(1.6, 0, depth).toFixed(2)}px`);
        node.style.setProperty('--orbit-z', String(Math.round(20 + depth * 80)));
      });
    }

    function measure() {
      const rect = scene.getBoundingClientRect();
      const scrollable = Math.max(1, rect.height - window.innerHeight);
      target = reduce ? 0 : clamp(-rect.top / scrollable, 0, 1);
      setSceneVars(target);
      if (!raf) raf = requestAnimationFrame(tick);
    }

    function tick() {
      raf = 0;
      current = reduce ? target : lerp(current, target, mode === 'mobile' ? .18 : .1);
      updateOrbitNodes(current);
      paint();
      if (Math.abs(current - target) > .001) raf = requestAnimationFrame(tick);
    }

    async function discoverAndPreload(nextMode) {
      mode = nextMode;
      hasFrames = false;
      images = [];
      lastFrame = -1;
      fallbackImage = await loadImage(fallbackImages[mode]).catch(() => null);
      fallback?.setAttribute('data-loaded', 'true');
      paint();

      const set = frameSets[mode];
      const first = await loadImage(frameUrl(set, 1)).catch(() => null);
      if (!first) return;
      hasFrames = true;
      frameCount = set.count;
      images[0] = first;
      fallback?.setAttribute('data-hidden', 'true');
      for (let i = 2; i <= set.warm; i += 1) loadImage(frameUrl(set, i)).then((img) => { images[i - 1] = img; paint(); }).catch(() => {});
      window.setTimeout(() => {
        const step = mode === 'mobile' ? 2 : 1;
        for (let i = set.warm + 1; i <= set.count; i += step) {
          loadImage(frameUrl(set, i)).then((img) => { images[i - 1] = img; }).catch(() => { frameCount = Math.min(frameCount, i - 1); });
        }
      }, 600);
    }

    function onPointerMove(event) {
      if (!finePointerQuery.matches || reduce) return;
      mouseX = (event.clientX / window.innerWidth - .5) * 2;
      mouseY = (event.clientY / window.innerHeight - .5) * 2;
      setSceneVars(target);
      if (!raf) raf = requestAnimationFrame(tick);
    }

    updateOrbitNodes(0);
    discoverAndPreload(getMode()).then(measure);
    window.addEventListener('scroll', measure, { passive: true });
    window.addEventListener('resize', () => {
      const nextMode = getMode();
      sizeCanvas();
      if (nextMode !== mode) discoverAndPreload(nextMode).then(measure);
      else measure();
    }, { passive: true });
    window.addEventListener('pointermove', onPointerMove, { passive: true });
    reduceQuery.addEventListener?.('change', (event) => { reduce = event.matches; measure(); });
  });
</script>

<style>
  .scroll-cinema {
    --progress: 0;
    --scene-scale: 1;
    --scene-tilt: 0deg;
    --gold-opacity: .42;
    --depth-opacity: .25;
    --mx: 0;
    --my: 0;
    min-height: 320vh;
    background: #030711;
    color: #fff7df;
  }

  .scroll-cinema__sticky {
    position: sticky;
    top: 0;
    min-height: 100svh;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    place-items: center;
    padding: clamp(92px, 9vw, 132px) clamp(18px, 5vw, 72px) clamp(28px, 5vw, 64px);
    background:
      radial-gradient(circle at 50% 42%, rgba(220, 174, 83, .14), transparent 31%),
      linear-gradient(180deg, #050917 0%, #02040b 100%);
  }

  .scroll-cinema__canvas,
  .scroll-cinema__fallback,
  .scroll-cinema__fallback img,
  .scroll-cinema__stars,
  .scroll-cinema__field,
  .scroll-cinema__gold,
  .scroll-cinema__depth,
  .scroll-cinema__vignette,
  .scroll-cinema__grain,
  .scroll-cinema__orbit {
    position: absolute;
    inset: 0;
  }

  .scroll-cinema__canvas {
    width: 100%;
    height: 100%;
    z-index: -8;
    transform: scale(var(--scene-scale)) rotate(var(--scene-tilt));
  }

  .scroll-cinema__fallback {
    z-index: -9;
    opacity: 1;
    transition: opacity .6s ease;
  }

  .scroll-cinema__fallback[data-hidden="true"] { opacity: 0; }

  .scroll-cinema__fallback img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform: scale(calc(var(--scene-scale) + .02));
    filter: saturate(.9) brightness(.78) contrast(1.05);
  }

  .scroll-cinema__stars {
    z-index: -7;
    opacity: .34;
    background-image:
      radial-gradient(circle, rgba(255,255,255,.8) 0 1px, transparent 1.5px),
      radial-gradient(circle, rgba(232,190,103,.55) 0 1px, transparent 1.4px);
    background-size: 120px 120px, 190px 190px;
    transform: translate3d(calc(var(--mx) * -10px), calc(var(--my) * -8px), 0);
  }

  .scroll-cinema__field {
    z-index: -6;
    background:
      linear-gradient(90deg, rgba(255,255,255,.04) 1px, transparent 1px),
      linear-gradient(0deg, rgba(255,255,255,.03) 1px, transparent 1px);
    background-size: 88px 88px;
    mask-image: radial-gradient(circle at center, #000 0 36%, transparent 72%);
    opacity: calc(.08 + var(--progress) * .11);
  }

  .scroll-cinema__orbit {
    z-index: -5;
    width: min(82vw, 920px);
    height: min(82vw, 920px);
    margin: auto;
    border: 1px solid rgba(232, 191, 111, .18);
    border-radius: 50%;
    transform: rotateX(68deg) rotateZ(calc(var(--progress) * 18deg));
    box-shadow: 0 0 80px rgba(218, 169, 78, .06);
  }

  .scroll-cinema__orbit--tight {
    width: min(58vw, 650px);
    height: min(58vw, 650px);
    border-color: rgba(255,255,255,.11);
    transform: rotateX(70deg) rotateZ(calc(var(--progress) * -24deg));
  }

  .scroll-cinema__gold {
    z-index: -4;
    opacity: var(--gold-opacity);
    background:
      radial-gradient(circle at calc(50% + var(--mx) * 5%) calc(43% + var(--my) * 4%), rgba(236, 181, 75, .34), transparent 20%),
      radial-gradient(circle at 50% 92%, rgba(174, 120, 42, .2), transparent 34%);
    mix-blend-mode: screen;
  }

  .scroll-cinema__depth {
    z-index: -3;
    opacity: var(--depth-opacity);
    background: linear-gradient(180deg, rgba(2,4,11,.1), rgba(2,4,11,.72));
  }

  .scroll-cinema__vignette {
    z-index: 5;
    pointer-events: none;
    background: radial-gradient(circle at center, transparent 0 45%, rgba(1,3,9,.78) 100%);
  }

  .scroll-cinema__grain {
    z-index: 6;
    pointer-events: none;
    opacity: .13;
    background-image: repeating-radial-gradient(circle at 20% 30%, rgba(255,255,255,.22) 0 1px, transparent 1px 4px);
    mix-blend-mode: overlay;
  }

  .scroll-cinema__brand {
    position: absolute;
    z-index: 12;
    left: 50%;
    top: 50%;
    color: rgba(255, 247, 223, .9);
    font-size: clamp(13px, 1.5vw, 18px);
    font-weight: 850;
    letter-spacing: .42em;
    text-decoration: none;
    text-shadow: 0 0 30px rgba(232, 190, 103, .55), 0 18px 60px rgba(0,0,0,.8);
    transform: translate3d(calc(-50% + var(--mx) * -5px), calc(-50% + var(--my) * -4px), 0);
  }

  .scroll-cinema__brand::before {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    width: clamp(140px, 19vw, 240px);
    aspect-ratio: 1;
    border: 1px solid rgba(232, 191, 111, .22);
    border-radius: 999px;
    pointer-events: none;
    transform: translate(-50%, -50%) rotateX(66deg);
    box-shadow: inset 0 0 34px rgba(232, 191, 111, .08), 0 0 70px rgba(232, 191, 111, .08);
  }

  .scroll-cinema__nodes {
    position: absolute;
    z-index: 20;
    inset: 0;
    pointer-events: none;
    perspective: 1100px;
    transform-style: preserve-3d;
  }

  .scroll-cinema__node {
    --orbit-x: 0px;
    --orbit-y: 0px;
    --orbit-scale: 1;
    --orbit-opacity: 1;
    --orbit-blur: 0px;
    --orbit-z: 20;
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: var(--orbit-z);
    display: inline-flex;
    align-items: center;
    gap: 11px;
    min-width: clamp(132px, 15vw, 184px);
    min-height: 56px;
    padding: 12px 15px;
    color: #fff7df;
    text-decoration: none;
    border: 1px solid rgba(255,255,255,.14);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255,255,255,.13), rgba(255,255,255,.045));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.14), 0 20px 70px rgba(0,0,0,.24);
    opacity: var(--orbit-opacity);
    filter: blur(var(--orbit-blur)) brightness(calc(.72 + var(--orbit-opacity) * .38));
    backdrop-filter: blur(22px) saturate(130%);
    pointer-events: auto;
    transform:
      translate(-50%, -50%)
      translate3d(var(--orbit-x), var(--orbit-y), 0)
      scale(var(--orbit-scale));
    transform-origin: center;
    transition: border-color .22s ease, background .22s ease, box-shadow .22s ease, filter .22s ease;
    will-change: transform, opacity, filter;
  }

  .scroll-cinema__node::before {
    content: "";
    position: absolute;
    inset: -1px;
    border-radius: inherit;
    pointer-events: none;
    background: radial-gradient(circle at 20% 0%, rgba(232,194,114,.26), transparent 34%);
    opacity: 0;
    transition: opacity .22s ease;
  }

  .scroll-cinema__node:hover,
  .scroll-cinema__node:focus-visible {
    border-color: rgba(235, 196, 119, .52);
    background: linear-gradient(135deg, rgba(255,255,255,.2), rgba(255,255,255,.075));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.22), 0 28px 86px rgba(218, 169, 78, .2);
    filter: blur(var(--orbit-blur)) brightness(1.14);
    outline: none;
  }

  .scroll-cinema__node:hover::before,
  .scroll-cinema__node:focus-visible::before { opacity: 1; }

  .scroll-cinema__node-index {
    color: rgba(233, 199, 127, .78);
    font-size: 11px;
    font-weight: 800;
    letter-spacing: .16em;
  }

  .scroll-cinema__node-text {
    display: inline-flex;
    flex-direction: column;
    gap: 3px;
    min-width: 0;
  }

  .scroll-cinema__node-title {
    font-size: 15px;
    font-weight: 760;
    letter-spacing: -.01em;
  }

  .scroll-cinema__node-kicker {
    color: rgba(255, 247, 223, .52);
    font-size: 11px;
    letter-spacing: .04em;
    white-space: nowrap;
  }

  .scroll-cinema__node-arrow { color: rgba(233, 199, 127, .8); }

  .scroll-cinema__meter {
    position: absolute;
    z-index: 25;
    right: 24px;
    top: 50%;
    width: 2px;
    height: 120px;
    background: rgba(255,255,255,.12);
    border-radius: 999px;
    overflow: hidden;
  }

  .scroll-cinema__meter span {
    display: block;
    width: 100%;
    height: calc(var(--progress) * 100%);
    background: linear-gradient(#fff7df, #e4b866);
  }

  @media (max-width: 900px) {
    .scroll-cinema { min-height: 250vh; }
    .scroll-cinema__sticky { padding: 72px 16px 28px; }
    .scroll-cinema__brand { font-size: 12px; letter-spacing: .34em; }
    .scroll-cinema__node {
      min-height: 56px;
      padding: 12px 14px;
      border-radius: 18px;
    }
    .scroll-cinema__node-kicker { display: none; }
    .scroll-cinema__meter { display: none; }
    .scroll-cinema__orbit { width: 115vw; height: 115vw; }
  }

  @media (prefers-reduced-motion: reduce) {
    .scroll-cinema { min-height: 100svh; }
    .scroll-cinema__sticky,
    .scroll-cinema__canvas,
    .scroll-cinema__fallback img,
    .scroll-cinema__stars { transform: none; }
    .scroll-cinema__node { transition: none; }
  }
</style>
