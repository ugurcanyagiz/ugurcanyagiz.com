---
import { atlasData } from "../lib/atlasData";

const currentPath = Astro.url.pathname.replace(/\/$/, "") || "/";
const nodes = atlasData;
---

<section class="atlas" data-knowledge-atlas aria-label="UGURCAN interactive knowledge atlas homepage">
  <div class="atlas__sticky">
    <canvas class="atlas__canvas" data-atlas-canvas aria-hidden="true"></canvas>
    <svg class="atlas__sigils" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="atlasGold" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0" stop-color="#fff4c7" stop-opacity=".7" />
          <stop offset=".55" stop-color="#d7a84f" stop-opacity=".3" />
          <stop offset="1" stop-color="#79d7ff" stop-opacity=".16" />
        </linearGradient>
      </defs>
      <path class="atlas__curve atlas__curve--science" d="M173 424 C 304 244, 489 239, 594 392 S 866 570, 1038 355" />
      <path class="atlas__curve atlas__curve--history" d="M128 519 C 316 571, 419 324, 608 397 S 858 502, 1068 279" />
      <path class="atlas__curve atlas__curve--art" d="M195 294 C 347 196, 432 566, 595 402 S 842 202, 1032 491" />
      <path class="atlas__curve atlas__curve--future" d="M108 402 C 332 361, 427 430, 600 400 S 881 342, 1104 403" />
    </svg>

    <div class="atlas__shade" aria-hidden="true"></div>
    <div class="atlas__grain" aria-hidden="true"></div>

    <div class="atlas__core" aria-hidden="true"></div>

    <nav class="atlas__nav" aria-label="Primary sections" data-atlas-nav>
      {nodes.map((node) => (
        <div
          class:list={["atlas__node-shell", `atlas__node-shell--${node.className}`]}
          data-atlas-node-shell
          data-category={node.key}
        >
          <button
            class:list={["atlas__node", `atlas__node--${node.className}`]}
            type="button"
            aria-expanded="false"
            aria-controls={`atlas-submenu-${node.key}`}
            data-atlas-node
            data-category={node.key}
          >
            <span class="atlas__node-index">{node.index}</span>
            <span class="atlas__node-mark" aria-hidden="true"></span>
            <span class="atlas__node-text">
              <span class="atlas__node-title">{node.title}</span>
              <span class="atlas__node-kicker">{node.kicker}</span>
            </span>
          </button>
        </div>
      ))}
    </nav>


    <div
      id="atlas-focus-panel"
      class="atlas__focus-panel"
      data-focus-panel
      aria-live="polite"
      aria-hidden="true"
    >
      <span class="atlas__focus-connector" aria-hidden="true"></span>
      <div class="atlas__focus-chrome">
        <button class="atlas__focus-close" type="button" data-focus-close aria-label="Back to atlas">
          <span aria-hidden="true">←</span> Back to atlas
        </button>

        {nodes.map((node) => (
          <section
            id={`atlas-submenu-${node.key}`}
            class="atlas__focus-section"
            data-focus-section
            data-category={node.key}
            aria-label={`${node.title} subtopics`}
            tabindex="-1"
          >
            <div class="atlas__panel-stage" data-panel-stage>
              <div class="atlas__panel-view atlas__panel-view--subtopics" data-panel-view="subtopics">
                <p class="atlas__focus-kicker">{node.kicker}</p>
                <h2 class="atlas__focus-title">{node.title}</h2>
                <div class="atlas__focus-subitems atlas__panel-scroll">
                  {node.children.map((child, childIndex) => (
                    <button
                      class="atlas__focus-subitem"
                      type="button"
                      style={`--i:${childIndex}`}
                      data-subtopic-button
                      data-category={node.key}
                      data-subtopic={child.title}
                    >
                      <span class="atlas__focus-dot" aria-hidden="true"></span>
                      <span class="atlas__focus-copy">
                        <span class="atlas__focus-subtitle">{child.title}</span>
                        <span class="atlas__focus-description">{child.description}</span>
                      </span>
                    </button>
                  ))}
                </div>
              </div>

              <div class="atlas__panel-view atlas__panel-view--topics" data-panel-view="topics" aria-hidden="true">
                {node.children.map((child) => (
                  <div class="atlas__topic-set" data-topic-set data-subtopic={child.title}>
                    <button class="atlas__topic-back" type="button" data-back-to-subtopics>
                      <span aria-hidden="true">←</span> Back to {node.title}
                    </button>
                    <p class="atlas__topic-breadcrumb">{node.title} / {child.title}</p>
                    <h3 class="atlas__topic-title">{child.title}</h3>
                    <p class="atlas__topic-description">{child.description}</p>
                    <div class="atlas__topic-cards atlas__panel-scroll">
                      {child.topics.map((topic, topicIndex) => (
                        <a
                          class:list={["atlas__topic-card", currentPath === topic.href && "atlas__topic-card--active"]}
                          href={topic.href}
                          style={`--i:${topicIndex}`}
                          aria-current={currentPath === topic.href ? "page" : undefined}
                        >
                          <span class="atlas__focus-dot" aria-hidden="true"></span>
                          <span class="atlas__focus-copy">
                            <span class="atlas__focus-subtitle">{topic.title}</span>
                            <span class="atlas__focus-description">{topic.description}</span>
                          </span>
                        </a>
                      ))}
                    </div>
                  </div>
                ))}
              </div>
            </div>
          </section>
        ))}
      </div>
    </div>

    <p class="atlas__phase" data-atlas-phase>COSMIC KNOWLEDGE FIELD</p>
  </div>
</section>

<script>
  const atlases = document.querySelectorAll('[data-knowledge-atlas]');

  atlases.forEach((atlas) => {
    const canvas = atlas.querySelector('[data-atlas-canvas]');
    const ctx = canvas.getContext('2d', { alpha: true, desynchronized: true });
    const nodeShells = Array.from(atlas.querySelectorAll('[data-atlas-node-shell]'));
    const nodeButtons = Array.from(atlas.querySelectorAll('[data-atlas-node]'));
    const focusPanel = atlas.querySelector('[data-focus-panel]');
    const focusClose = atlas.querySelector('[data-focus-close]');
    const focusSections = Array.from(atlas.querySelectorAll('[data-focus-section]'));
    const subtopicButtons = Array.from(atlas.querySelectorAll('[data-subtopic-button]'));
    const backToSubtopicsButtons = Array.from(atlas.querySelectorAll('[data-back-to-subtopics]'));
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    let width = 1;
    let height = 1;
    let dpr = 1;
    let raf = 0;
    let reduce = reduceQuery.matches;

    const motion = () => (reduce ? .38 : 1);
    let particles = [];
    let inputRotationTarget = 0;
    let inputRotationCurrent = 0;
    let virtualPhaseTarget = .18;
    let virtualPhaseCurrent = .18;
    let autoRotation = 0;
    let lastTime = performance.now();
    let lastTouchY = 0;
    let touchStartedOnLink = false;
    let touchStartedOnPanelButton = false;
    let touchStartedInSubmenu = false;
    let activeCategory = null;
    let activeSubtopic = null;
    let frozenNavRotation = 0;

    atlas.style.setProperty('--focus-x', '0');
    atlas.style.setProperty('--focus-y', '0');
    atlas.style.setProperty('--focus-scale', '1');

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const lerp = (a, b, t) => a + (b - a) * t;
    function wake() {
      if (!raf) raf = requestAnimationFrame(draw);
    }

    function seedParticles() {
      const count = window.innerWidth < 700 ? 86 : window.innerWidth < 1100 ? 130 : 180;
      particles = Array.from({ length: count }, (_, i) => ({
        angle: (i * 2.399963 + (i % 7) * .17) % (Math.PI * 2),
        radius: .12 + ((i * 37) % 100) / 100 * .78,
        size: .45 + ((i * 19) % 100) / 100 * 1.75,
        speed: .12 + ((i * 13) % 100) / 100 * .42,
        tone: i % 5,
      }));
    }

    function sizeCanvas() {
      dpr = Math.min(window.devicePixelRatio || 1, window.innerWidth < 700 ? 1.45 : 2);
      const rect = canvas.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width * dpr));
      height = Math.max(1, Math.floor(rect.height * dpr));
      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }
    }

    function drawOrbitalRing(cx, cy, rx, ry, rotation, alpha, color) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.scale(1, ry / rx);
      ctx.beginPath();
      ctx.arc(0, 0, rx, 0, Math.PI * 2);
      ctx.strokeStyle = color;
      ctx.globalAlpha = alpha;
      ctx.lineWidth = Math.max(1, dpr);
      ctx.stroke();
      ctx.restore();
    }

    function draw(now = performance.now()) {
      raf = 0;
      const isMobile = window.innerWidth < 700;
      const dt = Math.min(50, now - lastTime) / 1000;
      lastTime = now;

      autoRotation += dt * .045 * motion();

      inputRotationCurrent = lerp(inputRotationCurrent, inputRotationTarget, isMobile ? .18 : .11);
      virtualPhaseCurrent = lerp(virtualPhaseCurrent, virtualPhaseTarget, isMobile ? .12 : .08);

      const backgroundRotation = autoRotation + inputRotationCurrent;
      const navRotation = activeCategory ? frozenNavRotation : inputRotationCurrent;
      const phase = virtualPhaseCurrent + autoRotation * .08;
      const displayPhase = virtualPhaseCurrent;
      const cycle = phase * Math.PI * 2;

      const scienceGlow = clamp(.45 + .25 * Math.sin(cycle + 0), 0, 1);
      const historyGlow = clamp(.42 + .22 * Math.sin(cycle + Math.PI * .5), 0, 1);
      const artGlow = clamp(.46 + .24 * Math.sin(cycle + Math.PI), 0, 1);
      const futureGlow = clamp(.44 + .23 * Math.sin(cycle + Math.PI * 1.5), 0, 1);

      atlas.style.setProperty('--science-glow', scienceGlow.toFixed(4));
      atlas.style.setProperty('--history-glow', historyGlow.toFixed(4));
      atlas.style.setProperty('--art-glow', artGlow.toFixed(4));
      atlas.style.setProperty('--future-glow', futureGlow.toFixed(4));
      atlas.style.setProperty('--scroll-rotation', (backgroundRotation * 180 / Math.PI).toFixed(4));

      const cx = width * .5;
      const cy = height * .5;
      const min = Math.min(width, height);
      const science = scienceGlow;
      const history = historyGlow;
      const art = artGlow;
      const future = futureGlow;

      ctx.clearRect(0, 0, width, height);
      const bg = ctx.createRadialGradient(cx, cy, min * .04, cx, cy, min * .86);
      bg.addColorStop(0, `rgba(35, 29, 18, ${.78 + future * .1})`);
      bg.addColorStop(.28, '#07111f');
      bg.addColorStop(.68, '#030711');
      bg.addColorStop(1, '#01030a');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      ctx.save();
      ctx.globalAlpha = .08 + future * .08;
      ctx.strokeStyle = '#a9c8dd';
      ctx.lineWidth = 1 * dpr;
      const grid = 72 * dpr;
      for (let x = (cx % grid); x < width; x += grid) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(lerp(x, cx, .08), height); ctx.stroke(); }
      for (let y = (cy % grid); y < height; y += grid) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(width, lerp(y, cy, .08)); ctx.stroke(); }
      ctx.restore();

      particles.forEach((p) => {
        const layerPull = lerp(.78, 1.08, science);
        const a = p.angle + backgroundRotation * p.speed + cycle * .18 * (p.tone % 2 ? 1.7 : -1.25);
        const orbit = p.radius * min * .58 * layerPull;
        const x = cx + Math.cos(a) * orbit * (1 + history * .18);
        const y = cy + Math.sin(a) * orbit * (.48 + art * .12);
        const alpha = .14 + science * .36 + future * .18;
        ctx.beginPath();
        ctx.fillStyle = p.tone === 0 ? `rgba(235, 187, 91, ${alpha})` : `rgba(213, 231, 244, ${alpha * .72})`;
        ctx.arc(x, y, p.size * dpr * (1 + future * .45), 0, Math.PI * 2);
        ctx.fill();
      });

      for (let i = 0; i < 6; i += 1) {
        drawOrbitalRing(cx, cy, min * (.19 + i * .082 + future * .018), min * (.055 + i * .024 + history * .02), backgroundRotation * (.18 + i * .03) + cycle * .08 * i, .11 + i * .018 + history * .05, i % 2 ? 'rgba(240,198,111,.88)' : 'rgba(166,213,238,.62)');
      }

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(backgroundRotation * .24 + cycle * .12);
      for (let i = 0; i < 18; i += 1) {
        const a = i / 18 * Math.PI * 2;
        const r = min * (.15 + Math.sin(i * 1.7 + backgroundRotation) * .012 + art * .045);
        ctx.beginPath();
        ctx.moveTo(Math.cos(a) * r * .42, Math.sin(a) * r * .42);
        ctx.quadraticCurveTo(Math.cos(a + .55) * r, Math.sin(a + .55) * r, Math.cos(a + 1.15) * r * .72, Math.sin(a + 1.15) * r * .72);
        ctx.strokeStyle = `rgba(237, 202, 128, ${art * .18 + future * .08})`;
        ctx.lineWidth = (1.2 + art * 1.2) * dpr;
        ctx.stroke();
      }
      ctx.restore();

      const core = ctx.createRadialGradient(cx - min * .035, cy - min * .045, 0, cx, cy, min * (.145 + future * .018));
      core.addColorStop(0, 'rgba(255,247,213,.95)');
      core.addColorStop(.18, 'rgba(234,186,83,.8)');
      core.addColorStop(.48, 'rgba(71,105,130,.34)');
      core.addColorStop(1, 'rgba(2,6,14,0)');
      ctx.fillStyle = core;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.15 + future * .02), 0, Math.PI * 2);
      ctx.fill();

      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      ctx.strokeStyle = `rgba(255, 224, 146, ${.28 + future * .34})`;
      ctx.lineWidth = (1.4 + future * 1.6) * dpr;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.05 + future * .08), backgroundRotation, backgroundRotation + Math.PI * (1.15 + future));
      ctx.stroke();
      ctx.restore();

      updateNodes(displayPhase, navRotation);

      raf = requestAnimationFrame(draw);
    }

    function updateNodes(p, scrollRotation = 0) {
      const radiusX = Math.min(window.innerWidth * (window.innerWidth < 700 ? .36 : .34), 520);
      const radiusY = Math.min(window.innerHeight * (window.innerWidth < 700 ? .33 : .28), 265);
      nodeShells.forEach((node, index) => {
        const angle = index / nodeShells.length * Math.PI * 2 - Math.PI / 2 + scrollRotation + p * .45;
        const depth = (Math.sin(angle) + 1) / 2;
        node.style.setProperty('--x', `${Math.cos(angle) * radiusX}px`);
        node.style.setProperty('--y', `${Math.sin(angle) * radiusY}px`);
        node.style.setProperty('--s', lerp(.78, 1.12, depth).toFixed(3));
        node.style.setProperty('--o', lerp(.56, 1, depth).toFixed(3));
        node.style.setProperty('--z', String(Math.round(10 + depth * 90)));
      });
    }

    function applyVirtualDelta(delta, rotationScale, phaseScale) {
      const scale = motion();
      if (!activeCategory) inputRotationTarget += delta * rotationScale * scale;
      virtualPhaseTarget += delta * phaseScale * scale;
      wake();
    }

    function isInsideScrollableSubmenu(target) {
      return target instanceof Element && Boolean(target.closest('.atlas__focus-panel, .atlas__focus-subitems'));
    }

    function onWheel(event) {
      if (atlas.dataset.mode === 'focus' && isInsideScrollableSubmenu(event.target)) {
        return;
      }

      event.preventDefault();
      const normalized = clamp(event.deltaY, -80, 80);
      applyVirtualDelta(normalized, .006, .00055);
    }

    function onTouchStart(event) {
      touchStartedOnLink = event.target instanceof Element && Boolean(event.target.closest('a'));
      touchStartedOnPanelButton = event.target instanceof Element && Boolean(event.target.closest('[data-atlas-node], [data-subtopic-button], [data-back-to-subtopics], [data-focus-close]'));
      touchStartedInSubmenu = isInsideScrollableSubmenu(event.target);

      if (touchStartedOnLink || touchStartedOnPanelButton || touchStartedInSubmenu || !event.touches.length) return;
      lastTouchY = event.touches[0].clientY;
    }

    function onTouchMove(event) {
      if (touchStartedOnLink || touchStartedOnPanelButton || touchStartedInSubmenu || !event.touches.length) return;
      const y = event.touches[0].clientY;
      const delta = lastTouchY - y;
      lastTouchY = y;
      applyVirtualDelta(delta, .008, .00075);
      event.preventDefault();
    }

    function getFocusScale() {
      if (window.innerWidth < 700) return reduce ? 1.02 : 1.04;
      if (window.innerWidth < 1024) return 1.24;
      return 1.42;
    }

    function setFocusCamera(shell) {
      if (!shell) {
        atlas.style.setProperty('--focus-x', '0');
        atlas.style.setProperty('--focus-y', '0');
        atlas.style.setProperty('--focus-scale', String(getFocusScale()));
        return;
      }

      const rect = shell.getBoundingClientRect();
      const nodeCenterX = rect.left + rect.width / 2;
      const nodeCenterY = rect.top + rect.height / 2;
      const targetX = window.innerWidth < 700 ? window.innerWidth * .5 : window.innerWidth * .42;
      const targetY = window.innerWidth < 700 ? window.innerHeight * .42 : window.innerHeight * .5;
      atlas.style.setProperty('--focus-x', (nodeCenterX - targetX).toFixed(2));
      atlas.style.setProperty('--focus-y', (nodeCenterY - targetY).toFixed(2));
      atlas.style.setProperty('--focus-scale', String(getFocusScale()));
    }

    function closeSubmenu({ restoreFocus = true } = {}) {
      const previousButton = activeCategory ? nodeButtons.find((button) => button.dataset.category === activeCategory) : null;
      activeCategory = null;
      activeSubtopic = null;
      delete atlas.dataset.mode;
      delete atlas.dataset.activeCategory;
      atlas.style.setProperty('--focus-x', '0');
      atlas.style.setProperty('--focus-y', '0');
      atlas.style.setProperty('--focus-scale', '1');
      focusPanel?.setAttribute('aria-hidden', 'true');
      nodeShells.forEach((shell) => {
        delete shell.dataset.active;
      });
      focusSections.forEach((section) => {
        delete section.dataset.active;
        delete section.dataset.panelLevel;
        section.querySelectorAll('[data-panel-view="topics"]').forEach((view) => view.setAttribute('aria-hidden', 'true'));
        section.querySelectorAll('[data-topic-set]').forEach((set) => delete set.dataset.active);
      });
      nodeButtons.forEach((button) => {
        button.setAttribute('aria-expanded', 'false');
      });
      if (restoreFocus && previousButton) previousButton.focus({ preventScroll: true });
      wake();
    }

    function resetPanel(section) {
      if (!section) return;
      activeSubtopic = null;
      section.dataset.panelLevel = 'subtopics';
      section.querySelector('[data-panel-view="subtopics"]')?.removeAttribute('aria-hidden');
      section.querySelector('[data-panel-view="topics"]')?.setAttribute('aria-hidden', 'true');
      section.querySelectorAll('[data-topic-set]').forEach((set) => delete set.dataset.active);
    }

    function openTopicPanel(button) {
      if (!activeCategory || !button) return;
      const section = focusSections.find((item) => item.dataset.category === activeCategory);
      const subtopic = button.dataset.subtopic;
      if (!section || !subtopic) return;
      activeSubtopic = subtopic;
      section.dataset.panelLevel = 'topics';
      const subtopicsView = section.querySelector('[data-panel-view="subtopics"]');
      const topicsView = section.querySelector('[data-panel-view="topics"]');
      subtopicsView?.setAttribute('aria-hidden', 'true');
      topicsView?.removeAttribute('aria-hidden');
      section.querySelectorAll('[data-topic-set]').forEach((set) => {
        if (set.dataset.subtopic === subtopic) set.dataset.active = 'true';
        else delete set.dataset.active;
      });
      window.setTimeout(() => {
        const activeSet = section.querySelector('[data-topic-set][data-active="true"]');
        const backButton = activeSet?.querySelector('[data-back-to-subtopics]');
        backButton?.focus({ preventScroll: true });
      }, reduce ? 0 : 340);
    }

    function backToSubtopics({ restoreFocus = true } = {}) {
      if (!activeCategory) return;
      const section = focusSections.find((item) => item.dataset.category === activeCategory);
      const previousSubtopic = activeSubtopic;
      resetPanel(section);
      if (restoreFocus && section) {
        window.setTimeout(() => {
          const target = Array.from(section.querySelectorAll('[data-subtopic-button]')).find((button) => button.dataset.subtopic === previousSubtopic);
          target?.focus({ preventScroll: true });
        }, reduce ? 0 : 340);
      }
    }

    function openSubmenu(category) {
      activeCategory = category;
      frozenNavRotation = inputRotationCurrent;
      atlas.dataset.mode = 'focus';
      atlas.dataset.activeCategory = category;
      const activeShell = nodeShells.find((shell) => shell.dataset.category === category);
      nodeShells.forEach((shell) => {
        if (shell.dataset.category === category) shell.dataset.active = 'true';
        else delete shell.dataset.active;
      });
      focusSections.forEach((section) => {
        if (section.dataset.category === category) {
          section.dataset.active = 'true';
          resetPanel(section);
        } else {
          delete section.dataset.active;
          delete section.dataset.panelLevel;
        }
      });
      nodeButtons.forEach((button) => {
        button.setAttribute('aria-expanded', String(button.dataset.category === category));
      });
      focusPanel?.setAttribute('aria-hidden', 'false');
      requestAnimationFrame(() => {
        setFocusCamera(activeShell);
        const activeSection = focusSections.find((section) => section.dataset.category === category);
        const firstSubtopic = activeSection?.querySelector('[data-subtopic-button]');
        (firstSubtopic || activeSection)?.focus({ preventScroll: true });
      });
      wake();
    }

    function onNodeClick(event) {
      event.stopPropagation();
      const category = event.currentTarget.dataset.category;
      if (!category) return;
      if (activeCategory === category) closeSubmenu();
      else openSubmenu(category);
    }

    function onDocumentClick(event) {
      if (!activeCategory) return;
      const activeShell = atlas.querySelector('.atlas__node-shell[data-active="true"]');
      if (focusPanel?.contains(event.target)) return;
      if (activeShell && activeShell.contains(event.target)) return;
      closeSubmenu({ restoreFocus: false });
    }

    function onKeyDown(event) {
      if (event.key === 'Escape' && activeCategory) {
        if (activeSubtopic) backToSubtopics();
        else closeSubmenu();
      }
    }

    function onResize() {
      sizeCanvas();
      seedParticles();
      if (activeCategory) setFocusCamera(nodeShells.find((shell) => shell.dataset.category === activeCategory));
      wake();
    }

    sizeCanvas();
    seedParticles();
    updateNodes(.18);
    wake();

    atlas.addEventListener('wheel', onWheel, { passive: false });
    atlas.addEventListener('touchstart', onTouchStart, { passive: true });
    atlas.addEventListener('touchmove', onTouchMove, { passive: false });
    nodeButtons.forEach((button) => button.addEventListener('click', onNodeClick));
    subtopicButtons.forEach((button) => button.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      openTopicPanel(event.currentTarget);
    }));
    backToSubtopicsButtons.forEach((button) => button.addEventListener('click', (event) => {
      event.preventDefault();
      event.stopPropagation();
      backToSubtopics();
    }));
    document.addEventListener('click', onDocumentClick);
    window.addEventListener('keydown', onKeyDown);
    window.addEventListener('resize', onResize, { passive: true });
    focusClose?.addEventListener('click', () => closeSubmenu());
    reduceQuery.addEventListener?.('change', (event) => {
      reduce = event.matches;
      lastTime = performance.now();
      wake();
    });
  });
</script>

<style>
  .atlas {
    --science-glow: .45;
    --history-glow: .42;
    --art-glow: .46;
    --future-glow: .44;
    --scroll-rotation: 0;
    min-height: 100svh;
    height: 100svh;
    overflow: hidden;
    overscroll-behavior: none;
    touch-action: none;
