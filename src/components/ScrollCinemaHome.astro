---
import SectionNavButton from "./SectionNavButton.astro";
import { NAV_ITEMS } from "../lib/navigation";

const phases = [
  { key: "intro", eyebrow: "Cosmic Knowledge Atlas", title: "A cinematic archive of ideas.", text: "Science, memory, art, and the future — held in orbit.", accent: "Enter", href: "/me" },
  ...NAV_ITEMS.map((item) => ({
    key: item.sectionId,
    eyebrow: `${item.index} / ${item.label}`,
    title: item.label === "JLOG" ? "Field notes from the orbit." : item.subtitle,
    text: item.description,
    accent: item.label === "JLOG" ? "Open JLOG" : `Explore ${item.label}`,
    href: item.href,
  })),
];

const navItems = NAV_ITEMS;
const scrollHeight = 100 + (phases.length - 1) * 88;
---

<section class="cinema-atlas" data-cinema-atlas aria-label="Scroll reactive Cosmic Knowledge Atlas homepage" style={`--atlas-scroll-height:${scrollHeight}svh`}>
  <div class="cinema-atlas__sticky">
    <div class="cinema-atlas__scene atlas-scene" aria-hidden="true">
      <canvas class="cinema-atlas__canvas" data-atlas-canvas aria-hidden="true"></canvas>
      <div class="cinema-atlas__stars" aria-hidden="true"></div>
      <div class="cinema-atlas__aurora" aria-hidden="true"></div>
      <div class="cinema-atlas__vignette" aria-hidden="true"></div>
      <div class="cinema-atlas__map" aria-hidden="true">
      <span class="cinema-atlas__arc cinema-atlas__arc--one"></span>
      <span class="cinema-atlas__arc cinema-atlas__arc--two"></span>
      <span class="cinema-atlas__arc cinema-atlas__arc--three"></span>
      <span class="cinema-atlas__axis"></span>
      <span class="cinema-atlas__scanline cinema-atlas__scanline--one"></span>
      <span class="cinema-atlas__scanline cinema-atlas__scanline--two"></span>
    </div>

    <div class="cinema-atlas__camera">
      <div class="cinema-atlas__object" aria-hidden="true">
        <span class="cinema-atlas__orb cinema-atlas__orb--core"></span>
        <span class="cinema-atlas__orb cinema-atlas__orb--halo"></span>
        <span class="cinema-atlas__orb cinema-atlas__orb--meridian"></span>
        <span class="cinema-atlas__orb cinema-atlas__orb--aperture"></span>
        <span class="cinema-atlas__orb cinema-atlas__orb--crown"></span>
        <span class="cinema-atlas__needle cinema-atlas__needle--one"></span>
        <span class="cinema-atlas__needle cinema-atlas__needle--two"></span>
        <span class="cinema-atlas__glyph cinema-atlas__glyph--north">ATLAS</span>
        <span class="cinema-atlas__glyph cinema-atlas__glyph--south">SCROLL FIELD</span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--a"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--b"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--c"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--d"></span>
      </div>
    </div>

    </div>

    <div class="cinema-atlas__content-layer content-layer" aria-live="polite">
      <div class="cinema-atlas__copy">
        {phases.map((phase, index) => (
          <article
            class="cinema-atlas__phase"
            data-phase={index}
            data-phase-key={phase.key}
            data-active={index === 0 ? true : undefined}
            aria-hidden={index === 0 ? "false" : "true"}
          >
            <p class="cinema-atlas__eyebrow">{phase.eyebrow}</p>
            <h1 class="cinema-atlas__title">{phase.title}</h1>
            <p class="cinema-atlas__text">{phase.text}</p>
            <a class="cinema-atlas__phase-link" href={phase.href}>{phase.accent}</a>
          </article>
        ))}
      </div>
    </div>

    <div class="cinema-atlas__ui-layer ui-layer">
      <nav class="cinema-atlas__nav" aria-label="Atlas navigation">
        {navItems.map((item) => (
          <SectionNavButton
            index={item.index}
            label={item.label}
            href={item.href}
            sectionId={item.sectionId}
            subtitle={item.subtitle}
            className={`section-nav-button--${item.sectionId}`}
          />
        ))}
      </nav>

      <div class="cinema-atlas__hud" aria-hidden="true">
        <span data-active-label>Intro</span>
        <span class="cinema-atlas__progress"><i data-progress-bar></i></span>
        <span>One gesture · one scene</span>
      </div>
    </div>
  </div>
  <div class="cinema-atlas__scroll-space" aria-hidden="true"></div>
</section>

<script>
  const roots = document.querySelectorAll('[data-cinema-atlas]');

  roots.forEach((root) => {
    const canvas = root.querySelector('[data-atlas-canvas]');
    const ctx = canvas?.getContext('2d', { alpha: true, desynchronized: true });
    const phases = Array.from(root.querySelectorAll('[data-phase]'));
    const navButtons = Array.from(root.querySelectorAll('[data-section-nav-button]'));
    const label = root.querySelector('[data-active-label]');
    const bar = root.querySelector('[data-progress-bar]');
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const phaseNames = ['Intro', 'Science', 'History', 'Art', 'Future', 'JLOG'];
    const accents = [
      [239, 202, 128],
      [121, 215, 255],
      [221, 169, 101],
      [237, 141, 191],
      [139, 255, 214],
      [255, 247, 223],
    ];
    const clamp = (n, min, max) => Math.max(min, Math.min(max, n));
    const lerp = (a, b, t) => a + (b - a) * t;
    let progress = 0;
    let target = 0;
    let raf = 0;
    let width = 1;
    let height = 1;
    let dpr = 1;
    let stars = [];
    let currentScene = 0;
    let sceneLocked = false;
    let unlockTimer = 0;
    let wheelIdleTimer = 0;
    let wheelDelta = 0;
    let wheelGestureTriggered = false;
    let touchStartX = 0;
    let touchStartY = 0;
    let touchTracking = false;

    const SCENE_TRANSITION_MS = 760;
    const WHEEL_IDLE_MS = 180;
    const WHEEL_THRESHOLD = 24;
    const SWIPE_THRESHOLD = 44;

    function sceneScrollTop(index) {
      const rect = root.getBoundingClientRect();
      const rootTop = window.scrollY + rect.top;
      const max = Math.max(0, root.offsetHeight - window.innerHeight);
      const sceneProgress = phases.length > 1 ? index / (phases.length - 1) : 0;
      return rootTop + max * sceneProgress;
    }

    function goToScene(index) {
      if (reduceQuery.matches || sceneLocked) return false;
      const nextScene = clamp(index, 0, phases.length - 1);
      if (nextScene === currentScene) return false;

      currentScene = nextScene;
      sceneLocked = true;
      window.clearTimeout(unlockTimer);
      window.scrollTo({ top: sceneScrollTop(nextScene), behavior: 'smooth' });
      unlockTimer = window.setTimeout(() => {
        sceneLocked = false;
        measure();
      }, SCENE_TRANSITION_MS);
      return true;
    }

    function normalizeWheelDelta(event) {
      if (event.deltaMode === 1) return event.deltaY * 16;
      if (event.deltaMode === 2) return event.deltaY * window.innerHeight;
      return event.deltaY;
    }

    function resetWheelGesture() {
      wheelDelta = 0;
      wheelGestureTriggered = false;
    }

    function onWheel(event) {
      if (reduceQuery.matches || Math.abs(event.deltaX) > Math.abs(event.deltaY)) return;
      event.preventDefault();

      window.clearTimeout(wheelIdleTimer);
      wheelIdleTimer = window.setTimeout(resetWheelGesture, WHEEL_IDLE_MS);
      if (wheelGestureTriggered || sceneLocked) return;

      wheelDelta += normalizeWheelDelta(event);
      if (Math.abs(wheelDelta) < WHEEL_THRESHOLD) return;

      wheelGestureTriggered = true;
      goToScene(currentScene + Math.sign(wheelDelta));
    }

    function onTouchStart(event) {
      if (reduceQuery.matches || event.touches.length !== 1) {
        touchTracking = false;
        return;
      }
      touchStartX = event.touches[0].clientX;
      touchStartY = event.touches[0].clientY;
      touchTracking = true;
    }

    function onTouchMove(event) {
      if (!touchTracking || event.touches.length !== 1) return;
      const deltaX = event.touches[0].clientX - touchStartX;
      const deltaY = event.touches[0].clientY - touchStartY;
      if (Math.abs(deltaY) > 10 && Math.abs(deltaY) > Math.abs(deltaX)) event.preventDefault();
    }

    function onTouchEnd(event) {
      if (!touchTracking || event.changedTouches.length !== 1) return;
      touchTracking = false;
      const deltaX = event.changedTouches[0].clientX - touchStartX;
      const deltaY = event.changedTouches[0].clientY - touchStartY;
      if (Math.abs(deltaY) < SWIPE_THRESHOLD || Math.abs(deltaY) <= Math.abs(deltaX)) return;
      event.preventDefault();
      goToScene(currentScene + (deltaY < 0 ? 1 : -1));
    }

    function onKeyDown(event) {
      if (reduceQuery.matches || event.defaultPrevented || event.metaKey || event.ctrlKey || event.altKey) return;
      if (event.target instanceof Element && event.target.closest('a, button, input, select, textarea, [contenteditable="true"]')) return;

      let nextScene = null;
      if (event.key === 'ArrowDown' || event.key === 'PageDown' || (event.key === ' ' && !event.shiftKey)) nextScene = currentScene + 1;
      if (event.key === 'ArrowUp' || event.key === 'PageUp' || (event.key === ' ' && event.shiftKey)) nextScene = currentScene - 1;
      if (event.key === 'Home') nextScene = 0;
      if (event.key === 'End') nextScene = phases.length - 1;
      if (nextScene === null) return;

      event.preventDefault();
      goToScene(nextScene);
    }

    function seed() {
      dpr = Math.min(window.devicePixelRatio || 1, 1.5);
      const rect = canvas.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width * dpr));
      height = Math.max(1, Math.floor(rect.height * dpr));
      canvas.width = width;
      canvas.height = height;
      const count = window.innerWidth < 700 ? 120 : 240;
      stars = Array.from({ length: count }, (_, i) => ({
        x: ((i * 47) % 101) / 100,
        y: ((i * 83) % 97) / 96,
        r: .35 + ((i * 17) % 100) / 95,
        z: .25 + ((i * 29) % 100) / 100,
        drift: i % 2 ? 1 : -1,
      }));
    }

    function measure() {
      const rect = root.getBoundingClientRect();
      const max = root.offsetHeight - window.innerHeight;
      target = max > 0 ? clamp(-rect.top / max, 0, 1) : 0;
      if (!raf) raf = requestAnimationFrame(render);
    }

    function draw(p) {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);
      const cx = width * (.54 + Math.sin(p * Math.PI * 2) * .08);
      const cy = height * (.48 + Math.cos(p * Math.PI * 1.4) * .055);
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.min(width, height) * .75);
      g.addColorStop(0, `rgba(255, 241, 198, ${.20 + p * .10})`);
      g.addColorStop(.22, `rgba(59, 111, 152, ${.26 + Math.sin(p * 9) * .06})`);
      g.addColorStop(.52, `rgba(117, 74, 151, ${.10 + Math.cos(p * 7) * .04})`);
      g.addColorStop(1, 'rgba(1, 3, 10, 0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, width, height);
      stars.forEach((s) => {
        const x = ((s.x + p * s.z * .26 * s.drift + 1) % 1) * width;
        const y = ((s.y + p * s.z * .14) % 1) * height;
        ctx.globalAlpha = .18 + s.z * .55;
        ctx.fillStyle = s.z > .8 ? '#f0ca80' : '#d8efff';
        ctx.beginPath();
        ctx.arc(x, y, s.r * dpr, 0, Math.PI * 2);
        ctx.fill();
        if (s.z > .86) {
          ctx.globalAlpha *= .28;
          ctx.fillRect(x - s.r * dpr * 7, y, s.r * dpr * 14, Math.max(1, .35 * dpr));
        }
      });
      ctx.globalAlpha = .20;
      ctx.strokeStyle = '#bcdff2';
      ctx.lineWidth = dpr;
      for (let i = 0; i < 9; i++) {
        ctx.beginPath();
        ctx.ellipse(cx, cy, width * (.12 + i * .055), height * (.035 + i * .017), p * Math.PI + i * .28, 0, Math.PI * 2);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    function render() {
      raf = 0;
      const reduced = reduceQuery.matches;
      progress = reduced ? target : lerp(progress, target, .09);
      const sceneCount = phases.length;
      const sceneFloat = progress * (sceneCount - 1);
      const active = clamp(Math.round(sceneFloat), 0, sceneCount - 1);
      if (!sceneLocked) currentScene = active;
      const sceneProgress = sceneFloat - Math.floor(sceneFloat);
      const cameraX = Math.sin(progress * Math.PI * 2.1) * 13;
      const cameraY = Math.cos(progress * Math.PI * 1.55) * 8;
      const cameraScale = 1.04 + progress * .46 + Math.sin(progress * Math.PI * 3) * .07;
      root.style.setProperty('--scroll-progress', progress.toFixed(4));
      root.style.setProperty('--scene-progress', sceneProgress.toFixed(4));
      root.style.setProperty('--camera-x', `${cameraX.toFixed(3)}vw`);
      root.style.setProperty('--camera-y', `${cameraY.toFixed(3)}vh`);
      root.style.setProperty('--stars-x', `${(cameraX * -.35).toFixed(3)}vw`);
      root.style.setProperty('--stars-y', `${(cameraY * -.45).toFixed(3)}vh`);
      root.style.setProperty('--map-x', `${(cameraX * -.65).toFixed(3)}vw`);
      root.style.setProperty('--map-y', `${(cameraY * -.55).toFixed(3)}vh`);
      root.style.setProperty('--camera-scale', cameraScale.toFixed(4));
      root.style.setProperty('--orb-rotation', `${(progress * 980).toFixed(2)}deg`);
      root.style.setProperty('--orb-rotation-reverse', `${(progress * -760).toFixed(2)}deg`);
      root.style.setProperty('--orb-rotation-slow', `${(progress * 430).toFixed(2)}deg`);
      root.style.setProperty('--axis-rotation', `${(progress * 42).toFixed(2)}deg`);
      root.style.setProperty('--object-tilt', `${(Math.sin(progress * Math.PI * 2) * 18).toFixed(2)}deg`);
      root.style.setProperty('--lens-x', `${(48 + Math.sin(progress * Math.PI * 2.4) * 18).toFixed(2)}%`);
      root.style.setProperty('--lens-y', `${(46 + Math.cos(progress * Math.PI * 1.8) * 14).toFixed(2)}%`);
      const accent = accents[active] || accents[0];
      root.style.setProperty('--accent-r', String(accent[0]));
      root.style.setProperty('--accent-g', String(accent[1]));
      root.style.setProperty('--accent-b', String(accent[2]));
      root.style.setProperty('--hero-opacity', String(clamp(1 - progress * 1.2, 0, 1).toFixed(4)));
      root.style.setProperty('--background-shift', `${(progress * -18).toFixed(2)}vh`);
      root.dataset.activeScene = String(active);
      phases.forEach((phase, index) => {
        const direction = index < active ? -1 : 1;
        phase.toggleAttribute('data-active', index === active);
        phase.toggleAttribute('aria-hidden', index !== active);
        phase.style.setProperty('--phase-offset', index === active ? '0px' : `${direction * 28}px`);
      });
      navButtons.forEach((button, index) => {
        const isActive = active === index + 1 || (active === 5 && index === 4);
        button.classList.toggle('is-active', isActive);
        if (isActive) {
          button.setAttribute('aria-current', 'location');
        } else {
          button.removeAttribute('aria-current');
        }
      });
      if (label) label.textContent = phaseNames[active] || 'Atlas';
      if (bar) bar.style.transform = `scaleX(${progress})`;
      draw(progress);
      if (Math.abs(progress - target) > .001 && !reduced) raf = requestAnimationFrame(render);
    }

    seed();
    measure();
    root.addEventListener('wheel', onWheel, { passive: false });
    root.addEventListener('touchstart', onTouchStart, { passive: true });
    root.addEventListener('touchmove', onTouchMove, { passive: false });
    root.addEventListener('touchend', onTouchEnd, { passive: false });
    root.addEventListener('touchcancel', () => { touchTracking = false; }, { passive: true });
    window.addEventListener('keydown', onKeyDown);
    window.addEventListener('scroll', measure, { passive: true });
    window.addEventListener('resize', () => { seed(); measure(); }, { passive: true });
    reduceQuery.addEventListener?.('change', measure);
  });
</script>

<style>
  .cinema-atlas {
    --scroll-progress: 0;
    --scene-progress: 0;
    --camera-x: 0vw;
    --camera-y: 0vh;
    --camera-scale: 1;
    --stars-x: 0vw;
    --stars-y: 0vh;
    --map-x: 0vw;
    --map-y: 0vh;
    --accent-r: 239;
    --accent-g: 202;
    --accent-b: 128;
    --object-tilt: 0deg;
    --lens-x: 50%;
    --lens-y: 45%;
    --orb-rotation: 0deg;
    --orb-rotation-reverse: 0deg;
    --orb-rotation-slow: 0deg;
    --axis-rotation: 0deg;
    --hero-opacity: 1;
    --background-shift: 0vh;
    position: relative;
    min-height: var(--atlas-scroll-height, 540svh);
    color: #fff7df;
    background: #01030a;
    overscroll-behavior: none;
    touch-action: pan-x pinch-zoom;
  }

  .cinema-atlas__sticky { position: sticky; top: 0; height: 100svh; overflow: hidden; isolation: isolate; perspective: 1400px; background: radial-gradient(circle at var(--lens-x) var(--lens-y), rgba(var(--accent-r), var(--accent-g), var(--accent-b), .24), transparent 28%), radial-gradient(circle at 76% 18%, rgba(121, 215, 255, .12), transparent 34%), linear-gradient(135deg, #01030a 0%, #07101f 44%, #02040b 100%); contain: layout paint; }
  .cinema-atlas__scroll-space { height: 1px; }
  .cinema-atlas__scene { position: absolute; inset: 0; z-index: 0; pointer-events: none; isolation: isolate; }
  .cinema-atlas__content-layer,
  .cinema-atlas__ui-layer { position: absolute; inset: 0; z-index: 2; isolation: isolate; pointer-events: none; }
  .cinema-atlas__ui-layer { z-index: 3; }
  .cinema-atlas__canvas, .cinema-atlas__stars, .cinema-atlas__aurora, .cinema-atlas__vignette, .cinema-atlas__map { position: absolute; inset: 0; }
  .cinema-atlas__canvas { z-index: -9; width: 100%; height: 100%; transform: translateY(var(--background-shift)) scale(1.08); }
  .cinema-atlas__stars { z-index: -8; opacity: .22; background-image: linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px); background-size: 88px 88px; mask-image: radial-gradient(circle, #000 0 56%, transparent 82%); transform: translate3d(var(--stars-x), var(--stars-y), 0); }
  .cinema-atlas__aurora { z-index: -7; opacity: .82; background: conic-gradient(from var(--orb-rotation) at var(--lens-x) var(--lens-y), transparent 0 18%, rgba(var(--accent-r), var(--accent-g), var(--accent-b), .18), transparent 36% 58%, rgba(121,215,255,.12), transparent 78% 100%); filter: blur(46px) saturate(130%); transform: translate3d(var(--map-x), var(--map-y), 0) scale(1.18); }
  .cinema-atlas__vignette { z-index: 79; pointer-events: none; background: radial-gradient(circle at var(--lens-x) var(--lens-y), transparent 0 24%, rgba(1,3,10,.12) 45%, rgba(1,3,10,.78) 82%, #01030a 100%), linear-gradient(90deg, rgba(1,3,10,.82), transparent 21%, transparent 68%, rgba(1,3,10,.72)), linear-gradient(180deg, rgba(1,3,10,.82), transparent 30%, rgba(1,3,10,.88)); }
  .cinema-atlas__sticky::after { content: ""; position: absolute; inset: 0; z-index: 80; pointer-events: none; background: radial-gradient(circle at 50% 50%, transparent 0 46%, rgba(1,3,10,.42) 72%, rgba(1,3,10,.96)), linear-gradient(180deg, rgba(255,247,223,.04), transparent 18%, transparent 74%, rgba(1,3,10,.86)); }
  .cinema-atlas__sticky::before { content: ""; position: absolute; inset: 0; z-index: 81; opacity: .12; pointer-events: none; mix-blend-mode: overlay; background-image: repeating-radial-gradient(circle at 30% 20%, rgba(255,255,255,.34) 0 1px, transparent 1px 4px); }

  .cinema-atlas__map { z-index: -5; transform: translate3d(var(--map-x), var(--map-y), 0) scale(var(--camera-scale)); }
  .cinema-atlas__arc { position: absolute; left: 50%; top: 50%; width: min(92vw, 1180px); aspect-ratio: 1; border: 1px solid rgba(239,202,128,.17); border-radius: 50%; transform: translate(-50%, -50%) rotateX(67deg) rotateZ(var(--orb-rotation)); box-shadow: 0 0 80px rgba(121,215,255,.08); }
  .cinema-atlas__arc--two { width: min(70vw, 900px); border-color: rgba(121,215,255,.18); transform: translate(-50%, -50%) rotateX(58deg) rotateY(20deg) rotateZ(var(--orb-rotation-reverse)); }
  .cinema-atlas__arc--three { width: min(54vw, 680px); border-style: dashed; border-color: rgba(255,255,255,.16); transform: translate(-50%, -50%) rotateX(72deg) rotateY(-24deg) rotateZ(var(--orb-rotation-slow)); }
  .cinema-atlas__axis { position: absolute; left: 50%; top: 12%; bottom: 12%; width: 1px; background: linear-gradient(transparent, rgba(var(--accent-r), var(--accent-g), var(--accent-b), .44), transparent); transform: rotate(var(--axis-rotation)); transform-origin: 50% 50%; }
  .cinema-atlas__scanline { position: absolute; left: 50%; top: 50%; width: min(104vw, 1320px); height: 1px; background: linear-gradient(90deg, transparent, rgba(var(--accent-r), var(--accent-g), var(--accent-b), .34), transparent); transform: translate(-50%, -50%) rotate(var(--axis-rotation)); box-shadow: 0 0 34px rgba(var(--accent-r), var(--accent-g), var(--accent-b), .14); }
  .cinema-atlas__scanline--two { transform: translate(-50%, -50%) rotate(var(--orb-rotation-slow)); opacity: .5; }

  .cinema-atlas__camera { position: absolute; inset: 0; z-index: 4; display: grid; place-items: center; transform: translate3d(var(--camera-x), var(--camera-y), 0) scale(var(--camera-scale)); transform-style: preserve-3d; will-change: transform; }
  .cinema-atlas__object { position: relative; width: clamp(340px, 48vw, 760px); aspect-ratio: 1; transform: rotate(var(--orb-rotation)) rotateY(var(--object-tilt)); transform-style: preserve-3d; filter: drop-shadow(0 48px 120px rgba(0,0,0,.72)) drop-shadow(0 0 70px rgba(var(--accent-r), var(--accent-g), var(--accent-b), .14)); }
  .cinema-atlas__object::before, .cinema-atlas__object::after { content: ""; position: absolute; inset: 0; border-radius: 50%; border: 1px solid rgba(255,247,223,.12); transform: rotateX(68deg) rotateZ(var(--orb-rotation-slow)); box-shadow: 0 0 120px rgba(var(--accent-r), var(--accent-g), var(--accent-b), .12); }
  .cinema-atlas__object::after { inset: 12%; border-style: dashed; opacity: .55; transform: rotateX(58deg) rotateY(26deg) rotateZ(var(--orb-rotation-reverse)); }
