---
import { atlasData } from "../lib/atlasData";

const phases = [
  { key: "intro", eyebrow: "Cosmic Knowledge Atlas", title: "A personal atlas of science, art, history, and the future.", text: "Enter a cinematic field of ideas — mapped by curiosity, memory, beauty, and orbit.", accent: "Identity", href: "/me" },
  { key: "science", eyebrow: "01 / Science", title: "Where curiosity becomes structure.", text: "Matter, mind, language, life, uncertainty — arranged as signals in a living instrument.", accent: "Observe", href: "/science" },
  { key: "history", eyebrow: "02 / History", title: "Memory behaves like gravity.", text: "Empires, institutions, revolutions, roads, printing presses — old forces bending the present.", accent: "Remember", href: "/history" },
  { key: "art", eyebrow: "03 / Art", title: "Form gives feeling a coordinate system.", text: "Composition, sound, color, architecture, cinema — the human layer of the atlas.", accent: "Feel", href: "/art" },
  { key: "future", eyebrow: "04 / Astrophysics & Future", title: "The horizon is an instrument.", text: "Black holes, intelligence, space economies, longevity, fusion, robots — signals from tomorrow.", accent: "Project", href: "/future" },
  { key: "explore", eyebrow: "05 / Explore", title: "Science. Memory. Art. Orbit.", text: "Navigate the archive through constellations instead of menus. Follow the field that pulls you.", accent: "Navigate", href: "/blog" },
];

const navItems = atlasData.filter((item) => item.href).slice(0, 5);
---

<section class="cinema-atlas" data-cinema-atlas aria-label="Scroll reactive Cosmic Knowledge Atlas homepage">
  <div class="cinema-atlas__sticky">
    <canvas class="cinema-atlas__canvas" data-atlas-canvas aria-hidden="true"></canvas>
    <div class="cinema-atlas__stars" aria-hidden="true"></div>
    <div class="cinema-atlas__map" aria-hidden="true">
      <span class="cinema-atlas__arc cinema-atlas__arc--one"></span>
      <span class="cinema-atlas__arc cinema-atlas__arc--two"></span>
      <span class="cinema-atlas__arc cinema-atlas__arc--three"></span>
      <span class="cinema-atlas__axis"></span>
    </div>

    <div class="cinema-atlas__camera">
      <div class="cinema-atlas__object" aria-hidden="true">
        <span class="cinema-atlas__orb cinema-atlas__orb--core"></span>
        <span class="cinema-atlas__orb cinema-atlas__orb--halo"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--a"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--b"></span>
        <span class="cinema-atlas__satellite cinema-atlas__satellite--c"></span>
      </div>
    </div>

    <div class="cinema-atlas__copy" aria-live="polite">
      {phases.map((phase, index) => (
        <article class="cinema-atlas__phase" data-phase={index} data-phase-key={phase.key}>
          <p class="cinema-atlas__eyebrow">{phase.eyebrow}</p>
          <h1 class="cinema-atlas__title">{phase.title}</h1>
          <p class="cinema-atlas__text">{phase.text}</p>
          <a class="cinema-atlas__phase-link" href={phase.href}>{phase.accent}</a>
        </article>
      ))}
    </div>

    <nav class="cinema-atlas__nav" aria-label="Atlas navigation">
      {navItems.map((item) => (
        <a class={`cinema-atlas__nav-link cinema-atlas__nav-link--${item.className}`} href={item.href}>
          <span>{item.index}</span>{item.title}
        </a>
      ))}
    </nav>

    <div class="cinema-atlas__hud" aria-hidden="true">
      <span data-active-label>Intro</span>
      <span class="cinema-atlas__progress"><i data-progress-bar></i></span>
      <span>Scroll to steer</span>
    </div>
  </div>
  <div class="cinema-atlas__scroll-space" aria-hidden="true"></div>
</section>

<script>
  const roots = document.querySelectorAll('[data-cinema-atlas]');

  roots.forEach((root) => {
    const canvas = root.querySelector('[data-atlas-canvas]');
    const ctx = canvas?.getContext('2d', { alpha: true, desynchronized: true });
    const phases = Array.from(root.querySelectorAll('[data-phase]'));
    const label = root.querySelector('[data-active-label]');
    const bar = root.querySelector('[data-progress-bar]');
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');
    const phaseNames = ['Intro', 'Science', 'History', 'Art', 'Future', 'Explore'];
    const clamp = (n, min, max) => Math.max(min, Math.min(max, n));
    const lerp = (a, b, t) => a + (b - a) * t;
    let progress = 0;
    let target = 0;
    let raf = 0;
    let width = 1;
    let height = 1;
    let dpr = 1;
    let stars = [];

    function seed() {
      dpr = Math.min(window.devicePixelRatio || 1, 2);
      const rect = canvas.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width * dpr));
      height = Math.max(1, Math.floor(rect.height * dpr));
      canvas.width = width;
      canvas.height = height;
      const count = window.innerWidth < 700 ? 90 : 170;
      stars = Array.from({ length: count }, (_, i) => ({
        x: ((i * 47) % 101) / 100,
        y: ((i * 83) % 97) / 96,
        r: .35 + ((i * 17) % 100) / 95,
        z: .25 + ((i * 29) % 100) / 100,
      }));
    }

    function measure() {
      const rect = root.getBoundingClientRect();
      const max = root.offsetHeight - window.innerHeight;
      target = max > 0 ? clamp(-rect.top / max, 0, 1) : 0;
      if (!raf) raf = requestAnimationFrame(render);
    }

    function draw(p) {
      if (!ctx) return;
      ctx.clearRect(0, 0, width, height);
      const cx = width * (.5 + (p - .5) * .08);
      const cy = height * (.48 + Math.sin(p * Math.PI * 2) * .035);
      const g = ctx.createRadialGradient(cx, cy, 0, cx, cy, Math.min(width, height) * .75);
      g.addColorStop(0, `rgba(239, 202, 128, ${.16 + p * .08})`);
      g.addColorStop(.25, `rgba(59, 111, 152, ${.18 + Math.sin(p * 9) * .04})`);
      g.addColorStop(1, 'rgba(1, 3, 10, 0)');
      ctx.fillStyle = g;
      ctx.fillRect(0, 0, width, height);
      stars.forEach((s) => {
        const x = ((s.x + p * s.z * .16) % 1) * width;
        const y = ((s.y + p * s.z * .08) % 1) * height;
        ctx.globalAlpha = .18 + s.z * .55;
        ctx.fillStyle = s.z > .8 ? '#f0ca80' : '#d8efff';
        ctx.beginPath();
        ctx.arc(x, y, s.r * dpr, 0, Math.PI * 2);
        ctx.fill();
      });
      ctx.globalAlpha = .16;
      ctx.strokeStyle = '#bcdff2';
      ctx.lineWidth = dpr;
      for (let i = 0; i < 9; i++) {
        ctx.beginPath();
        ctx.ellipse(cx, cy, width * (.12 + i * .055), height * (.035 + i * .017), p * Math.PI + i * .28, 0, Math.PI * 2);
        ctx.stroke();
      }
      ctx.globalAlpha = 1;
    }

    function render() {
      raf = 0;
      const reduced = reduceQuery.matches;
      progress = reduced ? target : lerp(progress, target, .09);
      const sceneCount = phases.length;
      const sceneFloat = progress * (sceneCount - 1);
      const active = clamp(Math.round(sceneFloat), 0, sceneCount - 1);
      const sceneProgress = sceneFloat - Math.floor(sceneFloat);
      const cameraX = Math.sin(progress * Math.PI * 2) * 7;
      const cameraY = Math.cos(progress * Math.PI * 1.7) * 4;
      const cameraScale = 1 + progress * .28 + Math.sin(progress * Math.PI * 3) * .045;
      root.style.setProperty('--scroll-progress', progress.toFixed(4));
      root.style.setProperty('--scene-progress', sceneProgress.toFixed(4));
      root.style.setProperty('--camera-x', `${cameraX.toFixed(3)}vw`);
      root.style.setProperty('--camera-y', `${cameraY.toFixed(3)}vh`);
      root.style.setProperty('--camera-scale', cameraScale.toFixed(4));
      root.style.setProperty('--orb-rotation', `${(progress * 980).toFixed(2)}deg`);
      root.style.setProperty('--orb-rotation-reverse', `${(progress * -760).toFixed(2)}deg`);
      root.style.setProperty('--orb-rotation-slow', `${(progress * 430).toFixed(2)}deg`);
      root.style.setProperty('--axis-rotation', `${(progress * 42).toFixed(2)}deg`);
      root.style.setProperty('--hero-opacity', String(clamp(1 - progress * 1.2, 0, 1).toFixed(4)));
      root.style.setProperty('--background-shift', `${(progress * -18).toFixed(2)}vh`);
      root.style.setProperty('--text-depth', `${((sceneProgress - .5) * 46).toFixed(2)}px`);
      root.dataset.activeScene = String(active);
      phases.forEach((phase, index) => phase.toggleAttribute('data-active', index === active));
      if (label) label.textContent = phaseNames[active] || 'Atlas';
      if (bar) bar.style.transform = `scaleX(${progress})`;
      draw(progress);
      if (Math.abs(progress - target) > .001 && !reduced) raf = requestAnimationFrame(render);
    }

    seed();
    measure();
    window.addEventListener('scroll', measure, { passive: true });
    window.addEventListener('resize', () => { seed(); measure(); }, { passive: true });
    reduceQuery.addEventListener?.('change', measure);
  });
</script>

<style>
  .cinema-atlas {
    --scroll-progress: 0;
    --scene-progress: 0;
    --camera-x: 0vw;
    --camera-y: 0vh;
    --camera-scale: 1;
    --orb-rotation: 0deg;
    --orb-rotation-reverse: 0deg;
    --orb-rotation-slow: 0deg;
    --axis-rotation: 0deg;
    --hero-opacity: 1;
    --background-shift: 0vh;
    --text-depth: 0px;
    position: relative;
    min-height: 720svh;
    color: #fff7df;
    background: #01030a;
  }

  .cinema-atlas__sticky { position: sticky; top: 0; height: 100svh; overflow: hidden; isolation: isolate; background: radial-gradient(circle at 50% 40%, #101a2a, #030711 55%, #01030a 100%); }
  .cinema-atlas__scroll-space { height: 1px; }
  .cinema-atlas__canvas, .cinema-atlas__stars, .cinema-atlas__map { position: absolute; inset: 0; }
  .cinema-atlas__canvas { z-index: -7; width: 100%; height: 100%; transform: translateY(var(--background-shift)) scale(1.08); }
  .cinema-atlas__stars { z-index: -6; opacity: .22; background-image: linear-gradient(rgba(255,255,255,.08) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,.06) 1px, transparent 1px); background-size: 88px 88px; mask-image: radial-gradient(circle, #000 0 56%, transparent 82%); transform: translate3d(calc(var(--camera-x) * -.35), calc(var(--camera-y) * -.45), 0); }
  .cinema-atlas__sticky::after { content: ""; position: absolute; inset: 0; z-index: 80; pointer-events: none; background: radial-gradient(circle at 50% 50%, transparent 0 42%, rgba(1,3,10,.46) 72%, rgba(1,3,10,.93)), linear-gradient(180deg, rgba(1,3,10,.76), transparent 24%, transparent 72%, rgba(1,3,10,.82)); }
  .cinema-atlas__sticky::before { content: ""; position: absolute; inset: 0; z-index: 81; opacity: .12; pointer-events: none; mix-blend-mode: overlay; background-image: repeating-radial-gradient(circle at 30% 20%, rgba(255,255,255,.34) 0 1px, transparent 1px 4px); }

  .cinema-atlas__map { z-index: -4; transform: translate3d(calc(var(--camera-x) * -.65), calc(var(--camera-y) * -.55), 0) scale(var(--camera-scale)); }
  .cinema-atlas__arc { position: absolute; left: 50%; top: 50%; width: min(78vw, 920px); aspect-ratio: 1; border: 1px solid rgba(239,202,128,.17); border-radius: 50%; transform: translate(-50%, -50%) rotateX(67deg) rotateZ(var(--orb-rotation)); box-shadow: 0 0 80px rgba(121,215,255,.08); }
  .cinema-atlas__arc--two { width: min(58vw, 680px); border-color: rgba(121,215,255,.18); transform: translate(-50%, -50%) rotateX(58deg) rotateY(20deg) rotateZ(var(--orb-rotation-reverse)); }
  .cinema-atlas__arc--three { width: min(42vw, 500px); border-style: dashed; border-color: rgba(255,255,255,.16); transform: translate(-50%, -50%) rotateX(72deg) rotateY(-24deg) rotateZ(var(--orb-rotation-slow)); }
  .cinema-atlas__axis { position: absolute; left: 50%; top: 12%; bottom: 12%; width: 1px; background: linear-gradient(transparent, rgba(239,202,128,.38), transparent); transform: rotate(var(--axis-rotation)); transform-origin: 50% 50%; }

  .cinema-atlas__camera { position: absolute; inset: 0; z-index: 4; display: grid; place-items: center; transform: translate3d(var(--camera-x), var(--camera-y), 0) scale(var(--camera-scale)); will-change: transform; }
  .cinema-atlas__object { position: relative; width: clamp(220px, 34vw, 520px); aspect-ratio: 1; transform: rotate(var(--orb-rotation)); filter: drop-shadow(0 35px 90px rgba(0,0,0,.55)); }
  .cinema-atlas__orb { position: absolute; inset: 19%; border-radius: 50%; }
  .cinema-atlas__orb--core { background: radial-gradient(circle at 36% 30%, #fff8d8, #d9a74f 12%, #27415a 38%, #07111f 64%, transparent 70%), conic-gradient(from var(--orb-rotation), rgba(239,202,128,.8), rgba(121,215,255,.18), rgba(255,255,255,.06), rgba(239,202,128,.8)); box-shadow: inset -20px -28px 50px rgba(0,0,0,.6), 0 0 120px rgba(239,202,128,.24), 0 0 180px rgba(121,215,255,.12); }
  .cinema-atlas__orb--halo { inset: 8%; border: 1px solid rgba(239,202,128,.24); background: radial-gradient(circle, transparent 55%, rgba(121,215,255,.08)); }
  .cinema-atlas__satellite { position: absolute; left: 50%; top: 50%; width: 10px; aspect-ratio: 1; border-radius: 50%; background: #f0ca80; box-shadow: 0 0 24px rgba(240,202,128,.9); transform: rotate(var(--orb-rotation)) translateX(clamp(130px, 22vw, 330px)); }
  .cinema-atlas__satellite--b { background: #9be3ff; transform: rotate(var(--orb-rotation-reverse)) rotate(110deg) translateX(clamp(105px, 17vw, 260px)); }
  .cinema-atlas__satellite--c { width: 6px; transform: rotate(var(--orb-rotation-slow)) rotate(230deg) translateX(clamp(80px, 14vw, 210px)); opacity: .75; }

  .cinema-atlas__copy { position: absolute; left: clamp(20px, 6vw, 90px); top: 50%; z-index: 90; width: min(760px, 58vw); transform: translateY(-50%); pointer-events: none; }
  .cinema-atlas__phase { position: absolute; inset: auto; opacity: 0; transform: translate3d(0, calc(34px + var(--text-depth)), 0) scale(.98); transition: opacity 560ms ease, transform 760ms cubic-bezier(.16,1,.3,1), filter 560ms ease; filter: blur(10px); }
  .cinema-atlas__phase[data-active] { opacity: 1; transform: translate3d(0, var(--text-depth), 0) scale(1); filter: blur(0); pointer-events: auto; }
  .cinema-atlas__eyebrow { margin: 0 0 16px; color: rgba(121,215,255,.74); font-size: 12px; font-weight: 800; letter-spacing: .22em; text-transform: uppercase; }
  .cinema-atlas__title { max-width: 11ch; margin: 0; font-size: clamp(54px, 9vw, 148px); line-height: .78; letter-spacing: -.08em; text-wrap: balance; }
  .cinema-atlas__text { max-width: 520px; margin: 24px 0 0; color: rgba(255,247,223,.68); font-size: clamp(16px, 1.35vw, 21px); line-height: 1.45; }
  .cinema-atlas__phase-link { display: inline-flex; margin-top: 28px; padding: 13px 17px; color: #fff7df; text-decoration: none; font-size: 12px; font-weight: 850; letter-spacing: .16em; text-transform: uppercase; border: 1px solid rgba(239,202,128,.38); border-radius: 999px; background: rgba(255,255,255,.07); backdrop-filter: blur(18px); box-shadow: inset 0 1px rgba(255,255,255,.16), 0 20px 70px rgba(0,0,0,.32); }
  .cinema-atlas__phase-link:hover, .cinema-atlas__phase-link:focus-visible, .cinema-atlas__nav-link:hover, .cinema-atlas__nav-link:focus-visible { outline: none; border-color: rgba(239,202,128,.78); box-shadow: 0 0 0 4px rgba(239,202,128,.13), 0 24px 80px rgba(239,202,128,.16); }

  .cinema-atlas__nav { position: absolute; right: clamp(18px, 4vw, 60px); top: 50%; z-index: 92; display: grid; gap: 12px; transform: translateY(-50%); }
  .cinema-atlas__nav-link { display: flex; align-items: center; gap: 12px; min-width: 150px; padding: 11px 13px; color: rgba(255,247,223,.74); text-decoration: none; font-size: 12px; font-weight: 760; border: 1px solid rgba(255,247,223,.12); border-radius: 999px; background: rgba(255,255,255,.045); backdrop-filter: blur(18px); }
  .cinema-atlas__nav-link span { color: #efca80; font-size: 10px; letter-spacing: .14em; }
  .cinema-atlas__hud { position: absolute; left: clamp(18px, 4vw, 60px); right: clamp(18px, 4vw, 60px); bottom: clamp(18px, 4vw, 42px); z-index: 91; display: grid; grid-template-columns: auto 1fr auto; align-items: center; gap: 18px; color: rgba(255,247,223,.56); font-size: 11px; font-weight: 800; letter-spacing: .18em; text-transform: uppercase; }
  .cinema-atlas__progress { height: 1px; background: rgba(255,247,223,.16); overflow: hidden; }
  .cinema-atlas__progress i { display: block; width: 100%; height: 100%; background: linear-gradient(90deg, #efca80, #79d7ff); transform: scaleX(0); transform-origin: left; }

  @media (max-width: 900px) { .cinema-atlas__copy { width: min(680px, 74vw); } .cinema-atlas__title { font-size: clamp(50px, 12vw, 104px); } .cinema-atlas__nav { top: auto; right: auto; left: 18px; bottom: 70px; grid-template-columns: repeat(5, auto); max-width: calc(100vw - 36px); overflow-x: auto; transform: none; } .cinema-atlas__nav-link { min-width: auto; white-space: nowrap; } }
  @media (max-width: 640px) { .cinema-atlas { min-height: 680svh; } .cinema-atlas__copy { left: 18px; right: 18px; top: 18%; width: auto; transform: none; } .cinema-atlas__title { max-width: 10ch; font-size: clamp(46px, 16vw, 76px); } .cinema-atlas__text { max-width: 92vw; font-size: 15px; } .cinema-atlas__object { width: min(78vw, 360px); transform: translateY(14vh) rotate(var(--orb-rotation)); } .cinema-atlas__hud { grid-template-columns: 1fr; gap: 9px; font-size: 9px; } .cinema-atlas__nav { bottom: 92px; } }
  @media (prefers-reduced-motion: reduce) { .cinema-atlas { min-height: 100svh; } .cinema-atlas__sticky { position: relative; } .cinema-atlas__phase, .cinema-atlas__camera, .cinema-atlas__map, .cinema-atlas__stars { transition: none; transform: none; } .cinema-atlas__phase { position: relative; display: none; filter: none; } .cinema-atlas__phase[data-active] { display: block; } }
</style>
