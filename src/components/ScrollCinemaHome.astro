---
const nodes = [
  {
    key: "science",
    title: "Science",
    href: "/science",
    index: "01",
    kicker: "Matter & mind",
    className: "science",
    children: [
      { title: "Physics", href: "/science/physics", description: "Matter, force, motion, and the structure of reality." },
      { title: "Astronomy", href: "/science/astronomy", description: "Stars, galaxies, cosmic scale, and observation." },
      { title: "Biology", href: "/science/biology", description: "Life, evolution, systems, and adaptation." },
      { title: "Mind & Intelligence", href: "/science/mind", description: "Cognition, AI, consciousness, and learning." },
    ],
  },
  {
    key: "history",
    title: "History",
    href: "/history",
    index: "02",
    kicker: "Time & empire",
    className: "history",
    children: [
      { title: "Ancient Civilizations", href: "/history/ancient-civilizations", description: "Origins, cities, myths, and early power." },
      { title: "Empires", href: "/history/empires", description: "Expansion, collapse, law, and cultural memory." },
      { title: "Philosophy", href: "/history/philosophy", description: "Ideas that shaped civilization and selfhood." },
      { title: "Maps & Timelines", href: "/history/maps-timelines", description: "Spatial and chronological ways of reading history." },
    ],
  },
  {
    key: "art",
    title: "Art",
    href: "/art",
    index: "03",
    kicker: "Form & feeling",
    className: "art",
    children: [
      { title: "Visual Studies", href: "/art/visual-studies", description: "Image, form, color, and composition." },
      { title: "Design", href: "/art/design", description: "Interfaces, systems, objects, and visual language." },
      { title: "Cinema", href: "/art/cinema", description: "Movement, atmosphere, editing, and narrative." },
      { title: "Architecture", href: "/art/architecture", description: "Space, material, proportion, and memory." },
    ],
  },
  {
    key: "future",
    title: "Future",
    href: "/future",
    index: "04",
    kicker: "Signals ahead",
    className: "future",
    children: [
      { title: "Artificial Intelligence", href: "/future/artificial-intelligence", description: "Intelligence, automation, agents, and tools." },
      { title: "Space Futures", href: "/future/space", description: "Exploration, settlement, telescopes, and orbital life." },
      { title: "Technology", href: "/future/technology", description: "Signals, interfaces, networks, and emerging systems." },
      { title: "Society", href: "/future/society", description: "How people, cities, work, and culture may change." },
    ],
  },
  {
    key: "jlog",
    title: "JLOG",
    href: "/blog",
    index: "05",
    kicker: "Field notes",
    className: "jlog",
    children: [
      { title: "Personal Notes", href: "/blog/personal-notes", description: "Short reflections and observations." },
      { title: "Essays", href: "/blog/essays", description: "Longer written thoughts and arguments." },
      { title: "Reading Log", href: "/blog/reading-log", description: "Books, articles, ideas, and references." },
      { title: "Research Notes", href: "/blog/research-notes", description: "Collected fragments and study notes." },
    ],
  },
];
---

<section class="atlas" data-knowledge-atlas aria-label="UGURCAN interactive knowledge atlas homepage">
  <div class="atlas__sticky">
    <canvas class="atlas__canvas" data-atlas-canvas aria-hidden="true"></canvas>
    <svg class="atlas__sigils" viewBox="0 0 1200 800" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <defs>
        <linearGradient id="atlasGold" x1="0" x2="1" y1="0" y2="1">
          <stop offset="0" stop-color="#fff4c7" stop-opacity=".7" />
          <stop offset=".55" stop-color="#d7a84f" stop-opacity=".3" />
          <stop offset="1" stop-color="#79d7ff" stop-opacity=".16" />
        </linearGradient>
      </defs>
      <path class="atlas__curve atlas__curve--science" d="M173 424 C 304 244, 489 239, 594 392 S 866 570, 1038 355" />
      <path class="atlas__curve atlas__curve--history" d="M128 519 C 316 571, 419 324, 608 397 S 858 502, 1068 279" />
      <path class="atlas__curve atlas__curve--art" d="M195 294 C 347 196, 432 566, 595 402 S 842 202, 1032 491" />
      <path class="atlas__curve atlas__curve--future" d="M108 402 C 332 361, 427 430, 600 400 S 881 342, 1104 403" />
    </svg>

    <div class="atlas__shade" aria-hidden="true"></div>
    <div class="atlas__grain" aria-hidden="true"></div>

    <div class="atlas__core" aria-hidden="true"></div>

    <nav class="atlas__nav" aria-label="Primary sections" data-atlas-nav>
      {nodes.map((node) => (
        <div
          class:list={["atlas__node-shell", `atlas__node-shell--${node.className}`]}
          data-atlas-node-shell
          data-category={node.key}
        >
          <button
            class:list={["atlas__node", `atlas__node--${node.className}`]}
            type="button"
            aria-expanded="false"
            aria-controls={`atlas-submenu-${node.key}`}
            data-atlas-node
            data-category={node.key}
          >
            <span class="atlas__node-index">{node.index}</span>
            <span class="atlas__node-mark" aria-hidden="true"></span>
            <span class="atlas__node-text">
              <span class="atlas__node-title">{node.title}</span>
              <span class="atlas__node-kicker">{node.kicker}</span>
            </span>
          </button>

          <div
            id={`atlas-submenu-${node.key}`}
            class="atlas__submenu"
            data-atlas-submenu
            aria-label={`${node.title} subtopics`}
          >
            <span class="atlas__connector" aria-hidden="true"></span>

            {node.children.map((child, childIndex) => (
              <a class="atlas__subitem" href={child.href} style={`--i:${childIndex}`}>
                <span class="atlas__subitem-dot" aria-hidden="true"></span>
                <span class="atlas__subitem-copy">
                  <span class="atlas__subitem-title">{child.title}</span>
                  <span class="atlas__subitem-description">{child.description}</span>
                </span>
              </a>
            ))}
          </div>
        </div>
      ))}
    </nav>

    <p class="atlas__phase" data-atlas-phase>COSMIC KNOWLEDGE FIELD</p>
  </div>
</section>

<script>
  const atlases = document.querySelectorAll('[data-knowledge-atlas]');

  atlases.forEach((atlas) => {
    const canvas = atlas.querySelector('[data-atlas-canvas]');
    const ctx = canvas.getContext('2d', { alpha: true, desynchronized: true });
    const nodeShells = Array.from(atlas.querySelectorAll('[data-atlas-node-shell]'));
    const nodeButtons = Array.from(atlas.querySelectorAll('[data-atlas-node]'));
    const reduceQuery = window.matchMedia('(prefers-reduced-motion: reduce)');

    let width = 1;
    let height = 1;
    let dpr = 1;
    let raf = 0;
    let reduce = reduceQuery.matches;
    let particles = [];
    let inputRotationTarget = 0;
    let inputRotationCurrent = 0;
    let virtualPhaseTarget = .18;
    let virtualPhaseCurrent = .18;
    let autoRotation = 0;
    let lastTime = performance.now();
    let lastTouchY = 0;
    let touchStartedOnLink = false;
    let activeCategory = null;
    let frozenNavRotation = 0;

    const clamp = (value, min, max) => Math.max(min, Math.min(max, value));
    const lerp = (a, b, t) => a + (b - a) * t;
    function wake() {
      if (!raf) raf = requestAnimationFrame(draw);
    }

    function seedParticles() {
      const count = window.innerWidth < 700 ? 86 : window.innerWidth < 1100 ? 130 : 180;
      particles = Array.from({ length: count }, (_, i) => ({
        angle: (i * 2.399963 + (i % 7) * .17) % (Math.PI * 2),
        radius: .12 + ((i * 37) % 100) / 100 * .78,
        size: .45 + ((i * 19) % 100) / 100 * 1.75,
        speed: .12 + ((i * 13) % 100) / 100 * .42,
        tone: i % 5,
      }));
    }

    function sizeCanvas() {
      dpr = Math.min(window.devicePixelRatio || 1, window.innerWidth < 700 ? 1.45 : 2);
      const rect = canvas.getBoundingClientRect();
      width = Math.max(1, Math.floor(rect.width * dpr));
      height = Math.max(1, Math.floor(rect.height * dpr));
      if (canvas.width !== width || canvas.height !== height) {
        canvas.width = width;
        canvas.height = height;
      }
    }

    function drawOrbitalRing(cx, cy, rx, ry, rotation, alpha, color) {
      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(rotation);
      ctx.scale(1, ry / rx);
      ctx.beginPath();
      ctx.arc(0, 0, rx, 0, Math.PI * 2);
      ctx.strokeStyle = color;
      ctx.globalAlpha = alpha;
      ctx.lineWidth = Math.max(1, dpr);
      ctx.stroke();
      ctx.restore();
    }

    function draw(now = performance.now()) {
      raf = 0;
      const isMobile = window.innerWidth < 700;
      const dt = Math.min(50, now - lastTime) / 1000;
      lastTime = now;

      if (!reduce) autoRotation += dt * .045;

      inputRotationCurrent = reduce ? 0 : lerp(inputRotationCurrent, inputRotationTarget, isMobile ? .18 : .11);
      virtualPhaseCurrent = reduce ? .18 : lerp(virtualPhaseCurrent, virtualPhaseTarget, isMobile ? .12 : .08);

      const backgroundRotation = reduce ? 0 : autoRotation + inputRotationCurrent;
      const navRotation = reduce ? 0 : activeCategory ? frozenNavRotation : inputRotationCurrent;
      const phase = reduce ? .18 : virtualPhaseCurrent + autoRotation * .08;
      const displayPhase = reduce ? .18 : virtualPhaseCurrent;
      const cycle = phase * Math.PI * 2;

      const scienceGlow = clamp(.45 + .25 * Math.sin(cycle + 0), 0, 1);
      const historyGlow = clamp(.42 + .22 * Math.sin(cycle + Math.PI * .5), 0, 1);
      const artGlow = clamp(.46 + .24 * Math.sin(cycle + Math.PI), 0, 1);
      const futureGlow = clamp(.44 + .23 * Math.sin(cycle + Math.PI * 1.5), 0, 1);

      atlas.style.setProperty('--science-glow', scienceGlow.toFixed(4));
      atlas.style.setProperty('--history-glow', historyGlow.toFixed(4));
      atlas.style.setProperty('--art-glow', artGlow.toFixed(4));
      atlas.style.setProperty('--future-glow', futureGlow.toFixed(4));
      atlas.style.setProperty('--scroll-rotation', (backgroundRotation * 180 / Math.PI).toFixed(4));

      const cx = width * .5;
      const cy = height * .5;
      const min = Math.min(width, height);
      const science = scienceGlow;
      const history = historyGlow;
      const art = artGlow;
      const future = futureGlow;

      ctx.clearRect(0, 0, width, height);
      const bg = ctx.createRadialGradient(cx, cy, min * .04, cx, cy, min * .86);
      bg.addColorStop(0, `rgba(35, 29, 18, ${.78 + future * .1})`);
      bg.addColorStop(.28, '#07111f');
      bg.addColorStop(.68, '#030711');
      bg.addColorStop(1, '#01030a');
      ctx.fillStyle = bg;
      ctx.fillRect(0, 0, width, height);

      ctx.save();
      ctx.globalAlpha = .08 + future * .08;
      ctx.strokeStyle = '#a9c8dd';
      ctx.lineWidth = 1 * dpr;
      const grid = 72 * dpr;
      for (let x = (cx % grid); x < width; x += grid) { ctx.beginPath(); ctx.moveTo(x, 0); ctx.lineTo(lerp(x, cx, .08), height); ctx.stroke(); }
      for (let y = (cy % grid); y < height; y += grid) { ctx.beginPath(); ctx.moveTo(0, y); ctx.lineTo(width, lerp(y, cy, .08)); ctx.stroke(); }
      ctx.restore();

      particles.forEach((p) => {
        const layerPull = lerp(.78, 1.08, science);
        const a = p.angle + backgroundRotation * p.speed + cycle * .18 * (p.tone % 2 ? 1.7 : -1.25);
        const orbit = p.radius * min * .58 * layerPull;
        const x = cx + Math.cos(a) * orbit * (1 + history * .18);
        const y = cy + Math.sin(a) * orbit * (.48 + art * .12);
        const alpha = .14 + science * .36 + future * .18;
        ctx.beginPath();
        ctx.fillStyle = p.tone === 0 ? `rgba(235, 187, 91, ${alpha})` : `rgba(213, 231, 244, ${alpha * .72})`;
        ctx.arc(x, y, p.size * dpr * (1 + future * .45), 0, Math.PI * 2);
        ctx.fill();
      });

      for (let i = 0; i < 6; i += 1) {
        drawOrbitalRing(cx, cy, min * (.19 + i * .082 + future * .018), min * (.055 + i * .024 + history * .02), backgroundRotation * (.18 + i * .03) + cycle * .08 * i, .11 + i * .018 + history * .05, i % 2 ? 'rgba(240,198,111,.88)' : 'rgba(166,213,238,.62)');
      }

      ctx.save();
      ctx.translate(cx, cy);
      ctx.rotate(backgroundRotation * .24 + cycle * .12);
      for (let i = 0; i < 18; i += 1) {
        const a = i / 18 * Math.PI * 2;
        const r = min * (.15 + Math.sin(i * 1.7 + backgroundRotation) * .012 + art * .045);
        ctx.beginPath();
        ctx.moveTo(Math.cos(a) * r * .42, Math.sin(a) * r * .42);
        ctx.quadraticCurveTo(Math.cos(a + .55) * r, Math.sin(a + .55) * r, Math.cos(a + 1.15) * r * .72, Math.sin(a + 1.15) * r * .72);
        ctx.strokeStyle = `rgba(237, 202, 128, ${art * .18 + future * .08})`;
        ctx.lineWidth = (1.2 + art * 1.2) * dpr;
        ctx.stroke();
      }
      ctx.restore();

      const core = ctx.createRadialGradient(cx - min * .035, cy - min * .045, 0, cx, cy, min * (.145 + future * .018));
      core.addColorStop(0, 'rgba(255,247,213,.95)');
      core.addColorStop(.18, 'rgba(234,186,83,.8)');
      core.addColorStop(.48, 'rgba(71,105,130,.34)');
      core.addColorStop(1, 'rgba(2,6,14,0)');
      ctx.fillStyle = core;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.15 + future * .02), 0, Math.PI * 2);
      ctx.fill();

      ctx.save();
      ctx.globalCompositeOperation = 'lighter';
      ctx.strokeStyle = `rgba(255, 224, 146, ${.28 + future * .34})`;
      ctx.lineWidth = (1.4 + future * 1.6) * dpr;
      ctx.beginPath();
      ctx.arc(cx, cy, min * (.05 + future * .08), backgroundRotation, backgroundRotation + Math.PI * (1.15 + future));
      ctx.stroke();
      ctx.restore();

      updateNodes(displayPhase, navRotation);

      if (!reduce) raf = requestAnimationFrame(draw);
    }

    function updateNodes(p, scrollRotation = 0) {
      const radiusX = Math.min(window.innerWidth * (window.innerWidth < 700 ? .36 : .34), 520);
      const radiusY = Math.min(window.innerHeight * (window.innerWidth < 700 ? .33 : .28), 265);
      nodeShells.forEach((node, index) => {
        const angle = index / nodeShells.length * Math.PI * 2 - Math.PI / 2 + scrollRotation + p * .45;
        const depth = (Math.sin(angle) + 1) / 2;
        node.style.setProperty('--x', `${Math.cos(angle) * radiusX}px`);
        node.style.setProperty('--y', `${Math.sin(angle) * radiusY}px`);
        node.style.setProperty('--s', lerp(.78, 1.12, depth).toFixed(3));
        node.style.setProperty('--o', lerp(.56, 1, depth).toFixed(3));
        node.style.setProperty('--z', String(Math.round(10 + depth * 90)));
      });
    }

    function applyVirtualDelta(delta, rotationScale, phaseScale) {
      if (!activeCategory) inputRotationTarget += delta * rotationScale;
      virtualPhaseTarget += delta * phaseScale;
      wake();
    }

    function onWheel(event) {
      if (reduce) return;
      event.preventDefault();
      const normalized = clamp(event.deltaY, -80, 80);
      applyVirtualDelta(normalized, .006, .00055);
    }

    function onTouchStart(event) {
      touchStartedOnLink = Boolean(event.target.closest('a, [data-atlas-node]'));
      if (touchStartedOnLink || !event.touches.length) return;
      lastTouchY = event.touches[0].clientY;
    }

    function onTouchMove(event) {
      if (reduce || touchStartedOnLink || !event.touches.length) return;
      const y = event.touches[0].clientY;
      const delta = lastTouchY - y;
      lastTouchY = y;
      applyVirtualDelta(delta, .008, .00075);
      event.preventDefault();
    }

    function closeSubmenu() {
      activeCategory = null;
      delete atlas.dataset.mode;
      delete atlas.dataset.activeCategory;
      nodeShells.forEach((shell) => {
        delete shell.dataset.active;
      });
      nodeButtons.forEach((button) => {
        button.setAttribute('aria-expanded', 'false');
      });
    }

    function openSubmenu(category) {
      activeCategory = category;
      frozenNavRotation = inputRotationCurrent;
      atlas.dataset.mode = 'submenu';
      atlas.dataset.activeCategory = category;
      nodeShells.forEach((shell) => {
        if (shell.dataset.category === category) shell.dataset.active = 'true';
        else delete shell.dataset.active;
      });
      nodeButtons.forEach((button) => {
        button.setAttribute('aria-expanded', String(button.dataset.category === category));
      });
      wake();
    }

    function onNodeClick(event) {
      event.stopPropagation();
      const category = event.currentTarget.dataset.category;
      if (!category) return;
      if (activeCategory === category) closeSubmenu();
      else openSubmenu(category);
    }

    function onDocumentClick(event) {
      if (!activeCategory) return;
      const activeShell = atlas.querySelector('.atlas__node-shell[data-active="true"]');
      if (activeShell && !activeShell.contains(event.target)) closeSubmenu();
    }

    function onKeyDown(event) {
      if (event.key === 'Escape' && activeCategory) closeSubmenu();
    }

    function onResize() {
      sizeCanvas();
      seedParticles();
      wake();
    }

    sizeCanvas();
    seedParticles();
    updateNodes(.18);
    wake();

    atlas.addEventListener('wheel', onWheel, { passive: false });
    atlas.addEventListener('touchstart', onTouchStart, { passive: true });
    atlas.addEventListener('touchmove', onTouchMove, { passive: false });
    nodeButtons.forEach((button) => button.addEventListener('click', onNodeClick));
    document.addEventListener('click', onDocumentClick);
    window.addEventListener('keydown', onKeyDown);
    window.addEventListener('resize', onResize, { passive: true });
    reduceQuery.addEventListener?.('change', (event) => {
      reduce = event.matches;
      lastTime = performance.now();
      wake();
    });
  });
</script>

<style>
  .atlas {
    --science-glow: .45;
    --history-glow: .42;
    --art-glow: .46;
    --future-glow: .44;
    --scroll-rotation: 0;
    min-height: 100svh;
    height: 100svh;
    overflow: hidden;
    overscroll-behavior: none;
    touch-action: none;
    background: #01030a;
    color: #fff7df;
  }

  .atlas__sticky {
    position: relative;
    min-height: 100svh;
    height: 100svh;
    overflow: hidden;
    isolation: isolate;
    display: grid;
    place-items: center;
    background: #01030a;
  }

  .atlas__canvas,
  .atlas__sigils,
  .atlas__shade,
  .atlas__grain {
    position: absolute;
    inset: 0;
  }

  .atlas__canvas {
    z-index: -4;
    width: 100%;
    height: 100%;
  }

  .atlas__sigils {
    z-index: -3;
    opacity: .82;
    transform: scale(1.02);
  }

  .atlas__curve {
    fill: none;
    stroke: url(#atlasGold);
    stroke-width: 1.25;
    stroke-linecap: round;
    stroke-dasharray: 9 18;
    opacity: 0;
  }

  .atlas__curve--science { opacity: calc(var(--science-glow) * .36); }
  .atlas__curve--history { opacity: calc(var(--history-glow) * .34); }
  .atlas__curve--art { opacity: calc(var(--art-glow) * .48); stroke-dasharray: 2 13; }
  .atlas__curve--future { opacity: calc(var(--future-glow) * .58); stroke-dasharray: 1 10; }

  .atlas__shade {
    z-index: 5;
    pointer-events: none;
    background:
      radial-gradient(circle at 50% 50%, transparent 0 34%, rgba(1,3,10,.34) 64%, rgba(1,3,10,.92) 100%),
      linear-gradient(180deg, rgba(1,3,10,.64), transparent 24%, transparent 70%, rgba(1,3,10,.72));
  }

  .atlas__grain {
    z-index: 6;
    pointer-events: none;
    opacity: .12;
    mix-blend-mode: overlay;
    background-image: repeating-radial-gradient(circle at 30% 20%, rgba(255,255,255,.22) 0 1px, transparent 1px 4px);
  }

  .atlas__core {
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: 18;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 10px;
    color: #fff7df;
    text-decoration: none;
    transform: translate3d(-50%, -50%, 0);
  }

  .atlas__core::before,
  .atlas__core::after {
    content: "";
    position: absolute;
    left: 50%;
    top: 50%;
    border: 1px solid rgba(236, 196, 114, .22);
    border-radius: 50%;
    pointer-events: none;
    transform: translate(-50%, -50%) rotateX(68deg) rotateZ(calc(var(--scroll-rotation) * 1deg));
  }

  .atlas__core::before { width: clamp(170px, 25vw, 330px); aspect-ratio: 1; }
  .atlas__core::after { width: clamp(250px, 38vw, 520px); aspect-ratio: 1; opacity: .5; }

  .atlas__nav {
    position: absolute;
    inset: 0;
    z-index: 30;
    pointer-events: none;
    perspective: 1200px;
  }

  .atlas__node-shell {
    --x: 0px;
    --y: 0px;
    --s: 1;
    --o: 1;
    --z: 20;
    position: absolute;
    left: 50%;
    top: 50%;
    z-index: var(--z);
    opacity: var(--o);
    pointer-events: none;
    transform: translate(-50%, -50%) translate3d(var(--x), var(--y), 0) scale(var(--s));
    transition: opacity .32s ease, filter .32s ease, transform .42s cubic-bezier(.2,.8,.2,1);
    will-change: transform, opacity;
  }

  .atlas__node {
    appearance: none;
    display: inline-grid;
    grid-template-columns: auto auto 1fr;
    align-items: center;
    gap: 10px;
    min-width: clamp(138px, 15vw, 186px);
    min-height: 58px;
    padding: 11px 14px;
    color: #fff7df;
    font: inherit;
    text-align: left;
    border: 1px solid rgba(255, 247, 223, .15);
    border-radius: 999px;
    background: linear-gradient(135deg, rgba(255,255,255,.13), rgba(255,255,255,.045));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.16), 0 24px 70px rgba(0,0,0,.32);
    backdrop-filter: blur(24px) saturate(140%);
    cursor: pointer;
    pointer-events: auto;
    transition: border-color .22s ease, background .22s ease, box-shadow .22s ease;
  }

  .atlas__node:hover,
  .atlas__node:focus-visible {
    border-color: rgba(239, 202, 128, .62);
    background: linear-gradient(135deg, rgba(255,255,255,.22), rgba(255,255,255,.075));
    box-shadow: inset 0 1px 0 rgba(255,255,255,.25), 0 28px 90px rgba(222, 174, 82, .22);
    outline: none;
  }



  .atlas[data-mode="submenu"] .atlas__shade {
    background:
      radial-gradient(circle at 50% 50%, rgba(1,3,10,.08) 0 28%, rgba(1,3,10,.48) 64%, rgba(1,3,10,.95) 100%),
      linear-gradient(180deg, rgba(1,3,10,.7), transparent 24%, transparent 70%, rgba(1,3,10,.78));
  }

  .atlas[data-mode="submenu"] .atlas__node-shell:not([data-active="true"]) {
    opacity: .42;
    filter: saturate(.72) brightness(.78);
  }

  .atlas__node-shell[data-active="true"] {
    opacity: 1;
    filter: none;
  }

  .atlas__node-shell[data-active="true"] .atlas__node {
