---
import "../styles/cinematic-home.css";

const destinations = [
  { label: "JLOG", href: "/blog", tone: "journal" },
  { label: "Science", href: "/science", tone: "science" },
  { label: "History", href: "/history", tone: "history" },
  { label: "Art", href: "/art", tone: "art" },
  { label: "Future", href: "/future", tone: "future" },
] as const;
---

<section class="cosmic-library" data-cosmic-library data-active="0" aria-label="Explore Ugurcan Yagiz">
  <div class="cosmic-library__scene" aria-hidden="true">
    <div class="cosmic-library__backdrop"></div>
    <div class="cosmic-library__stars"></div>
    <div class="cosmic-library__orbits"></div>
    <div class="cosmic-library__glow"></div>
    <div class="cosmic-library__wind"></div>
    <div class="cosmic-library__papers">
      <i></i><i></i><i></i><i></i><i></i><i></i>
    </div>
    <div class="cosmic-library__shade"></div>
  </div>

  <a class="cosmic-library__brand" href="/" aria-label="Ugurcan Yagiz home">UGURCAN YAGIZ</a>
  <p class="cosmic-library__eyebrow">THE LIVING ARCHIVE</p>

  <nav class="cosmic-library__menu" aria-label="Main sections">
    <div class="cosmic-library__wheel" data-menu-wheel>
      {destinations.map((item, index) => (
        <a
          class="cosmic-library__item"
          data-menu-item
          data-index={index}
          data-tone={item.tone}
          href={item.href}
          aria-current={index === 0 ? "page" : undefined}
          tabindex={index === 0 ? 0 : -1}
        >
          <span>{item.label}</span>
        </a>
      ))}
    </div>
  </nav>

  <div class="cosmic-library__progress" aria-hidden="true">
    <span data-progress-current>01</span>
    <i></i>
    <span>{String(destinations.length).padStart(2, "0")}</span>
  </div>

  <p class="cosmic-library__hint"><span>SCROLL</span><i></i></p>
  <div class="cosmic-library__scroll-space" aria-hidden="true"></div>
</section>

<script>
  const roots = document.querySelectorAll<HTMLElement>("[data-cosmic-library]");

  roots.forEach((root) => {
    const items = [...root.querySelectorAll<HTMLAnchorElement>("[data-menu-item]")];
    const current = root.querySelector<HTMLElement>("[data-progress-current]");
    const reducedMotion = window.matchMedia("(prefers-reduced-motion: reduce)");
    let active = 0;
    let touchStart = 0;
    let locked = false;

    const select = (next: number, scrollPage = false) => {
      active = Math.max(0, Math.min(items.length - 1, next));
      root.dataset.active = String(active);
      root.dataset.tone = items[active]?.dataset.tone ?? "personal";
      items.forEach((item, index) => {
        const isActive = index === active;
        item.toggleAttribute("aria-current", isActive);
        item.tabIndex = isActive ? 0 : -1;
      });
      if (current) current.textContent = String(active + 1).padStart(2, "0");
      if (scrollPage && !reducedMotion.matches) {
        window.scrollTo({ top: active * window.innerHeight, behavior: "smooth" });
      }
    };

    const syncFromScroll = () => {
      const max = Math.max(1, root.scrollHeight - window.innerHeight);
      const local = Math.max(0, Math.min(max, window.scrollY - root.offsetTop));
      select(Math.round((local / max) * (items.length - 1)));
      root.style.setProperty("--scroll-progress", String(local / max));
    };

    const step = (direction: number) => {
      if (locked) return;
      locked = true;
      select(active + direction, true);
      window.setTimeout(() => { locked = false; }, 520);
    };

    items.forEach((item, index) => {
      item.addEventListener("focus", () => select(index));
      item.addEventListener("click", (event) => {
        if (index !== active) {
          event.preventDefault();
          select(index, true);
        }
      });
    });

    root.addEventListener("keydown", (event) => {
      if (["ArrowDown", "s", "S"].includes(event.key)) { event.preventDefault(); step(1); }
      if (["ArrowUp", "w", "W"].includes(event.key)) { event.preventDefault(); step(-1); }
      if ((event.key === "Enter" || event.key === " ") && document.activeElement === root) {
        event.preventDefault();
        items[active]?.click();
      }
    });
    root.addEventListener("touchstart", (event) => { touchStart = event.touches[0]?.clientY ?? 0; }, { passive: true });
    root.addEventListener("touchend", (event) => {
      const delta = touchStart - (event.changedTouches[0]?.clientY ?? touchStart);
      if (Math.abs(delta) > 44) step(delta > 0 ? 1 : -1);
    }, { passive: true });
    window.addEventListener("scroll", syncFromScroll, { passive: true });
    window.addEventListener("resize", syncFromScroll, { passive: true });
    syncFromScroll();
  });
</script>
