---
import { cinematicHomeMedia } from "../lib/cinematicMedia";
import "../styles/cinematic-home.css";

const media = cinematicHomeMedia;
const meteors = [
  { key: "science", label: "Science", href: "/science", duration: "42s", delay: "-9s", top: "15%", start: "8vw", end: "74vw", drift: "-9vh", angle: "-8deg", size: "clamp(66px, 6.4vw, 112px)", depth: ".92", blur: "0px" },
  { key: "history", label: "History", href: "/history", duration: "54s", delay: "-37s", top: "43%", start: "19vw", end: "78vw", drift: "-6vh", angle: "-5deg", size: "clamp(54px, 5.2vw, 92px)", depth: ".68", blur: ".45px" },
  { key: "art", label: "Art", href: "/art", duration: "47s", delay: "-25s", top: "29%", start: "5vw", end: "63vw", drift: "-12vh", angle: "-11deg", size: "clamp(62px, 5.9vw, 104px)", depth: ".82", blur: ".15px" },
  { key: "future", label: "Future", href: "/future", duration: "58s", delay: "-48s", top: "9%", start: "31vw", end: "79vw", drift: "8vh", angle: "6deg", size: "clamp(48px, 4.6vw, 82px)", depth: ".58", blur: ".8px" },
  { key: "astrophysics", label: "Astrophysics", href: "/science", duration: "45s", delay: "-33s", top: "48%", start: "7vw", end: "69vw", drift: "-14vh", angle: "-13deg", size: "clamp(68px, 6.8vw, 120px)", depth: ".96", blur: "0px" },
  { key: "mathematics", label: "Mathematics", href: "/science", duration: "62s", delay: "-17s", top: "35%", start: "27vw", end: "76vw", drift: "-4vh", angle: "-4deg", size: "clamp(44px, 4.2vw, 76px)", depth: ".52", blur: "1px" },
  { key: "jlog", label: "JLOG", href: "/blog", duration: "51s", delay: "-5s", top: "7%", start: "12vw", end: "66vw", drift: "10vh", angle: "7deg", size: "clamp(52px, 5vw, 88px)", depth: ".64", blur: ".55px" },
  { key: "me", label: "Me", href: "/me", duration: "60s", delay: "-43s", top: "24%", start: "36vw", end: "79vw", drift: "-8vh", angle: "-7deg", size: "clamp(46px, 4.5vw, 80px)", depth: ".56", blur: ".9px" },
] as const;
---

<section class="cinematic-home" aria-label="Explore Ugurcan's atlas">
  <picture class="cinematic-home__picture">
    <source media="(max-width: 640px), (orientation: portrait)" srcset={media.mobile} />
    <source media="(max-width: 1180px)" srcset={media.tablet} />
    <img
      class="cinematic-home__background"
      src={media.desktop}
      alt="A quiet anime-inspired study overlooking a city at sunset"
      fetchpriority="high"
      decoding="async"
    />
  </picture>

  <nav class="cinematic-home__sky" aria-label="Explore sections">
    {meteors.map((meteor, index) => (
      <a
        class={`cinematic-home__meteor cinematic-home__meteor--${meteor.key}`}
        href={meteor.href}
        aria-label={`Explore ${meteor.label}`}
        style={`--meteor-duration:${meteor.duration};--meteor-delay:${meteor.delay};--meteor-top:${meteor.top};--meteor-start:${meteor.start};--meteor-end:${meteor.end};--meteor-drift:${meteor.drift};--meteor-angle:${meteor.angle};--meteor-size:${meteor.size};--meteor-depth:${meteor.depth};--meteor-blur:${meteor.blur};--meteor-index:${index};`}
      >
        <span class="cinematic-home__trail" aria-hidden="true"></span>
        <img
          class="cinematic-home__meteor-image"
          src={`/images/cinematic-home/${meteor.key}.webp`}
          alt=""
          width="512"
          height="512"
          loading={index < 3 ? "eager" : "lazy"}
          decoding="async"
        />
        <span class="cinematic-home__meteor-label">{meteor.label}</span>
      </a>
    ))}
  </nav>

  <div class="cinematic-home__glass" aria-hidden="true"></div>
  <div class="cinematic-home__vignette" aria-hidden="true"></div>
</section>
