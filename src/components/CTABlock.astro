---
const { title = "Open to Senior Accountant / Financial Analyst opportunities.", text = "Financial reporting, SAP Business One, Excel automation, SQL reporting, dashboards, reconciliation, and process improvement." } = Astro.props;
---
<section class="atlas-cta" data-reveal>
  <div>
    <p class="atlas-eyebrow">Open to work</p>
    <h2>{title}</h2>
    <p>{text}</p>
  </div>
  <div class="atlas-actions">
    <a class="atlas-button atlas-button--primary" href="/resume">View Resume</a>
    <a class="atlas-button" href="https://www.linkedin.com/in/ugurcanyagiz" target="_blank" rel="noreferrer">LinkedIn</a>
    <a class="atlas-button" href="mailto:ugurcanyagiz@gmail.com">Contact</a>
  </div>
</section>
