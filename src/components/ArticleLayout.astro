---
import SiteLayout from "./SiteLayout.astro";

const { title = "UGURCAN YAGIZ", description = "" } = Astro.props;
---

<SiteLayout title={title} description={description} showBackground={false}>
  <div class="article-editorial" data-article-editorial>
    <div class="article-progress" aria-hidden="true"><span></span></div>
    <div class="article-atmosphere" aria-hidden="true">
      <span class="article-atmosphere__field article-atmosphere__field--cyan"></span>
      <span class="article-atmosphere__field article-atmosphere__field--gold"></span>
      <span class="article-atmosphere__orbital"></span>
      <span class="article-atmosphere__grain"></span>
    </div>
    <slot />
  </div>
</SiteLayout>

<script>
  const root = document.querySelector("[data-article-editorial]");

  if (root) {
    const progress = root.querySelector(".article-progress span");
    const atmosphere = root.querySelector(".article-atmosphere");
    const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)");

    const updateArticleProgress = () => {
      const doc = document.documentElement;
      const max = doc.scrollHeight - window.innerHeight;
      const ratio = max > 0 ? Math.min(1, Math.max(0, window.scrollY / max)) : 0;
      if (progress) progress.style.transform = `scaleX(${ratio})`;
      if (atmosphere && !reduceMotion.matches) {
        atmosphere.style.setProperty("--article-scroll", ratio.toFixed(4));
      }
    };

    updateArticleProgress();
    window.addEventListener("scroll", updateArticleProgress, { passive: true });
    window.addEventListener("resize", updateArticleProgress);

    const revealTargets = root.querySelectorAll("article.page > header, article.page > .section, article.page > .footnav");
    revealTargets.forEach((target) => target.classList.add("article-reveal"));

    if ("IntersectionObserver" in window && !reduceMotion.matches) {
      const observer = new IntersectionObserver((entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            entry.target.classList.add("is-visible");
            observer.unobserve(entry.target);
          }
        });
      }, { rootMargin: "0px 0px -12%", threshold: 0.12 });

      revealTargets.forEach((target) => observer.observe(target));
    } else {
      revealTargets.forEach((target) => target.classList.add("is-visible"));
    }
  }
</script>

<style is:global>
  :root{--article-ink:#11131a;--article-muted:rgba(17,19,26,.68);--article-line:rgba(17,19,26,.1);--article-paper:rgba(255,255,255,.76);--article-accent:#1f8fff;--article-gold:#d99b43}
  .article-editorial{position:relative;min-height:100svh;overflow-x:clip;background:linear-gradient(180deg,#fbfaf7 0%,#eef7ff 46%,#fff8ee 100%);color:var(--article-ink);isolation:isolate}
  .article-progress{position:fixed;z-index:80;top:0;left:0;right:0;height:3px;background:rgba(17,19,26,.08)}
  .article-progress span{display:block;height:100%;transform:scaleX(0);transform-origin:left center;background:linear-gradient(90deg,#6fdcff,#f0c36d);will-change:transform}
  .article-atmosphere{position:absolute;inset:0;z-index:-1;overflow-x:clip;pointer-events:none;contain:paint;--article-scroll:0}
  .article-atmosphere__field{position:absolute;width:min(58vw,760px);aspect-ratio:1;border-radius:999px;filter:blur(28px);opacity:.28;transform:translate3d(0,calc(var(--article-scroll)*80px),0)}
  .article-atmosphere__field--cyan{left:-18vw;top:8rem;background:radial-gradient(circle,rgba(111,220,255,.8),transparent 68%)}
  .article-atmosphere__field--gold{right:-20vw;top:36rem;background:radial-gradient(circle,rgba(240,195,109,.72),transparent 70%)}
  .article-atmosphere__orbital{position:absolute;left:50%;top:12rem;width:min(92vw,1180px);aspect-ratio:1/.42;transform:translateX(-50%) rotate(-7deg);border:1px solid rgba(31,143,255,.13);border-radius:50%;opacity:.8}
  .article-atmosphere__grain{position:absolute;inset:0;opacity:.04;background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 180 180' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='3' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E")}
  article.page{width:min(1160px,calc(100% - 32px));margin:0 auto;padding:clamp(5.5rem,9vw,8rem) 0 6rem;display:grid;gap:clamp(1.25rem,3vw,2.5rem)}
  article.page>header,.hero{display:grid;gap:clamp(1rem,2vw,1.4rem);margin:0 0 .5rem}article.page>header::after{content:'';display:block;width:100%;max-width:1160px;aspect-ratio:16/5;border:1px solid rgba(31,143,255,.12);border-radius:28px;background:radial-gradient(circle at 18% 42%,rgba(111,220,255,.42),transparent 22%),radial-gradient(circle at 76% 44%,rgba(240,195,109,.34),transparent 24%),linear-gradient(135deg,rgba(255,255,255,.58),rgba(255,255,255,.22));box-shadow:inset 0 1px 0 rgba(255,255,255,.7),0 24px 80px rgba(24,47,79,.08)}article.page>header:has(.hero-img)::after{display:none}.hero-top{display:flex;align-items:center;justify-content:space-between;gap:1rem;min-width:0}.back{color:var(--article-muted);font-size:.82rem;font-weight:800;text-decoration:none}.back:hover,.back:focus-visible{color:var(--article-ink);text-decoration:underline;text-underline-offset:4px}.chip{display:inline-flex;align-items:center;max-width:100%;padding:.5rem .7rem;border:1px solid color-mix(in srgb,var(--article-accent) 24%,transparent);border-radius:999px;background:rgba(255,255,255,.58);color:color-mix(in srgb,var(--article-accent) 72%,#11131a);font-size:.72rem;font-weight:900;letter-spacing:.14em;text-transform:uppercase;white-space:nowrap}.chip[class*="--"]{box-shadow:inset 0 0 0 1px rgba(31,143,255,.1)}
  h1{max-width:13ch;margin:0;color:#0d111b;font-family:Georgia,'Times New Roman',serif;font-size:clamp(3rem,6vw,5.5rem);font-weight:520;line-height:.96;letter-spacing:-.065em;text-wrap:balance}.subtitle,.lead{max-width:72ch;margin:0;color:var(--article-muted);font-size:clamp(1.05rem,1.45vw,1.28rem);line-height:1.72}.subtitle+ .subtitle{font-size:.9rem;font-weight:800;letter-spacing:.06em;text-transform:uppercase;color:rgba(17,19,26,.52)}.meta{display:flex;flex-wrap:wrap;gap:.55rem;margin-top:.35rem}.meta-pill,.meta{color:rgba(17,19,26,.62);font-size:.82rem}.meta-pill{padding:.45rem .65rem;border:1px solid var(--article-line);border-radius:999px;background:rgba(255,255,255,.6);font-weight:800}.hero-grid{display:grid;grid-template-columns:minmax(0,1.08fr) minmax(280px,.72fr);gap:clamp(1rem,2vw,1.4rem);align-items:stretch}.hero-left{display:grid;align-content:center;gap:1rem;min-width:0}.hero-right{min-width:0}.hero-img{display:block;width:100%;height:auto;aspect-ratio:16/10;object-fit:cover;border-radius:22px;background:#dfe8ee}.hero-img-cap{margin-top:.65rem;color:rgba(17,19,26,.58);font-size:.78rem;font-weight:800;letter-spacing:.04em;text-transform:uppercase}
  .section{max-width:72ch;width:100%;margin:0 auto}.section:has(.two-col),.section:has(.grid3),.section.card,.card.section{max-width:1160px}.section>h2,.card>h2,.hsmall{margin:0 0 .8rem;color:#10131a;font-size:clamp(1.45rem,2.3vw,2.15rem);line-height:1.08;letter-spacing:-.035em}.hsmall{font-size:1rem;letter-spacing:.02em;text-transform:uppercase}.section p,.card p,.list,ul,ol{color:var(--article-muted);font-size:1rem;line-height:1.75}.card{min-width:0;border:1px solid rgba(17,19,26,.09);border-radius:24px;background:var(--article-paper);box-shadow:0 22px 70px rgba(24,47,79,.08);backdrop-filter:blur(18px);padding:clamp(1rem,2.2vw,1.65rem)}.pad{padding:clamp(1.1rem,2.4vw,1.9rem)}.grid,.grid3,.two-col,.tldr{display:grid;gap:clamp(.85rem,1.6vw,1.25rem)}.grid{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}.grid3{grid-template-columns:repeat(3,minmax(0,1fr))}.two-col{grid-template-columns:repeat(2,minmax(0,1fr));max-width:1160px}.tldr{grid-template-columns:repeat(auto-fit,minmax(230px,1fr))}.tldr-item,.mini,.callout{min-width:0;border:1px solid rgba(17,19,26,.08);border-radius:18px;background:rgba(255,255,255,.52);padding:1rem}.dot{width:.7rem;height:.7rem;border-radius:50%;background:linear-gradient(135deg,#6fdcff,#f0c36d);box-shadow:0 0 0 6px rgba(111,220,255,.12);margin-bottom:.7rem}h3,h4{margin:.1rem 0 .45rem;color:#11131a}.faq{display:grid;gap:.8rem}details{border:1px solid rgba(17,19,26,.09);border-radius:18px;background:rgba(255,255,255,.62);padding:1rem 1.1rem}summary{cursor:pointer;font-weight:850;color:#11131a}summary:focus-visible,a:focus-visible{outline:3px solid rgba(31,143,255,.38);outline-offset:4px}.note{border-left:3px solid var(--article-gold);padding-left:1rem}.footnav{display:flex;justify-content:space-between;gap:1rem;flex-wrap:wrap;max-width:1160px;width:100%;margin:0 auto}.btn{display:inline-flex;align-items:center;justify-content:center;min-height:44px;padding:.72rem 1rem;border:1px solid rgba(17,19,26,.12);border-radius:999px;background:rgba(255,255,255,.74);color:#11131a;text-decoration:none;font-size:.86rem;font-weight:850;box-shadow:0 10px 30px rgba(24,47,79,.07)}.btn:hover{transform:translateY(-1px)}.article-reveal{opacity:0;transform:translateY(18px);transition:opacity .55s ease,transform .55s ease}.article-reveal.is-visible{opacity:1;transform:none}
  @media (max-width: 1024px){.hero-grid,.two-col{grid-template-columns:1fr}.grid3{grid-template-columns:repeat(auto-fit,minmax(220px,1fr))}.section,.section:has(.two-col),.section:has(.grid3),.section.card,.card.section{max-width:72ch}h1{font-size:clamp(2.8rem,8vw,4.6rem)}}
  @media (max-width: 640px){article.page{width:min(100% - 24px,1160px);padding-top:5rem}.hero-top{align-items:flex-start}.chip{font-size:.64rem;letter-spacing:.1em;white-space:normal}h1{max-width:100%;font-size:clamp(2.5rem,13vw,3.5rem);line-height:1}.subtitle,.lead{font-size:1rem;line-height:1.65}.card{border-radius:20px}.footnav{flex-direction:column}.btn{width:100%}}
  @media (prefers-reduced-motion: reduce){*,*::before,*::after{scroll-behavior:auto}.article-atmosphere__field,.article-reveal,.btn{transition:none;transform:none}.article-reveal{opacity:1}.article-atmosphere__field{filter:blur(34px)}}
</style>

