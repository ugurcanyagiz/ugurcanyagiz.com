---
export interface Props {
  index: string;
  label: string;
  href: string;
  active?: boolean;
  className?: string;
}

const { index, label, href, active = false, className = "" } = Astro.props;
const classes = ["section-nav-button", active && "is-active", className].filter(Boolean).join(" ");
---

<a
  class={classes}
  href={href}
  data-section-nav-button
  aria-current={active ? "page" : undefined}
  aria-label={`Open ${label}`}
>
  <span class="section-nav-button__index" aria-hidden="true">{index}</span>
  <span class="section-nav-button__label">{label}</span>
  <span class="section-nav-button__indicator" aria-hidden="true"></span>
</a>
